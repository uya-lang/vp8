{
  "schema_version": 1,
  "speedup_metric": "scalar_median_ns / simd_median_ns",
  "policy": {
    "default_dispatch": "disabled_until_threshold_passes",
    "notes": [
      "A kernel can be forced for diagnosis before it passes these thresholds.",
      "Default dispatcher registration requires bit-exact output, codegen inspection, and benchmark evidence."
    ]
  },
  "kernel_classes": {
    "memory": {
      "description": "Memory-bound copy, fill, predictor, and residual store kernels.",
      "min_speedup_to_default_enable": 1.1,
      "max_regression_percent": 0.0,
      "min_repeats": 5,
      "min_warmups": 1,
      "required_checks": [
        "bit_exact",
        "codegen",
        "benchmark"
      ]
    },
    "compute": {
      "description": "Transform, filter, SAD/SSE/SATD, and arithmetic-heavy kernels.",
