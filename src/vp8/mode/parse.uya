export const VP8_Y_MODE_V: byte = 1 as byte;
export const VP8_Y_MODE_H: byte = 2 as byte;
export const VP8_Y_MODE_TM: byte = 3 as byte;
export const VP8_Y_MODE_B: byte = 4 as byte;
export const VP8_UV_MODE_DC: byte = 0 as byte;
export const VP8_UV_MODE_V: byte = 1 as byte;
export const VP8_UV_MODE_H: byte = 2 as byte;
export const VP8_UV_MODE_TM: byte = 3 as byte;
export const VP8_B_MODE_DC: byte = 0 as byte;
export const VP8_B_MODE_TM: byte = 1 as byte;
export const VP8_B_MODE_VE: byte = 2 as byte;
export const VP8_B_MODE_HE: byte = 3 as byte;
export const VP8_B_MODE_LD: byte = 4 as byte;
export const VP8_B_MODE_RD: byte = 5 as byte;
export const VP8_B_MODE_VR: byte = 6 as byte;
export const VP8_B_MODE_VL: byte = 7 as byte;
export const VP8_B_MODE_HD: byte = 8 as byte;
export const VP8_B_MODE_HU: byte = 9 as byte;
export const VP8_REF_CURRENT: byte = 0 as byte;
export const VP8_REF_LAST: byte = 1 as byte;
export const VP8_REF_GOLDEN: byte = 2 as byte;
export const VP8_REF_ALTREF: byte = 3 as byte;
export const VP8_INTER_MV_MODE_NEAREST: byte = 0 as byte;
export const VP8_INTER_MV_MODE_NEAR: byte = 1 as byte;
export const VP8_INTER_MV_MODE_ZERO: byte = 2 as byte;
export const VP8_INTER_MV_MODE_NEW: byte = 3 as byte;

error ErrVp8BModeProbOutOfBounds;
error ErrVp8MvProbOutOfBounds;
error ErrVp8MvInvalidGeometry;

export struct Vp8MotionVector {
    y: i16,
    x: i16,
    mode: byte
}

