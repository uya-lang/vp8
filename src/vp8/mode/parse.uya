export fn vp8_kf_bmode_prob(above: byte, left: byte, tree_index: usize) !byte {
    if above >= (10 as byte) || left >= (10 as byte) || tree_index >= 9 {
        return error.ErrVp8BModeProbOutOfBounds;
    }
    const base: usize = (((above as usize) * 10) + (left as usize)) * 9;
    return VP8_KF_BMODE_PROBS[base + tree_index];
}

export fn parse_key_frame_y_mode(reader: &BoolReader, probs: &Vp8Probs) !byte {
    if (try read_bit_with_probability(reader, probs.y_mode_probs[0])) == 0 {
        return VP8_Y_MODE_DC;
    }
    if (try read_bit_with_probability(reader, probs.y_mode_probs[1])) == 0 {
        return VP8_Y_MODE_V;
    }
    if (try read_bit_with_probability(reader, probs.y_mode_probs[2])) == 0 {
        return VP8_Y_MODE_H;
    }
    if (try read_bit_with_probability(reader, probs.y_mode_probs[3])) == 0 {
        return VP8_Y_MODE_TM;
    }
    return VP8_Y_MODE_B;
}

export fn parse_key_frame_uv_mode(reader: &BoolReader, probs: &Vp8Probs) !byte {
    if (try read_bit_with_probability(reader, probs.uv_mode_probs[0])) == 0 {
        return VP8_UV_MODE_DC;
    }
    if (try read_bit_with_probability(reader, probs.uv_mode_probs[1])) == 0 {
        return VP8_UV_MODE_V;
    }
    if (try read_bit_with_probability(reader, probs.uv_mode_probs[2])) == 0 {
        return VP8_UV_MODE_H;
    }
    return VP8_UV_MODE_TM;
}

export fn parse_key_frame_luma_4x4_block_mode(reader: &BoolReader, above: byte, left: byte) !byte {
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 0))) == 0 {
        return VP8_B_MODE_DC;
    }
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 1))) == 0 {
        return VP8_B_MODE_TM;
    }
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 2))) == 0 {
        return VP8_B_MODE_VE;
    }
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 3))) == 0 {
        if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 4))) == 0 {
            return VP8_B_MODE_HE;
        }
        if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 5))) == 0 {
            return VP8_B_MODE_RD;
        }
        return VP8_B_MODE_VR;
    }
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 6))) == 0 {
        return VP8_B_MODE_LD;
    }
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 7))) == 0 {
        return VP8_B_MODE_VL;
    }
    if (try read_bit_with_probability(reader, try vp8_kf_bmode_prob(above, left, 8))) == 0 {
        return VP8_B_MODE_HD;
    }
    return VP8_B_MODE_HU;
}

export fn parse_key_frame_luma_4x4_modes(reader: &BoolReader, above_modes: &byte, left_modes: &byte, output_modes: &byte) !void {
    var by: usize = 0;
    while by < 4 {
        var bx: usize = 0;
        while bx < 4 {
            const index: usize = (by * 4) + bx;
            var above: byte = 0 as byte;
            var left: byte = 0 as byte;
            if by == 0 {
                above = above_modes[bx];
            } else {
                above = output_modes[index - 4];
            }
            if bx == 0 {
                left = left_modes[by];
            } else {
                left = output_modes[index - 1];
            }
            output_modes[index] = try parse_key_frame_luma_4x4_block_mode(reader, above, left);
            bx = bx + 1;
        }
        by = by + 1;
    }

    var col: usize = 0;
    while col < 4 {
        above_modes[col] = output_modes[12 + col];
        col = col + 1;
    }

    var row: usize = 0;
    while row < 4 {
        left_modes[row] = output_modes[(row * 4) + 3];
        row = row + 1;
    }
}

export fn parse_inter_intra_flag(reader: &BoolReader, prob_inter: byte) !bool {
    return (try read_bit_with_probability(reader, prob_inter)) != 0;
}

export fn parse_inter_reference_frame(reader: &BoolReader, prob_last: byte, prob_gf: byte) !byte {
    if (try read_bit_with_probability(reader, prob_last)) == 0 {
        return VP8_REF_LAST;
    }
    if (try read_bit_with_probability(reader, prob_gf)) == 0 {
        return VP8_REF_GOLDEN;
    }
    return VP8_REF_ALTREF;
}

export fn parse_skip_coefficient_flag(reader: &BoolReader, skip_enabled: bool, prob_skip_false: byte) !bool {
    if !skip_enabled {
        return false;
    }
    return (try read_bit_with_probability(reader, prob_skip_false)) != 0;
}

fn parse_inter_mv_mode(reader: &BoolReader) !byte {
    if (try read_bit_with_probability(reader, 2 as byte)) == 0 {
        return VP8_INTER_MV_MODE_ZERO;
    }
    if (try read_bit_with_probability(reader, 173 as byte)) != 0 {
        return VP8_INTER_MV_MODE_NEW;
    }
    if (try read_bit_with_probability(reader, 34 as byte)) != 0 {
        return VP8_INTER_MV_MODE_ZERO;
    }
    if (try read_bit_with_probability(reader, 173 as byte)) != 0 {
        return VP8_INTER_MV_MODE_NEAR;
    }
    return VP8_INTER_MV_MODE_NEAREST;
}

fn parse_small_mv_component(reader: &BoolReader, probs: &byte) !i16 {
    if (try read_bit_with_probability(reader, probs[2])) == 0 {
        if (try read_bit_with_probability(reader, probs[3])) == 0 {
            if (try read_bit_with_probability(reader, probs[4])) == 0 {
                return 0 as i16;
            }
            return 1 as i16;
        }
        if (try read_bit_with_probability(reader, probs[5])) == 0 {
            return 2 as i16;
        }
        return 3 as i16;
    }

    if (try read_bit_with_probability(reader, probs[6])) == 0 {
        if (try read_bit_with_probability(reader, probs[7])) == 0 {
            return 4 as i16;
        }
        return 5 as i16;
    }
    if (try read_bit_with_probability(reader, probs[8])) == 0 {
        return 6 as i16;
    }
    return 7 as i16;
}

fn parse_large_mv_component(reader: &BoolReader, probs: &byte) !i16 {
    var magnitude: i16 = (try read_literal(reader, 4 as u8)) as i16;
    var bit_index: usize = 0;
    while bit_index < 4 {
        if (try read_bit_with_probability(reader, probs[9 + bit_index])) != 0 {
            magnitude = (magnitude + ((16 as i16) << (bit_index as i32))) as i16;
        }
        bit_index = bit_index + 1;
    }
    return magnitude;
}

fn parse_mv_component(reader: &BoolReader, probs: &byte) !i16 {
    var magnitude: i16 = 0;
    if (try read_bit_with_probability(reader, probs[0])) == 0 {
        magnitude = try parse_small_mv_component(reader, probs);
    } else {
        magnitude = try parse_large_mv_component(reader, probs);
    }

    if magnitude != 0 && (try read_bit_with_probability(reader, probs[1])) != 0 {
        return (0 - magnitude) as i16;
    }
    return magnitude;
}

export fn parse_inter_motion_vector(reader: &BoolReader, probs: &Vp8Probs, nearest: &Vp8MotionVector, near: &Vp8MotionVector, new_base: &Vp8MotionVector) !Vp8MotionVector {
    if probs.mv_prob_count < 38 {
        return error.ErrVp8MvProbOutOfBounds;
    }

    const mode: byte = try parse_inter_mv_mode(reader);
    if mode == VP8_INTER_MV_MODE_NEAREST {
        return Vp8MotionVector{ y: nearest.y, x: nearest.x, mode: mode };
    }
    if mode == VP8_INTER_MV_MODE_NEAR {
        return Vp8MotionVector{ y: near.y, x: near.x, mode: mode };
    }
    if mode == VP8_INTER_MV_MODE_ZERO {
        return Vp8MotionVector{ y: 0, x: 0, mode: mode };
    }

    const delta_y: i16 = try parse_mv_component(reader, &probs.mv_probs[0] as &byte);
    const delta_x: i16 = try parse_mv_component(reader, &probs.mv_probs[19] as &byte);
    return Vp8MotionVector{
        y: (new_base.y + delta_y) as i16,
        x: (new_base.x + delta_x) as i16,
        mode: mode
    };
}

fn validate_mv_geometry(mb_x: usize, mb_y: usize, frame_width: usize, frame_height: usize, block_width: usize, block_height: usize) !void {
    if frame_width == 0 || frame_height == 0 || block_width == 0 || block_height == 0 {
        return error.ErrVp8MvInvalidGeometry;
    }
    if block_width > frame_width || block_height > frame_height {
        return error.ErrVp8MvInvalidGeometry;
    }

    const origin_x: usize = mb_x * (16 as usize);
    const origin_y: usize = mb_y * (16 as usize);
    if origin_x > frame_width || origin_y > frame_height {
        return error.ErrVp8MvInvalidGeometry;
    }
    if origin_x + block_width > frame_width || origin_y + block_height > frame_height {
        return error.ErrVp8MvInvalidGeometry;
    }
}

fn clamp_i32_to_i16(value: i32, min_value: i32, max_value: i32) i16 {
    var clamped: i32 = value;
    if clamped < min_value {
        clamped = min_value;
    }
    if clamped > max_value {
        clamped = max_value;
    }
    return clamped as i16;
}

fn motion_vector_bounds(mb_coord: usize, frame_size: usize, block_size: usize, min_out: &i32, max_out: &i32) void {
    const origin_subpel: i32 = (mb_coord as i32) * 16 * 8;
    min_out[0] = 0 - origin_subpel;
    max_out[0] = (((frame_size - block_size) as i32) * 8) - origin_subpel;
}

export fn clamp_inter_motion_vector(mv: &Vp8MotionVector, mb_x: usize, mb_y: usize, frame_width: usize, frame_height: usize, block_width: usize, block_height: usize) !Vp8MotionVector {
    try validate_mv_geometry(mb_x, mb_y, frame_width, frame_height, block_width, block_height);

    var min_x: i32 = 0;
    var max_x: i32 = 0;
    var min_y: i32 = 0;
    var max_y: i32 = 0;
    motion_vector_bounds(mb_x, frame_width, block_width, &min_x as &i32, &max_x as &i32);
    motion_vector_bounds(mb_y, frame_height, block_height, &min_y as &i32, &max_y as &i32);

    return Vp8MotionVector{
        y: clamp_i32_to_i16(mv.y as i32, min_y, max_y),
        x: clamp_i32_to_i16(mv.x as i32, min_x, max_x),
        mode: mv.mode
    };
}

export fn inter_motion_vector_inside_frame(mv: &Vp8MotionVector, mb_x: usize, mb_y: usize, frame_width: usize, frame_height: usize, block_width: usize, block_height: usize) !bool {
    try validate_mv_geometry(mb_x, mb_y, frame_width, frame_height, block_width, block_height);

    var min_x: i32 = 0;
    var max_x: i32 = 0;
    var min_y: i32 = 0;
    var max_y: i32 = 0;
    motion_vector_bounds(mb_x, frame_width, block_width, &min_x as &i32, &max_x as &i32);
    motion_vector_bounds(mb_y, frame_height, block_height, &min_y as &i32, &max_y as &i32);

    return (mv.x as i32) >= min_x && (mv.x as i32) <= max_x && (mv.y as i32) >= min_y && (mv.y as i32) <= max_y;
}
