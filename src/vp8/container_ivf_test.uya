use std.testing.assert_eq_i32;

use bitstream.readers.BoundedSlice;
use container.ivf.IvfHeader;
use container.ivf.IvfFrame;
use container.ivf.IvfFrameIterator;
use container.ivf.ivf_frame_iterator_has_next;
use container.ivf.ivf_frame_iterator_next;
use container.ivf.make_ivf_frame_iterator;
use container.ivf.parse_ivf_header;
use container.ivf.write_ivf_frame_header;
use container.ivf.write_ivf_header;

fn dummy_header() IvfHeader {
    return IvfHeader{
        version: 0,
        header_size: 0,
        width: 0,
        height: 0,
        timebase_denominator: 0,
        timebase_numerator: 0,
        frame_count: 0,
        unused: 0
    };
}

test "parse IVF VP8 header" {
    var data: [byte: 32] = [
        'D' as byte, 'K' as byte, 'I' as byte, 'F' as byte,
        0x00, 0x00, 0x20, 0x00,
        'V' as byte, 'P' as byte, '8' as byte, '0' as byte,
        0x80, 0x02, 0xe0, 0x01,
        0x1e, 0x00, 0x00, 0x00,
        0x01, 0x00, 0x00, 0x00,
        0x2a, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00
    ];

    const header: IvfHeader = try parse_ivf_header(&data[0] as &byte, 32);

    try assert_eq_i32(header.version as i32, 0);
    try assert_eq_i32(header.header_size as i32, 32);
    try assert_eq_i32(header.width as i32, 640);
    try assert_eq_i32(header.height as i32, 480);
    try assert_eq_i32(header.timebase_denominator as i32, 30);
    try assert_eq_i32(header.timebase_numerator as i32, 1);
    try assert_eq_i32(header.frame_count as i32, 42);
}

test "reject malformed IVF header" {
    var short_data: [byte: 3] = [ 'D' as byte, 'K' as byte, 'I' as byte ];
    var bad_signature: [byte: 32] = [
        'B' as byte, 'A' as byte, 'D' as byte, '!' as byte,
        0x00, 0x00, 0x20, 0x00,
        'V' as byte, 'P' as byte, '8' as byte, '0' as byte,
        0x80, 0x02, 0xe0, 0x01,
        0x1e, 0x00, 0x00, 0x00,
        0x01, 0x00, 0x00, 0x00,
        0x2a, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00
    ];
    var bad_fourcc: [byte: 32] = [
        'D' as byte, 'K' as byte, 'I' as byte, 'F' as byte,
        0x00, 0x00, 0x20, 0x00,
        'A' as byte, 'V' as byte, '1' as byte, '0' as byte,
        0x80, 0x02, 0xe0, 0x01,
        0x1e, 0x00, 0x00, 0x00,
        0x01, 0x00, 0x00, 0x00,
        0x2a, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00
    ];

    var short_failed: i32 = 0;
    var signature_failed: i32 = 0;
    var fourcc_failed: i32 = 0;

    _ = parse_ivf_header(&short_data[0] as &byte, 3) catch {
        short_failed = 1;
        dummy_header();
    };
    _ = parse_ivf_header(&bad_signature[0] as &byte, 32) catch {
        signature_failed = 1;
        dummy_header();
    };
    _ = parse_ivf_header(&bad_fourcc[0] as &byte, 32) catch {
        fourcc_failed = 1;
        dummy_header();
    };

    try assert_eq_i32(short_failed, 1);
    try assert_eq_i32(signature_failed, 1);
    try assert_eq_i32(fourcc_failed, 1);
}

test "iterate IVF frames" {
    var data: [byte: 53] = [
        'D' as byte, 'K' as byte, 'I' as byte, 'F' as byte,
        0x00, 0x00, 0x20, 0x00,
        'V' as byte, 'P' as byte, '8' as byte, '0' as byte,
        0x02, 0x00, 0x02, 0x00,
        0x1e, 0x00, 0x00, 0x00,
        0x01, 0x00, 0x00, 0x00,
        0x02, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x03, 0x00, 0x00, 0x00,
        0x0a, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0xaa, 0xbb, 0xcc,
        0x02, 0x00, 0x00, 0x00,
        0x0b, 0x00
    ];

    const header: IvfHeader = try parse_ivf_header(&data[0] as &byte, 53);
    var iterator: IvfFrameIterator = try make_ivf_frame_iterator(&data[0] as &byte, 53, &header);

    try assert_eq_i32(ivf_frame_iterator_has_next(&iterator) as i32, true as i32);
    const frame0: IvfFrame = try ivf_frame_iterator_next(&iterator);
    try assert_eq_i32(frame0.index as i32, 0);
    try assert_eq_i32(frame0.timestamp as i32, 10);
    try assert_eq_i32(frame0.payload.len as i32, 3);
    try assert_eq_i32(frame0.payload.data[2] as i32, 0xcc);

    const failed_frame1: IvfFrame = ivf_frame_iterator_next(&iterator) catch {
        dummy_header();
        IvfFrame{ index: 99, timestamp: 99, payload: BoundedSlice{ data: &data[0] as &byte, len: 99 } };
    };
    try assert_eq_i32(failed_frame1.index as i32, 99);
    try assert_eq_i32(ivf_frame_iterator_has_next(&iterator) as i32, true as i32);
}

test "write IVF header and frame header" {
    var out: [byte: 47] = [];
    const source: IvfHeader = IvfHeader{
        version: 0,
        header_size: 32,
        width: 16,
        height: 8,
        timebase_denominator: 60,
        timebase_numerator: 1,
        frame_count: 1,
        unused: 0
    };

    try write_ivf_header(&out[0] as &byte, 47, &source);
    try write_ivf_frame_header(&out[0] as &byte, 47, 32, 3, 123);
    out[44] = 0xde;
    out[45] = 0xad;
    out[46] = 0xbe;

    const parsed: IvfHeader = try parse_ivf_header(&out[0] as &byte, 47);
    var iterator: IvfFrameIterator = try make_ivf_frame_iterator(&out[0] as &byte, 47, &parsed);
    const frame: IvfFrame = try ivf_frame_iterator_next(&iterator);

    try assert_eq_i32(parsed.width as i32, 16);
    try assert_eq_i32(parsed.height as i32, 8);
    try assert_eq_i32(parsed.timebase_denominator as i32, 60);
    try assert_eq_i32(frame.timestamp as i32, 123);
    try assert_eq_i32(frame.payload.len as i32, 3);
    try assert_eq_i32(frame.payload.data[1] as i32, 0xad);
    try assert_eq_i32(ivf_frame_iterator_has_next(&iterator) as i32, false as i32);
}

test "IVF writer rejects short output" {
    var out: [byte: 16] = [];
    const source: IvfHeader = dummy_header();
    var header_failed: i32 = 0;
    var frame_failed: i32 = 0;

    _ = write_ivf_header(&out[0] as &byte, 16, &source) catch {
        header_failed = 1;
    };
    _ = write_ivf_frame_header(&out[0] as &byte, 16, 8, 9, 10) catch {
        frame_failed = 1;
    };

    try assert_eq_i32(header_failed, 1);
    try assert_eq_i32(frame_failed, 1);
}
