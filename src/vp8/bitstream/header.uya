use vp8.bitstream.readers.read_le_u24_at;
use vp8.bitstream.readers.BoundedSlice;
use vp8.bitstream.readers.read_le_u16_at;
use vp8.bitstream.readers.read_slice_at;
use vp8.bitstream.bool_reader.BoolReader;
use vp8.bitstream.bool_reader.make_bool_reader_for_partition;
use vp8.bitstream.bool_reader.read_bit_with_probability;
use vp8.bitstream.bool_reader.read_literal;
use vp8.bitstream.bool_reader.read_signed_value;

error ErrInvalidKeyFrameStartCode;
error ErrFirstPartitionOutOfBounds;
error ErrInvalidTokenPartitionCount;
error ErrTokenPartitionOutOfBounds;

export struct Vp8FrameHeader {
    frame_type: u8,
    version: u8,
    show_frame: bool,
    first_partition_size: u32,
    width: u16,
    height: u16,
    horizontal_scale: u8,
    vertical_scale: u8
}

export struct Vp8Segmentation {
    enabled: bool,
    update_map: bool,
    update_data: bool,
    absolute_delta: bool,
    quantizer_delta: [i16: 4],
    loop_filter_delta: [i8: 4],
    segment_prob: [byte: 3]
}

export struct Vp8LoopFilterHeader {
    filter_type: u8,
    level: u8,
    sharpness: u8,
    delta_enabled: bool,
    delta_update: bool,
    ref_delta: [i8: 4],
    mode_delta: [i8: 4]
}

export struct Vp8QuantHeader {
    base_qindex: u8,
    y1_dc_delta: i8,
    y2_dc_delta: i8,
    y2_ac_delta: i8,
    uv_dc_delta: i8,
    uv_ac_delta: i8
}

export struct Vp8Probs {
    y_mode_probs: [byte: 4],
    uv_mode_probs: [byte: 3],
    coeff_probs: &byte,
    coeff_prob_count: usize,
    mv_probs: &byte,
    mv_prob_count: usize
}

