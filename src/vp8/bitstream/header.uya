export fn vp8_default_probs() Vp8Probs {
    return Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &VP8_DEFAULT_COEFF_PROBS[0] as &byte,
        coeff_prob_count: VP8_COEFF_PROB_COUNT,
        mv_probs: &VP8_DEFAULT_MV_PROBS[0] as &byte,
        mv_prob_count: VP8_MV_PROB_COUNT
    };
}

export struct Vp8FrameTag {
    frame_type: u8,
    version: u8,
    show_frame: bool,
    first_partition_size: u32
}

export struct Vp8KeyFrameSize {
    width: u16,
    height: u16,
    horizontal_scale: u8,
    vertical_scale: u8
}

export fn parse_vp8_frame_tag(data: &byte, len: usize) !Vp8FrameTag {
    const tag: u32 = try read_le_u24_at(data, len, 0);
    return Vp8FrameTag{
        frame_type: (tag & (0x01 as u32)) as u8,
        version: ((tag >> 1) & (0x07 as u32)) as u8,
        show_frame: (((tag >> 4) & (0x01 as u32)) != 0),
        first_partition_size: tag >> 5
    };
}

export fn parse_vp8_frame_tag_checked(data: &byte, len: usize) !Vp8FrameTag {
    const tag: Vp8FrameTag = try parse_vp8_frame_tag(data, len);
    const remaining: usize = len - 3;
    if (tag.first_partition_size as usize) > remaining {
        return error.ErrFirstPartitionOutOfBounds;
    }

    return tag;
}

export fn parse_key_frame_start_code(data: &byte, len: usize) !void {
    const start_code: BoundedSlice = try read_slice_at(data, len, 3, 3);
    if start_code.data[0] != 0x9d as byte || start_code.data[1] != 0x01 as byte || start_code.data[2] != 0x2a as byte {
        return error.ErrInvalidKeyFrameStartCode;
    }
}

export fn parse_key_frame_size(data: &byte, len: usize) !Vp8KeyFrameSize {
    try parse_key_frame_start_code(data, len);
    const width_word: u16 = try read_le_u16_at(data, len, 6);
    const height_word: u16 = try read_le_u16_at(data, len, 8);

    return Vp8KeyFrameSize{
        width: width_word & (0x3fff as u16),
        height: height_word & (0x3fff as u16),
        horizontal_scale: ((width_word >> 14) & (0x03 as u16)) as u8,
        vertical_scale: ((height_word >> 14) & (0x03 as u16)) as u8
    };
}
