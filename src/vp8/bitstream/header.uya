export fn vp8_default_probs() Vp8Probs {
    return Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &VP8_DEFAULT_COEFF_PROBS[0] as &byte,
        coeff_prob_count: VP8_COEFF_PROB_COUNT,
        mv_probs: &VP8_DEFAULT_MV_PROBS[0] as &byte,
        mv_prob_count: VP8_MV_PROB_COUNT
    };
}

export fn reset_vp8_key_frame_probs(probs: &Vp8Probs) void {
    probs.y_mode_probs[0] = 112 as byte;
    probs.y_mode_probs[1] = 86 as byte;
    probs.y_mode_probs[2] = 140 as byte;
    probs.y_mode_probs[3] = 37 as byte;
    probs.uv_mode_probs[0] = 162 as byte;
    probs.uv_mode_probs[1] = 101 as byte;
    probs.uv_mode_probs[2] = 204 as byte;

    var index: usize = 0;
    while index < VP8_COEFF_PROB_COUNT {
        probs.coeff_probs[index] = VP8_DEFAULT_COEFF_PROBS[index];
        index = index + 1;
    }

    index = 0;
    while index < VP8_MV_PROB_COUNT {
        probs.mv_probs[index] = VP8_DEFAULT_MV_PROBS[index];
        index = index + 1;
    }
}

export fn vp8_coeff_update_probability(index: usize) byte {
    if index >= VP8_COEFF_PROB_COUNT {
        return 255 as byte;
    }

    return VP8_COEFF_UPDATE_PROBS[index];
}

export fn parse_vp8_coeff_probability_updates(reader: &BoolReader, probs: &Vp8Probs) !void {
    var index: usize = 0;
    while index < VP8_COEFF_PROB_COUNT {
        if (try read_bit_with_probability(reader, VP8_COEFF_UPDATE_PROBS[index])) != 0 {
            probs.coeff_probs[index] = (try read_literal(reader, 8 as u8)) as byte;
        }
        index = index + 1;
    }
}

export fn vp8_mv_update_probability(index: usize) byte {
    if index >= VP8_MV_PROB_COUNT {
        return 255 as byte;
    }

    return VP8_MV_UPDATE_PROBS[index];
}

export fn parse_vp8_mv_probability_updates(reader: &BoolReader, probs: &Vp8Probs) !void {
    var index: usize = 0;
    while index < VP8_MV_PROB_COUNT {
        if (try read_bit_with_probability(reader, VP8_MV_UPDATE_PROBS[index])) != 0 {
            probs.mv_probs[index] = (try read_literal(reader, 7 as u8)) as byte;
        }
        index = index + 1;
    }
}

export fn parse_vp8_frame_probability_updates(reader: &BoolReader, probs: &Vp8Probs, key_frame: bool) !void {
    if key_frame {
        reset_vp8_key_frame_probs(probs);
    }

    try parse_vp8_coeff_probability_updates(reader, probs);
    if key_frame {
        return;
    }
    try parse_vp8_mv_probability_updates(reader, probs);
}

export fn parse_vp8_segmentation(reader: &BoolReader) !Vp8Segmentation {
    var segmentation: Vp8Segmentation = Vp8Segmentation{
        enabled: false,
        update_map: false,
        update_data: false,
        absolute_delta: false,
        quantizer_delta: [ 0, 0, 0, 0 ],
        loop_filter_delta: [ 0, 0, 0, 0 ],
        segment_prob: [ 255, 255, 255 ]
    };

    segmentation.enabled = (try read_bit_with_probability(reader, 128 as byte)) != 0;
    if !segmentation.enabled {
        return segmentation;
    }

    segmentation.update_map = (try read_bit_with_probability(reader, 128 as byte)) != 0;
    segmentation.update_data = (try read_bit_with_probability(reader, 128 as byte)) != 0;

    if segmentation.update_data {
        segmentation.absolute_delta = (try read_bit_with_probability(reader, 128 as byte)) != 0;

        var quant_index: usize = 0;
        while quant_index < 4 {
            if (try read_bit_with_probability(reader, 128 as byte)) != 0 {
                segmentation.quantizer_delta[quant_index] = (try read_signed_value(reader, 7 as u8)) as i16;
            }
            quant_index = quant_index + 1;
        }

        var filter_index: usize = 0;
        while filter_index < 4 {
            if (try read_bit_with_probability(reader, 128 as byte)) != 0 {
                segmentation.loop_filter_delta[filter_index] = (try read_signed_value(reader, 6 as u8)) as i8;
            }
            filter_index = filter_index + 1;
        }
    }

    if segmentation.update_map {
        var prob_index: usize = 0;
        while prob_index < 3 {
            if (try read_bit_with_probability(reader, 128 as byte)) != 0 {
                segmentation.segment_prob[prob_index] = (try read_literal(reader, 8 as u8)) as byte;
            }
            prob_index = prob_index + 1;
        }
    }

    return segmentation;
}

export fn parse_vp8_loop_filter(reader: &BoolReader) !Vp8LoopFilterHeader {
    var loop_filter: Vp8LoopFilterHeader = Vp8LoopFilterHeader{
        filter_type: 0,
        level: 0,
        sharpness: 0,
        delta_enabled: false,
        delta_update: false,
        ref_delta: [ 2, -1, -1, 1 ],
        mode_delta: [ 4, -1, 2, 4 ]
    };

    loop_filter.filter_type = try read_bit_with_probability(reader, 128 as byte);
    loop_filter.level = (try read_literal(reader, 6 as u8)) as u8;
    loop_filter.sharpness = (try read_literal(reader, 3 as u8)) as u8;
    loop_filter.delta_enabled = (try read_bit_with_probability(reader, 128 as byte)) != 0;

    if loop_filter.delta_enabled {
        loop_filter.delta_update = (try read_bit_with_probability(reader, 128 as byte)) != 0;
        if loop_filter.delta_update {
            var ref_index: usize = 0;
            while ref_index < 4 {
                if (try read_bit_with_probability(reader, 128 as byte)) != 0 {
                    loop_filter.ref_delta[ref_index] = (try read_signed_value(reader, 6 as u8)) as i8;
                }
                ref_index = ref_index + 1;
            }

            var mode_index: usize = 0;
            while mode_index < 4 {
                if (try read_bit_with_probability(reader, 128 as byte)) != 0 {
                    loop_filter.mode_delta[mode_index] = (try read_signed_value(reader, 6 as u8)) as i8;
                }
                mode_index = mode_index + 1;
            }
        }
    }

    return loop_filter;
}

fn read_vp8_quant_delta(reader: &BoolReader) !i8 {
    if (try read_bit_with_probability(reader, 128 as byte)) == 0 {
        return 0 as i8;
    }

    return (try read_signed_value(reader, 4 as u8)) as i8;
}

export fn parse_vp8_quant(reader: &BoolReader) !Vp8QuantHeader {
    return Vp8QuantHeader{
        base_qindex: (try read_literal(reader, 7 as u8)) as u8,
        y1_dc_delta: try read_vp8_quant_delta(reader),
        y2_dc_delta: try read_vp8_quant_delta(reader),
        y2_ac_delta: try read_vp8_quant_delta(reader),
        uv_dc_delta: try read_vp8_quant_delta(reader),
        uv_ac_delta: try read_vp8_quant_delta(reader)
    };
}

export fn parse_vp8_token_partition_count(reader: &BoolReader) !u8 {
    const code: u32 = try read_literal(reader, 2 as u8);
    return (1 as u8) << (code as i32);
}

fn validate_vp8_token_partition_count(count: u8) !void {
    if count == (1 as u8) || count == (2 as u8) || count == (4 as u8) || count == (8 as u8) {
        return;
    }

    return error.ErrInvalidTokenPartitionCount;
}

export fn vp8_token_partition_for_row(mb_row: usize, token_partition_count: u8) !u8 {
    try validate_vp8_token_partition_count(token_partition_count);
    return (mb_row % (token_partition_count as usize)) as u8;
}

export fn parse_vp8_token_partition_readers(data: &byte, len: usize, first_partition_offset: usize, first_partition_size: u32, token_partition_count: u8, readers: &BoolReader) !void {
    try validate_vp8_token_partition_count(token_partition_count);

    if first_partition_offset > len {
        return error.ErrFirstPartitionOutOfBounds;
    }

    const first_partition_end: usize = first_partition_offset + (first_partition_size as usize);
    if first_partition_end < first_partition_offset || first_partition_end > len {
        return error.ErrFirstPartitionOutOfBounds;
    }

    const size_table_len: usize = ((token_partition_count as usize) - 1) * 3;
    if (len - first_partition_end) < size_table_len {
        return error.ErrTokenPartitionOutOfBounds;
    }

    const size_table_offset: usize = first_partition_end;
    var partition_offset: usize = first_partition_end + size_table_len;
    var index: usize = 0;

    while index < (token_partition_count as usize) {
        var partition_len: usize = 0;
        if index + 1 < (token_partition_count as usize) {
            partition_len = (try read_le_u24_at(data, len, size_table_offset + (index * 3))) as usize;
            if partition_len > (len - partition_offset) {
                return error.ErrTokenPartitionOutOfBounds;
            }
        } else {
            partition_len = len - partition_offset;
        }

        readers[index] = try make_bool_reader_for_partition(&data[partition_offset] as &byte, partition_len, index as i32);
        partition_offset = partition_offset + partition_len;
        index = index + 1;
    }
}

export struct Vp8FrameTag {
    frame_type: u8,
    version: u8,
    show_frame: bool,
    first_partition_size: u32
}

export struct Vp8KeyFrameSize {
    width: u16,
    height: u16,
    horizontal_scale: u8,
    vertical_scale: u8
}

export struct Vp8KeyFrameColorConfig {
    color_space: u8,
    clamping_type: u8
}

export struct Vp8SkipCoeffHeader {
    enabled: bool,
    prob_skip_false: byte
}

export fn parse_vp8_key_frame_color_config(reader: &BoolReader) !Vp8KeyFrameColorConfig {
    return Vp8KeyFrameColorConfig{
        color_space: try read_bit_with_probability(reader, 128 as byte),
        clamping_type: try read_bit_with_probability(reader, 128 as byte)
    };
}

export fn parse_vp8_refresh_entropy(reader: &BoolReader) !bool {
    return (try read_bit_with_probability(reader, 128 as byte)) != 0;
}

export fn parse_vp8_skip_coeff_header(reader: &BoolReader) !Vp8SkipCoeffHeader {
    const enabled: bool = (try read_bit_with_probability(reader, 128 as byte)) != 0;
    var prob_skip_false: byte = 0 as byte;
    if enabled {
        prob_skip_false = (try read_literal(reader, 8 as u8)) as byte;
    }

    return Vp8SkipCoeffHeader{
        enabled: enabled,
        prob_skip_false: prob_skip_false
    };
}

export fn parse_vp8_frame_tag(data: &byte, len: usize) !Vp8FrameTag {
    const tag: u32 = try read_le_u24_at(data, len, 0);
    return Vp8FrameTag{
        frame_type: (tag & (0x01 as u32)) as u8,
        version: ((tag >> 1) & (0x07 as u32)) as u8,
        show_frame: (((tag >> 4) & (0x01 as u32)) != 0),
        first_partition_size: tag >> 5
    };
}

export fn parse_vp8_frame_tag_checked(data: &byte, len: usize) !Vp8FrameTag {
    const tag: Vp8FrameTag = try parse_vp8_frame_tag(data, len);
    var first_partition_offset: usize = 3;
    if tag.frame_type == (0 as u8) {
        if len < 10 {
            return error.ErrFirstPartitionOutOfBounds;
        }
        first_partition_offset = 10;
    }

    const remaining: usize = len - first_partition_offset;
    if (tag.first_partition_size as usize) > remaining {
        return error.ErrFirstPartitionOutOfBounds;
    }

    return tag;
}

export fn parse_key_frame_start_code(data: &byte, len: usize) !void {
    const start_code: BoundedSlice = try read_slice_at(data, len, 3, 3);
    if start_code.data[0] != 0x9d as byte || start_code.data[1] != 0x01 as byte || start_code.data[2] != 0x2a as byte {
        return error.ErrInvalidKeyFrameStartCode;
    }
}

export fn parse_key_frame_size(data: &byte, len: usize) !Vp8KeyFrameSize {
    try parse_key_frame_start_code(data, len);
    const width_word: u16 = try read_le_u16_at(data, len, 6);
    const height_word: u16 = try read_le_u16_at(data, len, 8);

    return Vp8KeyFrameSize{
        width: width_word & (0x3fff as u16),
        height: height_word & (0x3fff as u16),
        horizontal_scale: ((width_word >> 14) & (0x03 as u16)) as u8,
        vertical_scale: ((height_word >> 14) & (0x03 as u16)) as u8
    };
}

export fn parse_vp8_key_frame_header(data: &byte, len: usize) !Vp8FrameHeader {
    const tag: Vp8FrameTag = try parse_vp8_frame_tag(data, len);
    const size: Vp8KeyFrameSize = try parse_key_frame_size(data, len);

    return Vp8FrameHeader{
        frame_type: tag.frame_type,
        version: tag.version,
        show_frame: tag.show_frame,
        first_partition_size: tag.first_partition_size,
        width: size.width,
        height: size.height,
        horizontal_scale: size.horizontal_scale,
        vertical_scale: size.vertical_scale
    };
}
