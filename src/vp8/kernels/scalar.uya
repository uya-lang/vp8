        const base: usize = row * dst_stride;
        const left_value: i32 = left[row] as i32;
        var col: usize = 0;
        while col < 8 {
            dst[base + col] = clip_i32_to_u8(left_value + (above[col] as i32) - (above_left as i32));
            col = col + 1;
        }
        row = row + 1;
    }
}

export fn predict_y16x16_dc(dst: &byte, dst_stride: usize, above: &byte, has_above: bool, left: &byte, has_left: bool) void {
    var sum: i32 = 0;
    var value: byte = 128 as byte;

    if has_above {
        var col: usize = 0;
        while col < 16 {
            sum = sum + (above[col] as i32);
            col = col + 1;
        }
    }
    if has_left {
        var row: usize = 0;
        while row < 16 {
            sum = sum + (left[row] as i32);
            row = row + 1;
        }
    }

    if has_above && has_left {
        value = ((sum + 16) >> 5) as byte;
    } else if has_above || has_left {
        value = ((sum + 8) >> 4) as byte;
    }

    fill_16x16(dst, dst_stride, value);
}

