export fn predict_y16x16_true_motion(dst: &byte, dst_stride: usize, above: &byte, left: &byte, above_left: byte) void {
    var row: usize = 0;
    while row < 16 {
        const base: usize = row * dst_stride;
        const left_value: i32 = left[row] as i32;
        var col: usize = 0;
        while col < 16 {
            dst[base + col] = clip_i32_to_u8(left_value + (above[col] as i32) - (above_left as i32));
