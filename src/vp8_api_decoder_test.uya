use std.testing.assert_eq_i32;
use std.testing.expect;

use vp8.api.Vp8DecodedFrame;
use vp8.api.Vp8Decoder;
use vp8.api.Vp8DecoderOptions;
use vp8.api.Vp8DecoderStats;
use vp8.api.empty_vp8_decoder;
use vp8.api.make_vp8_decoder_options;
use vp8.api.vp8_decoded_frame_release;
use vp8.api.vp8_decoder_decode_frame;
use vp8.api.vp8_decoder_deinit;
use vp8.api.vp8_decoder_flush;
use vp8.api.vp8_decoder_init;
use vp8.api.vp8_decoder_set_simd_level;
use vp8.api.vp8_decoder_stats;
use vp8.bitstream.bool_writer.BoolWriter;
use vp8.bitstream.bool_writer.bool_writer_byte_count;
use vp8.bitstream.bool_writer.bool_writer_flush;
use vp8.bitstream.bool_writer.bool_writer_write;
use vp8.bitstream.bool_writer.make_bool_writer;
use vp8.bitstream.header.Vp8Probs;
use vp8.bitstream.header.vp8_coeff_update_probability;
use vp8.bitstream.header.vp8_default_probs;
use vp8.common.cpu.SimdLevel;

fn write_literal(writer: &BoolWriter, value: u32, bit_count: u8) !void {
    var index: i8 = (bit_count as i8) - 1;
    while index >= 0 {
        try bool_writer_write(writer, ((value >> (index as u8)) & (1 as u32)) as u8, 128 as byte);
        index = index - 1;
    }
}

fn write_api_minimal_key_frame_partition(writer: &BoolWriter) !void {
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 1 as u8);
    try write_literal(writer, 0, 6 as u8);
    try write_literal(writer, 0, 3 as u8);
    try write_literal(writer, 0, 2 as u8);
    try write_literal(writer, 0, 7 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);

    var index: usize = 0;
    while index < 1056 {
        try bool_writer_write(writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    const key_y_mode_probs: [byte: 4] = [ 145, 156, 163, 128 ];
    const key_uv_mode_probs: [byte: 3] = [ 142, 114, 183 ];
    try bool_writer_write(writer, 1 as u8, key_y_mode_probs[0]);
    try bool_writer_write(writer, 0 as u8, key_y_mode_probs[1]);
    try bool_writer_write(writer, 0 as u8, key_y_mode_probs[2]);
    try bool_writer_write(writer, 0 as u8, key_uv_mode_probs[0]);
    try bool_writer_flush(writer);
}

fn api_coeff_prob_offset(block_type: usize, position: usize, context: byte) usize {
    const band: usize = 0;
    return ((((block_type * (8 as usize)) + band) * (3 as usize)) + (context as usize)) * (11 as usize);
}

fn write_api_eob_token(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = api_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset]);
}

fn write_api_all_eob_tokens(writer: &BoolWriter, probs: &Vp8Probs) !void {
    var block: usize = 0;
    while block < 16 {
        try write_api_eob_token(writer, probs.coeff_probs, 0, 0, 0 as byte);
        block = block + 1;
    }

    block = 0;
    while block < 8 {
        try write_api_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn make_api_16x16_key_frame(first_partition: &byte, token_partition: &byte, token_partition_len: usize, frame: &byte) usize {
    const first_partition_size: u32 = 256 as u32;
    const tag: u32 = (0 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | (first_partition_size << 5);
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;
    frame[3] = 0x9d as byte;
    frame[4] = 0x01 as byte;
    frame[5] = 0x2a as byte;
    frame[6] = 16 as byte;
    frame[7] = 0 as byte;
    frame[8] = 16 as byte;
    frame[9] = 0 as byte;

    var index: usize = 0;
    while index < 256 {
        frame[10 + index] = first_partition[index];
        index = index + 1;
    }
    index = 0;
    while index < token_partition_len {
        frame[266 + index] = token_partition[index];
        index = index + 1;
    }
    return 266 + token_partition_len;
}

fn build_api_test_key_frame(frame: &byte) !usize {
    var first_partition: [byte: 256] = [];
    var first_writer: BoolWriter = make_bool_writer(&first_partition[0] as &byte, 256);
    try write_api_minimal_key_frame_partition(&first_writer);

    const probs: Vp8Probs = vp8_default_probs();
    var token_partition: [byte: 64] = [];
    var token_writer: BoolWriter = make_bool_writer(&token_partition[0] as &byte, 64);
    try write_api_all_eob_tokens(&token_writer, &probs);

    return make_api_16x16_key_frame(&first_partition[0] as &byte, &token_partition[0] as &byte, bool_writer_byte_count(&token_writer), frame);
}

test "public decoder API decodes a borrowed frame and exposes stats" {
    var frame: [byte: 330] = [];
    const frame_len: usize = try build_api_test_key_frame(&frame[0] as &byte);

    var options: Vp8DecoderOptions = try make_vp8_decoder_options(16, 16);
    options.simd_level = SimdLevel.scalar;

    var decoder: Vp8Decoder = try vp8_decoder_init(&options);
    defer vp8_decoder_deinit(&decoder);

    try vp8_decoder_set_simd_level(&decoder, SimdLevel.scalar);

    const before: Vp8DecoderStats = vp8_decoder_stats(&decoder);
    try assert_eq_i32(before.decoded_frame_count as i32, 0);
    try assert_eq_i32(before.output_frame_count as i32, 0);

    var decoded: Vp8DecodedFrame = try vp8_decoder_decode_frame(&decoder, &frame[0] as &byte, frame_len);
    try assert_eq_i32(decoded.has_output as i32, true as i32);
    try assert_eq_i32(decoded.released as i32, false as i32);
    try assert_eq_i32(decoded.view.width as i32, 16);
    try assert_eq_i32(decoded.view.height as i32, 16);
    try assert_eq_i32(decoded.view.y.origin[0] as i32, 128);
    try assert_eq_i32(decoded.view.u.origin[0] as i32, 128);
    try assert_eq_i32(decoded.view.v.origin[0] as i32, 128);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count0 as i32, 1);

    const after: Vp8DecoderStats = vp8_decoder_stats(&decoder);
    try assert_eq_i32(after.decoded_frame_count as i32, 1);
    try assert_eq_i32(after.output_frame_count as i32, 1);
    try assert_eq_i32(after.last_performance.macroblock_count as i32, 1);
    try assert_eq_i32(after.last_performance.hot_loop_heap_allocation_count as i32, 0);

    try vp8_decoded_frame_release(&decoded);
    try assert_eq_i32(decoded.released as i32, true as i32);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count0 as i32, 0);

    vp8_decoder_flush(&decoder);
}

test "public decoder API keeps outstanding borrowed frames without implicit copies" {
    var frame: [byte: 330] = [];
    const frame_len: usize = try build_api_test_key_frame(&frame[0] as &byte);

    var options: Vp8DecoderOptions = try make_vp8_decoder_options(16, 16);
    options.simd_level = SimdLevel.scalar;

    var decoder: Vp8Decoder = try vp8_decoder_init(&options);
    defer vp8_decoder_deinit(&decoder);

    var first: Vp8DecodedFrame = try vp8_decoder_decode_frame(&decoder, &frame[0] as &byte, frame_len);
    try assert_eq_i32(first.has_output as i32, true as i32);
    try assert_eq_i32(first.released as i32, false as i32);
    try assert_eq_i32(decoder.context.frame_pool.current_slot as i32, 0);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count0 as i32, 1);
    try assert_eq_i32(first.performance.bytes_copied_for_ref_refresh as i32, 0);
    const first_y_origin: &byte = first.view.y.origin;

    var second: Vp8DecodedFrame = try vp8_decoder_decode_frame(&decoder, &frame[0] as &byte, frame_len);
    try assert_eq_i32(second.has_output as i32, true as i32);
    try assert_eq_i32(second.released as i32, false as i32);
    try assert_eq_i32(decoder.context.frame_pool.current_slot as i32, 1);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count0 as i32, 1);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count1 as i32, 1);
    try expect(first.view.y.origin == first_y_origin);
    try expect(first.view.y.origin != second.view.y.origin);
    try assert_eq_i32(first.view.y.origin[0] as i32, 128);
    try assert_eq_i32(second.view.y.origin[0] as i32, 128);
    try assert_eq_i32(second.performance.bytes_copied_for_ref_refresh as i32, 0);

    const stats: Vp8DecoderStats = vp8_decoder_stats(&decoder);
    try assert_eq_i32(stats.decoded_frame_count as i32, 2);
    try assert_eq_i32(stats.output_frame_count as i32, 2);
    try assert_eq_i32(stats.last_performance.bytes_copied_for_ref_refresh as i32, 0);

    try vp8_decoded_frame_release(&first);
    try assert_eq_i32(first.released as i32, true as i32);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count0 as i32, 0);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count1 as i32, 1);

    try vp8_decoded_frame_release(&second);
    try assert_eq_i32(second.released as i32, true as i32);
    try assert_eq_i32(decoder.context.frame_pool.slot_lease_count1 as i32, 0);
}

test "public decoder API validates options before allocating" {
    var bad: Vp8DecoderOptions = try make_vp8_decoder_options(16, 16);
    bad.thread_count = 0;

    var failed: i32 = 0;
    _ = vp8_decoder_init(&bad) catch {
        failed = 1;
        empty_vp8_decoder();
    };

    try assert_eq_i32(failed, 1);
}
