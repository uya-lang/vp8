use std.testing.assert_eq_i32;
use std.testing.expect;

use vp8.common.frame.FrameBuffer;
use vp8.common.frame.FramePool;
use vp8.common.frame.FrameVisibleView;
use vp8.common.frame.allocate_frame_buffer;
use vp8.common.frame.allocate_frame_pool;
use vp8.common.frame.empty_frame_buffer;
use vp8.common.frame.free_frame_pool;
use vp8.common.frame.free_frame_buffer;
use vp8.common.frame.frame_buffer_chroma_border;
use vp8.common.frame.frame_buffer_chroma_dim;
use vp8.common.frame.frame_buffer_border_dirty;
use vp8.common.frame.frame_buffer_clear_border_dirty;
use vp8.common.frame.frame_buffer_mark_border_dirty;
use vp8.common.frame.frame_buffer_visible_view;
use vp8.common.frame.frame_pool_begin_frame;
use vp8.common.frame.frame_pool_get_slot;
use vp8.common.frame.frame_pool_refresh_references;

fn assert_aligned(value: usize, alignment: usize) !void {
    try expect((value % alignment) == 0);
}

test "FrameBuffer allocates aligned Y U V 420 planes" {
    try assert_eq_i32(frame_buffer_chroma_dim(1) as i32, 1);
    try assert_eq_i32(frame_buffer_chroma_dim(17) as i32, 9);
    try assert_eq_i32(frame_buffer_chroma_border(32) as i32, 16);

    var frame: FrameBuffer = try allocate_frame_buffer(17, 17, 32, 32);
    defer free_frame_buffer(&frame);

    try assert_eq_i32(frame.width as i32, 17);
    try assert_eq_i32(frame.height as i32, 17);
    try assert_eq_i32(frame.y.plane.width as i32, 17);
    try assert_eq_i32(frame.y.plane.height as i32, 17);
    try assert_eq_i32(frame.y.plane.border as i32, 32);
    try assert_eq_i32(frame.y.plane.stride as i32, 96);
    try assert_eq_i32(frame.u.plane.width as i32, 9);
    try assert_eq_i32(frame.u.plane.height as i32, 9);
    try assert_eq_i32(frame.u.plane.border as i32, 16);
    try assert_eq_i32(frame.u.plane.stride as i32, 64);
    try assert_eq_i32(frame.v.plane.width as i32, 9);
    try assert_eq_i32(frame.v.plane.height as i32, 9);
    try assert_eq_i32(frame.v.plane.border as i32, 16);
    try assert_eq_i32(frame.v.plane.stride as i32, 64);
    try assert_aligned(@usize_from_ptr(frame.y.plane.data as &void), 32);
    try assert_aligned(@usize_from_ptr(frame.u.plane.data as &void), 32);
    try assert_aligned(@usize_from_ptr(frame.v.plane.data as &void), 32);
}

test "FrameBuffer rejects invalid dimensions and clears ownership on free" {
    var failed: i32 = 0;
    _ = allocate_frame_buffer(0, 17, 32, 32) catch {
        failed = 1;
        empty_frame_buffer();
    };
    try assert_eq_i32(failed, 1);

    var frame: FrameBuffer = try allocate_frame_buffer(1, 1, 32, 32);
    free_frame_buffer(&frame);
    try expect(frame.y.raw == null);
    try expect(frame.u.raw == null);
    try expect(frame.v.raw == null);
}

test "FramePool allocates current last golden and altref slots" {
    var pool: FramePool = try allocate_frame_pool(17, 17, 32, 32);
    defer free_frame_pool(&pool);

    try assert_eq_i32(pool.width as i32, 17);
    try assert_eq_i32(pool.height as i32, 17);
    try assert_eq_i32(pool.current_slot as i32, 0);
    try assert_eq_i32(pool.last_slot as i32, 1);
    try assert_eq_i32(pool.golden_slot as i32, 2);
    try assert_eq_i32(pool.altref_slot as i32, 3);
    const current: &FrameBuffer = try frame_pool_get_slot(&pool, pool.current_slot);
    const last: &FrameBuffer = try frame_pool_get_slot(&pool, pool.last_slot);
    const golden: &FrameBuffer = try frame_pool_get_slot(&pool, pool.golden_slot);
    const altref: &FrameBuffer = try frame_pool_get_slot(&pool, pool.altref_slot);
    try assert_eq_i32(current.y.plane.width as i32, 17);
    try assert_eq_i32(last.u.plane.width as i32, 9);
    try assert_eq_i32(golden.v.plane.height as i32, 9);
    try assert_eq_i32(altref.y.plane.border as i32, 32);
}

test "FramePool refresh aliases logical refs to physical current without copying" {
    var pool: FramePool = try allocate_frame_pool(17, 17, 32, 32);
    defer free_frame_pool(&pool);

    try assert_eq_i32(pool.slot_ref_count0 as i32, 0);
    try assert_eq_i32(pool.slot_ref_count1 as i32, 1);
    try assert_eq_i32(pool.slot_ref_count2 as i32, 1);
    try assert_eq_i32(pool.slot_ref_count3 as i32, 1);

    try frame_pool_refresh_references(&pool, true, true, false);

    try assert_eq_i32(pool.last_slot as i32, 0);
    try assert_eq_i32(pool.golden_slot as i32, 0);
    try assert_eq_i32(pool.altref_slot as i32, 3);
    try assert_eq_i32(pool.slot_ref_count0 as i32, 2);
    try assert_eq_i32(pool.slot_ref_count1 as i32, 0);
    try assert_eq_i32(pool.slot_ref_count2 as i32, 0);
    try assert_eq_i32(pool.slot_ref_count3 as i32, 1);
    try assert_eq_i32(pool.bytes_copied_for_ref_refresh as i32, 0);

    try frame_pool_begin_frame(&pool);

    try assert_eq_i32(pool.current_slot as i32, 1);
    try assert_eq_i32(pool.slot_ref_count1 as i32, 0);
    try assert_eq_i32(pool.last_slot as i32, 0);
    try assert_eq_i32(pool.golden_slot as i32, 0);
    try assert_eq_i32(pool.altref_slot as i32, 3);
}

test "FrameBuffer tracks reference border dirty flags per plane" {
    var frame: FrameBuffer = try allocate_frame_buffer(16, 16, 32, 32);
    defer free_frame_buffer(&frame);

    try expect(!frame_buffer_border_dirty(&frame));
    try expect(!frame.y_border_dirty);
    try expect(!frame.u_border_dirty);
    try expect(!frame.v_border_dirty);

    frame_buffer_mark_border_dirty(&frame);

    try expect(frame_buffer_border_dirty(&frame));
    try expect(frame.y_border_dirty);
    try expect(frame.u_border_dirty);
    try expect(frame.v_border_dirty);

    frame_buffer_clear_border_dirty(&frame);

    try expect(!frame_buffer_border_dirty(&frame));
    try expect(!frame.y_border_dirty);
    try expect(!frame.u_border_dirty);
    try expect(!frame.v_border_dirty);
}

test "FramePool refresh marks aliased current border dirty" {
    var pool: FramePool = try allocate_frame_pool(16, 16, 32, 32);
    defer free_frame_pool(&pool);

    const current: &FrameBuffer = try frame_pool_get_slot(&pool, pool.current_slot);
    try expect(!frame_buffer_border_dirty(current));

    try frame_pool_refresh_references(&pool, true, false, false);

    const last: &FrameBuffer = try frame_pool_get_slot(&pool, pool.last_slot);
    try expect(frame_buffer_border_dirty(last));
}

test "FrameBuffer visible view exposes Y U V origins without border" {
    var frame: FrameBuffer = try allocate_frame_buffer(17, 17, 32, 32);
    defer free_frame_buffer(&frame);

    var view: FrameVisibleView = frame_buffer_visible_view(&frame);

    try assert_eq_i32(view.width as i32, 17);
    try assert_eq_i32(view.height as i32, 17);
    try assert_eq_i32(view.y.width as i32, 17);
    try assert_eq_i32(view.y.height as i32, 17);
    try assert_eq_i32(view.y.stride as i32, frame.y.plane.stride as i32);
    try assert_eq_i32(view.y.border as i32, 0);
    try assert_eq_i32(view.u.width as i32, 9);
    try assert_eq_i32(view.u.height as i32, 9);
    try assert_eq_i32(view.u.border as i32, 0);
    try assert_eq_i32(view.v.width as i32, 9);
    try assert_eq_i32(view.v.height as i32, 9);
    try assert_eq_i32(view.v.border as i32, 0);
    try expect(view.y.origin == frame.y.plane.origin);
    try expect(view.u.origin == frame.u.plane.origin);
    try expect(view.v.origin == frame.v.plane.origin);
}
