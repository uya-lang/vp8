use std.testing.assert_eq_i32;
use std.testing.expect;

use vp8.common.scratch.RowScratchArena;
use vp8.common.scratch.MbCoeffScratchRing;
use vp8.common.scratch.TokenDecodeRowOutput;
use vp8.common.scratch.TokenDecodeRowScratch;
use vp8.common.scratch.allocate_row_scratch_arena;
use vp8.common.scratch.allocate_mb_coeff_scratch_ring;
use vp8.common.scratch.allocate_token_decode_row_output;
use vp8.common.scratch.allocate_token_decode_row_scratch;
use vp8.common.scratch.coeff_scratch_note_bytes_read;
use vp8.common.scratch.coeff_scratch_note_bytes_written;
use vp8.common.scratch.free_mb_coeff_scratch_ring;
use vp8.common.scratch.free_row_scratch_arena;
use vp8.common.scratch.frame_scratch_reset;
use vp8.common.scratch.mb_coeff_scratch_ring_acquire_decode_row;
use vp8.common.scratch.mb_coeff_scratch_ring_bound_bytes;
use vp8.common.scratch.mb_coeff_scratch_ring_high_water_bytes;
use vp8.common.scratch.mb_coeff_scratch_ring_in_flight_rows;
use vp8.common.scratch.mb_coeff_scratch_ring_release_reconstructed_row;
use vp8.common.scratch.row_scratch_alloc_bytes;
use vp8.common.scratch.row_scratch_reset;
use vp8.common.scratch.token_decode_row_block_coefficients;
use vp8.common.scratch.token_decode_row_block_summary;
use vp8.common.scratch.token_decode_row_set_block_summary;
use vp8.common.scratch.token_decode_row_output_bytes;
use vp8.common.scratch.token_decode_row_scratch_bytes;

fn assert_aligned(ptr: &byte, alignment: usize) !void {
    try expect((@usize_from_ptr(ptr as &void) % alignment) == 0);
}

fn assert_i16_aligned(ptr: &i16, alignment: usize) !void {
    try expect((@usize_from_ptr(ptr as &void) % alignment) == 0);
}

test "RowScratchArena bump allocates aligned memory and resets per row" {
    var arena: RowScratchArena = try allocate_row_scratch_arena(64, 16);
    defer free_row_scratch_arena(&arena);

    try assert_eq_i32(arena.capacity as i32, 64);
    try assert_eq_i32(arena.offset as i32, 0);
    try assert_aligned(arena.data, 16);

    const first: &byte = try row_scratch_alloc_bytes(&arena, 5, 8);
    const second: &byte = try row_scratch_alloc_bytes(&arena, 9, 16);

    try assert_aligned(first, 8);
    try assert_aligned(second, 16);
    try assert_eq_i32(arena.offset as i32, 25);
    try assert_eq_i32(arena.high_water as i32, 25);

    try row_scratch_reset(&arena);
    try assert_eq_i32(arena.offset as i32, 0);

    _ = try row_scratch_alloc_bytes(&arena, 4, 8);
    try assert_eq_i32(arena.offset as i32, 4);
}

test "RowScratchArena rejects invalid allocation requests and clears ownership" {
    var arena: RowScratchArena = try allocate_row_scratch_arena(16, 8);

    var failed_too_large: i32 = 0;
    _ = row_scratch_alloc_bytes(&arena, 32, 8) catch {
        failed_too_large = 1;
        null as &byte;
    };
    try assert_eq_i32(failed_too_large, 1);

    free_row_scratch_arena(&arena);
    try expect(arena.data == null);
    try assert_eq_i32(arena.capacity as i32, 0);
}

test "TokenDecodeRowScratch allocates row-local coefficient blocks from arena" {
    var arena: RowScratchArena = try allocate_row_scratch_arena(256, 16);
    defer free_row_scratch_arena(&arena);

    const scratch: TokenDecodeRowScratch = try allocate_token_decode_row_scratch(&arena);
    const block_bytes: usize = 16 * (@size_of(i16) as usize);
    const coeff_addr: usize = @usize_from_ptr(scratch.coefficients as &void);
    const y2_coeff_addr: usize = @usize_from_ptr(scratch.y2_coefficients as &void);
    const y2_dequantized_addr: usize = @usize_from_ptr(scratch.y2_dequantized as &void);
    const y2_dc_addr: usize = @usize_from_ptr(scratch.y2_dc as &void);

    try assert_i16_aligned(scratch.coefficients, 16);
    try assert_i16_aligned(scratch.y2_coefficients, 16);
    try assert_i16_aligned(scratch.y2_dequantized, 16);
    try assert_i16_aligned(scratch.y2_dc, 16);
    try assert_eq_i32((y2_coeff_addr - coeff_addr) as i32, block_bytes as i32);
    try assert_eq_i32((y2_dequantized_addr - y2_coeff_addr) as i32, block_bytes as i32);
    try assert_eq_i32((y2_dc_addr - y2_dequantized_addr) as i32, block_bytes as i32);
    try assert_eq_i32(arena.high_water as i32, token_decode_row_scratch_bytes() as i32);

    scratch.coefficients[0] = 7 as i16;
    scratch.y2_dc[15] = -3 as i16;

    try row_scratch_reset(&arena);
    _ = try allocate_token_decode_row_scratch(&arena);
    try assert_eq_i32(arena.offset as i32, token_decode_row_scratch_bytes() as i32);
    try assert_eq_i32(arena.high_water as i32, token_decode_row_scratch_bytes() as i32);
}

test "TokenDecodeRowOutput allocates row-local macroblock coefficient output" {
    var arena: RowScratchArena = try allocate_row_scratch_arena(4096, 16);
    defer free_row_scratch_arena(&arena);

    const output: TokenDecodeRowOutput = try allocate_token_decode_row_output(&arena, 2);
    const bytes: usize = try token_decode_row_output_bytes(2);

    try assert_eq_i32(output.mb_cols as i32, 2);
    try assert_eq_i32(bytes as i32, 1613);
    try assert_i16_aligned(output.coefficients, 16);
    try expect(output.summaries != null);
    try assert_eq_i32(arena.high_water as i32, bytes as i32);

    const first_mb_y2: &i16 = try token_decode_row_block_coefficients(&output, 0, 0);
    const second_mb_y2: &i16 = try token_decode_row_block_coefficients(&output, 1, 0);

    first_mb_y2[0] = 5 as i16;
    second_mb_y2[0] = 9 as i16;
    try token_decode_row_set_block_summary(&output, 0, 0, 1 as byte);
    try token_decode_row_set_block_summary(&output, 0, 1, 2 as byte);
    try token_decode_row_set_block_summary(&output, 1, 24, 3 as byte);

    try assert_eq_i32(first_mb_y2[0] as i32, 5);
    try assert_eq_i32(second_mb_y2[0] as i32, 9);
    try assert_eq_i32((try token_decode_row_block_summary(&output, 0, 0)) as i32, 1);
    try assert_eq_i32((try token_decode_row_block_summary(&output, 0, 1)) as i32, 2);
    try assert_eq_i32((try token_decode_row_block_summary(&output, 1, 24)) as i32, 3);
}

test "RowScratchArena tracks coefficient scratch read and write bytes" {
    var arena: RowScratchArena = try allocate_row_scratch_arena(32, 8);
    defer free_row_scratch_arena(&arena);

    try assert_eq_i32(arena.coeff_bytes_read as i32, 0);
    try assert_eq_i32(arena.coeff_bytes_written as i32, 0);

    try coeff_scratch_note_bytes_read(&arena, 6);
    try coeff_scratch_note_bytes_written(&arena, 10);
    try coeff_scratch_note_bytes_read(&arena, 4);

    try assert_eq_i32(arena.coeff_bytes_read as i32, 10);
    try assert_eq_i32(arena.coeff_bytes_written as i32, 10);

    try row_scratch_reset(&arena);
    try assert_eq_i32(arena.coeff_bytes_read as i32, 10);
    try assert_eq_i32(arena.coeff_bytes_written as i32, 10);
}

test "RowScratchArena frame reset clears row state and coefficient stats" {
    var arena: RowScratchArena = try allocate_row_scratch_arena(64, 16);
    defer free_row_scratch_arena(&arena);

    _ = try row_scratch_alloc_bytes(&arena, 20, 8);
    try coeff_scratch_note_bytes_read(&arena, 12);
    try coeff_scratch_note_bytes_written(&arena, 16);

    try assert_eq_i32(arena.offset as i32, 20);
    try assert_eq_i32(arena.high_water as i32, 20);
    try assert_eq_i32(arena.coeff_bytes_read as i32, 12);
    try assert_eq_i32(arena.coeff_bytes_written as i32, 16);

    try frame_scratch_reset(&arena);

    try assert_eq_i32(arena.offset as i32, 0);
    try assert_eq_i32(arena.high_water as i32, 0);
    try assert_eq_i32(arena.coeff_bytes_read as i32, 0);
    try assert_eq_i32(arena.coeff_bytes_written as i32, 0);
}

test "MbCoeffScratchRing bounds decoded rows by reconstruct fence" {
    var ring: MbCoeffScratchRing = try allocate_mb_coeff_scratch_ring(2, 2, 16);
    defer free_mb_coeff_scratch_ring(&ring);

    const row_bytes: usize = try token_decode_row_output_bytes(2);
    try assert_eq_i32(mb_coeff_scratch_ring_bound_bytes(&ring) as i32, (row_bytes * 2) as i32);

    const row0: &TokenDecodeRowOutput = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 0);
    const coeff0: &i16 = try token_decode_row_block_coefficients(row0, 0, 0);
    coeff0[0] = 33 as i16;

    _ = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 1);
    try assert_eq_i32(mb_coeff_scratch_ring_in_flight_rows(&ring) as i32, 2);

    var failed_full: i32 = 0;
    _ = mb_coeff_scratch_ring_acquire_decode_row(&ring, 2) catch {
        failed_full = 1;
        null as &TokenDecodeRowOutput;
    };
    try assert_eq_i32(failed_full, 1);

    try mb_coeff_scratch_ring_release_reconstructed_row(&ring, 0);
    const row2: &TokenDecodeRowOutput = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 2);
    const coeff2: &i16 = try token_decode_row_block_coefficients(row2, 0, 0);

    try assert_eq_i32(coeff2[0] as i32, 0);
    try assert_eq_i32(mb_coeff_scratch_ring_in_flight_rows(&ring) as i32, 2);
}

test "MbCoeffScratchRing binds release order to row fence" {
    var ring: MbCoeffScratchRing = try allocate_mb_coeff_scratch_ring(2, 2, 16);
    defer free_mb_coeff_scratch_ring(&ring);

    var failed_decode_order: i32 = 0;
    _ = mb_coeff_scratch_ring_acquire_decode_row(&ring, 1) catch {
        failed_decode_order = 1;
        null as &TokenDecodeRowOutput;
    };
    try assert_eq_i32(failed_decode_order, 1);

    _ = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 0);
    _ = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 1);

    var failed_release_order: i32 = 0;
    _ = mb_coeff_scratch_ring_release_reconstructed_row(&ring, 1) catch {
        failed_release_order = 1;
    };
    try assert_eq_i32(failed_release_order, 1);

    try mb_coeff_scratch_ring_release_reconstructed_row(&ring, 0);
    try mb_coeff_scratch_ring_release_reconstructed_row(&ring, 1);
    try assert_eq_i32(mb_coeff_scratch_ring_in_flight_rows(&ring) as i32, 0);
}

test "MbCoeffScratchRing peak scratch stays bounded by ring depth and row width" {
    const mb_cols: usize = 3;
    const ring_depth: usize = 2;
    const frame_rows: usize = 12;
    var ring: MbCoeffScratchRing = try allocate_mb_coeff_scratch_ring(mb_cols, ring_depth, 16);
    defer free_mb_coeff_scratch_ring(&ring);

    const row_bytes: usize = try token_decode_row_output_bytes(mb_cols);
    const bound_bytes: usize = row_bytes * ring_depth;
    try assert_eq_i32(mb_coeff_scratch_ring_bound_bytes(&ring) as i32, bound_bytes as i32);
    try assert_eq_i32((try mb_coeff_scratch_ring_high_water_bytes(&ring)) as i32, 0);

    _ = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 0);
    _ = try mb_coeff_scratch_ring_acquire_decode_row(&ring, 1);
    try assert_eq_i32((try mb_coeff_scratch_ring_high_water_bytes(&ring)) as i32, bound_bytes as i32);

    var next_row: usize = 2;
    var release_row: usize = 0;
    while next_row < frame_rows {
        try mb_coeff_scratch_ring_release_reconstructed_row(&ring, release_row);
        _ = try mb_coeff_scratch_ring_acquire_decode_row(&ring, next_row);
        try assert_eq_i32((try mb_coeff_scratch_ring_high_water_bytes(&ring)) as i32, bound_bytes as i32);
        try assert_eq_i32(mb_coeff_scratch_ring_in_flight_rows(&ring) as i32, ring_depth as i32);
        release_row = release_row + 1;
        next_row = next_row + 1;
    }
}
