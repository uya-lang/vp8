use std.testing.assert_eq_i32;

use vp8.bitstream.bool_reader.BoolReader;
use vp8.bitstream.bool_reader.BoolReaderTrace;
use vp8.bitstream.bool_reader.BoolReaderTraceEntry;
use vp8.bitstream.bool_reader.make_bool_reader;
use vp8.bitstream.bool_reader.make_bool_reader_for_partition;
use vp8.bitstream.bool_reader.make_bool_reader_trace;
use vp8.bitstream.bool_reader.bool_reader_bit_offset;
use vp8.bitstream.bool_reader.bool_reader_byte_offset;
use vp8.bitstream.bool_reader.bool_reader_error_byte_offset;
use vp8.bitstream.bool_reader.bool_reader_error_partition_id;
use vp8.bitstream.bool_reader.bool_reader_partition_id;
use vp8.bitstream.bool_reader.bool_reader_read_traced;
use vp8.bitstream.bool_reader.bool_reader_trace_count;
use vp8.bitstream.bool_reader.bool_reader_read;
use vp8.bitstream.bool_reader.read_bit_with_probability;
use vp8.bitstream.bool_reader.read_literal;
use vp8.bitstream.bool_reader.read_signed_value;

test "VP8 boolean reader decodes probability split bits" {
    var data: [byte: 3] = [ 0x80, 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader(&data[0] as &byte, 3);

    try assert_eq_i32((try bool_reader_read(&reader, 128 as byte)) as i32, 1);
    try assert_eq_i32((try bool_reader_read(&reader, 128 as byte)) as i32, 0);
    try assert_eq_i32((try bool_reader_read(&reader, 128 as byte)) as i32, 0);
    try assert_eq_i32(bool_reader_bit_offset(&reader) as i32, 3);
}

test "read bit with probability uses VP8 split math" {
    var data: [byte: 3] = [ 0x40, 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader(&data[0] as &byte, 3);

    try assert_eq_i32((try read_bit_with_probability(&reader, 200 as byte)) as i32, 0);
    try assert_eq_i32((try read_bit_with_probability(&reader, 32 as byte)) as i32, 1);
    try assert_eq_i32(bool_reader_bit_offset(&reader) as i32, 2);
}

test "read literal helper accumulates MSB-first bits" {
    var data: [byte: 3] = [ 0xa0, 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader(&data[0] as &byte, 3);

    try assert_eq_i32((try read_literal(&reader, 3 as u8)) as i32, 5);
    try assert_eq_i32((try read_literal(&reader, 0 as u8)) as i32, 0);
    try assert_eq_i32(bool_reader_bit_offset(&reader) as i32, 3);
}

test "read signed value helper applies trailing sign bit" {
    var positive_data: [byte: 3] = [ 0xa0, 0x00, 0x00 ];
    var positive_reader: BoolReader = try make_bool_reader(&positive_data[0] as &byte, 3);
    try assert_eq_i32(try read_signed_value(&positive_reader, 3 as u8), 5);

    var negative_data: [byte: 3] = [ 0xb0, 0x00, 0x00 ];
    var negative_reader: BoolReader = try make_bool_reader(&negative_data[0] as &byte, 3);
    try assert_eq_i32(try read_signed_value(&negative_reader, 3 as u8), -5);
}

test "VP8 boolean reader rejects short initialization and overread" {
    var empty_data: [byte: 1] = [ 0x00 ];
    const init_fallback: usize = (make_bool_reader(&empty_data[0] as &byte, 1) catch {
        BoolReader{ data: &empty_data[0] as &byte, len: 0, partition_id: 0, byte_pos: 0, range: 0, value: 0, bits_left: 0, bit_offset: 99, error_partition_id: -1, error_byte_offset: 0 };
    }).bit_offset;
    try assert_eq_i32(init_fallback as i32, 99);

    var data: [byte: 2] = [ 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader(&data[0] as &byte, 2);
    var count: i32 = 0;
    while count < 9 {
        try assert_eq_i32((try bool_reader_read(&reader, 128 as byte)) as i32, 0);
        count = count + 1;
    }

    const bit_fallback: u8 = bool_reader_read(&reader, 128 as byte) catch { 7 as u8; };
    try assert_eq_i32(bit_fallback as i32, 7);
    try assert_eq_i32(bool_reader_byte_offset(&reader) as i32, 2);
}

test "partition boundary overread keeps reader offsets stable" {
    var data: [byte: 2] = [ 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader_for_partition(&data[0] as &byte, 2, 4);
    var count: i32 = 0;
    while count < 9 {
        try assert_eq_i32((try bool_reader_read(&reader, 128 as byte)) as i32, 0);
        count = count + 1;
    }

    const bit_offset_before: usize = bool_reader_bit_offset(&reader);
    const byte_offset_before: usize = bool_reader_byte_offset(&reader);
    const fallback: u8 = bool_reader_read(&reader, 128 as byte) catch { 9 as u8; };

    try assert_eq_i32(fallback as i32, 9);
    try assert_eq_i32(bool_reader_partition_id(&reader), 4);
    try assert_eq_i32(bool_reader_bit_offset(&reader) as i32, bit_offset_before as i32);
    try assert_eq_i32(bool_reader_byte_offset(&reader) as i32, byte_offset_before as i32);
}

test "overread error records partition id and byte offset" {
    var data: [byte: 2] = [ 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader_for_partition(&data[0] as &byte, 2, 7);
    var count: i32 = 0;

    while count < 9 {
        try assert_eq_i32((try bool_reader_read(&reader, 128 as byte)) as i32, 0);
        count = count + 1;
    }

    const fallback: u8 = bool_reader_read(&reader, 128 as byte) catch { 9 as u8; };

    try assert_eq_i32(fallback as i32, 9);
    try assert_eq_i32(bool_reader_error_partition_id(&reader), 7);
    try assert_eq_i32(bool_reader_error_byte_offset(&reader) as i32, 2);
}

test "reader trace records bit probability and offsets" {
    var data: [byte: 3] = [ 0x80, 0x00, 0x00 ];
    var entries: [BoolReaderTraceEntry: 2] = [
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 }
    ];
    var reader: BoolReader = try make_bool_reader(&data[0] as &byte, 3);
    var trace: BoolReaderTrace = make_bool_reader_trace(&entries[0] as &BoolReaderTraceEntry, 2);

    try assert_eq_i32((try bool_reader_read_traced(&reader, 128 as byte, &trace)) as i32, 1);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 200 as byte, &trace)) as i32, 0);

    try assert_eq_i32(bool_reader_trace_count(&trace) as i32, 2);
    try assert_eq_i32(entries[0].bit as i32, 1);
    try assert_eq_i32(entries[0].probability as i32, 128);
    try assert_eq_i32(entries[0].byte_offset as i32, 2);
    try assert_eq_i32(entries[0].bit_offset as i32, 0);
    try assert_eq_i32(entries[1].bit as i32, 0);
    try assert_eq_i32(entries[1].probability as i32, 200);
    try assert_eq_i32(entries[1].bit_offset as i32, 1);
}

test "reader trace matches libvpx boolhuff small sample" {
    var data: [byte: 2] = [ 0xb3, 0xe0 ];
    var entries: [BoolReaderTraceEntry: 8] = [
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 },
        BoolReaderTraceEntry{ bit: 0, probability: 0, byte_offset: 0, bit_offset: 0 }
    ];
    var reader: BoolReader = try make_bool_reader(&data[0] as &byte, 2);
    var trace: BoolReaderTrace = make_bool_reader_trace(&entries[0] as &BoolReaderTraceEntry, 8);

    try assert_eq_i32((try bool_reader_read_traced(&reader, 128 as byte, &trace)) as i32, 1);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 128 as byte, &trace)) as i32, 0);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 200 as byte, &trace)) as i32, 1);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 32 as byte, &trace)) as i32, 1);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 128 as byte, &trace)) as i32, 0);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 200 as byte, &trace)) as i32, 0);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 32 as byte, &trace)) as i32, 1);
    try assert_eq_i32((try bool_reader_read_traced(&reader, 128 as byte, &trace)) as i32, 0);

    try assert_eq_i32(bool_reader_trace_count(&trace) as i32, 8);
    try assert_eq_i32(entries[0].bit as i32, 1);
    try assert_eq_i32(entries[0].probability as i32, 128);
    try assert_eq_i32(entries[0].byte_offset as i32, 2);
    try assert_eq_i32(entries[0].bit_offset as i32, 0);
    try assert_eq_i32(entries[1].bit as i32, 0);
    try assert_eq_i32(entries[1].probability as i32, 128);
    try assert_eq_i32(entries[1].bit_offset as i32, 1);
    try assert_eq_i32(entries[2].bit as i32, 1);
    try assert_eq_i32(entries[2].probability as i32, 200);
    try assert_eq_i32(entries[2].bit_offset as i32, 2);
    try assert_eq_i32(entries[3].bit as i32, 1);
    try assert_eq_i32(entries[3].probability as i32, 32);
    try assert_eq_i32(entries[3].bit_offset as i32, 3);
    try assert_eq_i32(entries[4].bit as i32, 0);
    try assert_eq_i32(entries[4].probability as i32, 128);
    try assert_eq_i32(entries[4].bit_offset as i32, 4);
    try assert_eq_i32(entries[5].bit as i32, 0);
    try assert_eq_i32(entries[5].probability as i32, 200);
    try assert_eq_i32(entries[5].bit_offset as i32, 5);
    try assert_eq_i32(entries[6].bit as i32, 1);
    try assert_eq_i32(entries[6].probability as i32, 32);
    try assert_eq_i32(entries[6].bit_offset as i32, 6);
    try assert_eq_i32(entries[7].bit as i32, 0);
    try assert_eq_i32(entries[7].probability as i32, 128);
    try assert_eq_i32(entries[7].byte_offset as i32, 2);
    try assert_eq_i32(entries[7].bit_offset as i32, 7);
}
