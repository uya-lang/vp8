use std.testing.assert_eq_i32;
use std.testing.assert_eq_i64;
use std.testing.assert_eq_u64;

use vp8.encoder.context.EncoderConfig;
use vp8.encoder.context.EncoderRateControlMode;
use vp8.encoder.context.make_default_encoder_config;
use vp8.encoder.rate_control.EncoderCbrBufferModel;
use vp8.encoder.rate_control.EncoderCbrBufferUpdate;
use vp8.encoder.rate_control.EncoderRateControl;
use vp8.encoder.rate_control.EncoderRateControlDecision;
use vp8.encoder.rate_control.EncoderRateControlFrameReport;
use vp8.encoder.rate_control.encoder_cbr_buffer_finish_frame;
use vp8.encoder.rate_control.encoder_rate_control_decide_frame;
use vp8.encoder.rate_control.encoder_rate_control_finish_frame;
use vp8.encoder.rate_control.make_encoder_rate_control_frame_report;
use vp8.encoder.rate_control.make_encoder_cbr_buffer_model;
use vp8.encoder.rate_control.make_encoder_rate_control;

fn dummy_rate_control() EncoderRateControl {
    return EncoderRateControl{
        mode: EncoderRateControlMode.constant_quantizer,
        cqp_quantizer: 0 as u8,
        current_quantizer: 0 as u8,
        target_bits_per_frame: 0,
        frame_index: 0,
        last_actual_bits: 0
    };
}

fn dummy_rate_control_decision() EncoderRateControlDecision {
    return EncoderRateControlDecision{
        frame_index: 0,
        quantizer: 0 as u8,
        target_bits: 0,
        is_keyframe: false
    };
}

fn dummy_cbr_buffer_model() EncoderCbrBufferModel {
    return EncoderCbrBufferModel{
        capacity_bits: 1,
        fullness_bits: 0,
        target_bits_per_frame: 1,
        underflow_count: 0,
        overflow_count: 0
    };
}

fn dummy_cbr_buffer_update() EncoderCbrBufferUpdate {
    return EncoderCbrBufferUpdate{
        before_fullness_bits: 0,
        after_fullness_bits: 0,
        underflow: false,
        overflow: false
    };
}

fn dummy_frame_report() EncoderRateControlFrameReport {
    return EncoderRateControlFrameReport{
        target_bits: 0,
        actual_bits: 0,
        error_bits: 0,
        absolute_error_bits: 0,
        error_ppm: 0 as u64,
        tolerance_ppm: 0,
        within_tolerance: false
    };
}

test "CQP rate control keeps fixed quantizer across feedback" {
    var config: EncoderConfig = make_default_encoder_config(16, 16);
    config.quantizer = 47 as u8;

    var control: EncoderRateControl = try make_encoder_rate_control(&config);
    const first: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&control, true);
    try assert_eq_i32(first.frame_index as i32, 0);
    try assert_eq_i32(first.quantizer as i32, 47);
    try assert_eq_i32(first.target_bits as i32, 0);
    try assert_eq_i32(first.is_keyframe as i32, true as i32);

    try encoder_rate_control_finish_frame(&control, 99999);
    const second: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&control, false);
    try assert_eq_i32(second.frame_index as i32, 1);
    try assert_eq_i32(second.quantizer as i32, 47);
    try assert_eq_i32(second.target_bits as i32, 0);
    try assert_eq_i32(second.is_keyframe as i32, false as i32);
    try assert_eq_i32(control.last_actual_bits as i32, 99999);
}

test "CQP rate control rejects invalid config" {
    var failed: i32 = 0;
    _ = make_encoder_rate_control(null as &EncoderConfig) catch {
        failed = 1;
        dummy_rate_control();
    };
    try assert_eq_i32(failed, 1);

    var invalid_quantizer: EncoderConfig = make_default_encoder_config(16, 16);
    invalid_quantizer.quantizer = 128 as u8;
    failed = 0;
    _ = make_encoder_rate_control(&invalid_quantizer) catch {
        failed = 1;
        dummy_rate_control();
    };
    try assert_eq_i32(failed, 1);

    var invalid_bitrate: EncoderConfig = make_default_encoder_config(16, 16);
    invalid_bitrate.rate_control_mode = EncoderRateControlMode.target_bitrate;
    invalid_bitrate.target_bitrate_bps = 0;
    failed = 0;
    _ = make_encoder_rate_control(&invalid_bitrate) catch {
        failed = 1;
        dummy_rate_control();
    };
    try assert_eq_i32(failed, 1);

    failed = 0;
    _ = encoder_rate_control_decide_frame(null as &EncoderRateControl, false) catch {
        failed = 1;
        dummy_rate_control_decision();
    };
    try assert_eq_i32(failed, 1);
}

test "simple VBR rate control computes target bits and adapts quantizer" {
    var config: EncoderConfig = make_default_encoder_config(16, 16);
    config.rate_control_mode = EncoderRateControlMode.target_bitrate;
    config.target_bitrate_bps = 240000;
    config.fps_numerator = 30;
    config.fps_denominator = 1;
    config.quantizer = 40 as u8;

    var control: EncoderRateControl = try make_encoder_rate_control(&config);
    const first: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&control, false);
    try assert_eq_i32(first.frame_index as i32, 0);
    try assert_eq_i32(first.quantizer as i32, 40);
    try assert_eq_i32(first.target_bits as i32, 8000);

    try encoder_rate_control_finish_frame(&control, 12000);
    const second: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&control, false);
    try assert_eq_i32(second.frame_index as i32, 1);
    try assert_eq_i32(second.quantizer as i32, 42);
    try assert_eq_i32(second.target_bits as i32, 8000);
    try assert_eq_i32(control.last_actual_bits as i32, 12000);

    try encoder_rate_control_finish_frame(&control, 4000);
    const third: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&control, false);
    try assert_eq_i32(third.frame_index as i32, 2);
    try assert_eq_i32(third.quantizer as i32, 40);
    try assert_eq_i32(third.target_bits as i32, 8000);
}

test "simple VBR quantizer adjustment clamps to VP8 qindex range" {
    var high_config: EncoderConfig = make_default_encoder_config(16, 16);
    high_config.rate_control_mode = EncoderRateControlMode.target_bitrate;
    high_config.target_bitrate_bps = 30000;
    high_config.quantizer = 126 as u8;
    var high: EncoderRateControl = try make_encoder_rate_control(&high_config);
    try encoder_rate_control_finish_frame(&high, 2000);
    const high_decision: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&high, false);
    try assert_eq_i32(high_decision.quantizer as i32, 127);

    var low_config: EncoderConfig = make_default_encoder_config(16, 16);
    low_config.rate_control_mode = EncoderRateControlMode.target_bitrate;
    low_config.target_bitrate_bps = 30000;
    low_config.quantizer = 1 as u8;
    var low: EncoderRateControl = try make_encoder_rate_control(&low_config);
    try encoder_rate_control_finish_frame(&low, 0);
    const low_decision: EncoderRateControlDecision = try encoder_rate_control_decide_frame(&low, false);
    try assert_eq_i32(low_decision.quantizer as i32, 0);
}

test "target bitrate frame report measures error against tolerance" {
    const low: EncoderRateControlFrameReport = try make_encoder_rate_control_frame_report(8000, 7600, 100000);
    try assert_eq_i32(low.target_bits as i32, 8000);
    try assert_eq_i32(low.actual_bits as i32, 7600);
    try assert_eq_i64(low.error_bits, 0 - 400);
    try assert_eq_i32(low.absolute_error_bits as i32, 400);
    try assert_eq_u64(low.error_ppm, 50000 as u64);
    try assert_eq_i32(low.within_tolerance as i32, true as i32);

    const high: EncoderRateControlFrameReport = try make_encoder_rate_control_frame_report(8000, 9000, 100000);
    try assert_eq_i64(high.error_bits, 1000);
    try assert_eq_i32(high.absolute_error_bits as i32, 1000);
    try assert_eq_u64(high.error_ppm, 125000 as u64);
    try assert_eq_i32(high.within_tolerance as i32, false as i32);

    var failed: i32 = 0;
    _ = make_encoder_rate_control_frame_report(0, 100, 100000) catch {
        failed = 1;
        dummy_frame_report();
    };
    try assert_eq_i32(failed, 1);
}

test "CBR buffer model replenishes budget and clamps underflow overflow" {
    var model: EncoderCbrBufferModel = try make_encoder_cbr_buffer_model(1000, 4000, 2000);

    const first: EncoderCbrBufferUpdate = try encoder_cbr_buffer_finish_frame(&model, 900);
    try assert_eq_i32(first.before_fullness_bits as i32, 2000);
    try assert_eq_i32(first.after_fullness_bits as i32, 2100);
    try assert_eq_i32(first.underflow as i32, false as i32);
    try assert_eq_i32(first.overflow as i32, false as i32);
    try assert_eq_i32(model.fullness_bits as i32, 2100);

    const second: EncoderCbrBufferUpdate = try encoder_cbr_buffer_finish_frame(&model, 3500);
    try assert_eq_i32(second.before_fullness_bits as i32, 2100);
    try assert_eq_i32(second.after_fullness_bits as i32, 0);
    try assert_eq_i32(second.underflow as i32, true as i32);
    try assert_eq_i32(second.overflow as i32, false as i32);
    try assert_eq_i32(model.underflow_count as i32, 1);

    var nearly_full: EncoderCbrBufferModel = try make_encoder_cbr_buffer_model(1000, 4000, 3900);
    const overflow: EncoderCbrBufferUpdate = try encoder_cbr_buffer_finish_frame(&nearly_full, 100);
    try assert_eq_i32(overflow.before_fullness_bits as i32, 3900);
    try assert_eq_i32(overflow.after_fullness_bits as i32, 4000);
    try assert_eq_i32(overflow.underflow as i32, false as i32);
    try assert_eq_i32(overflow.overflow as i32, true as i32);
    try assert_eq_i32(nearly_full.overflow_count as i32, 1);
}

test "CBR buffer model rejects invalid parameters" {
    var failed: i32 = 0;
    _ = make_encoder_cbr_buffer_model(0, 4000, 0) catch {
        failed = 1;
        dummy_cbr_buffer_model();
    };
    try assert_eq_i32(failed, 1);

    failed = 0;
    _ = make_encoder_cbr_buffer_model(1000, 0, 0) catch {
        failed = 1;
        dummy_cbr_buffer_model();
    };
    try assert_eq_i32(failed, 1);

    failed = 0;
    _ = make_encoder_cbr_buffer_model(1000, 4000, 5000) catch {
        failed = 1;
        dummy_cbr_buffer_model();
    };
    try assert_eq_i32(failed, 1);

    failed = 0;
    _ = encoder_cbr_buffer_finish_frame(null as &EncoderCbrBufferModel, 1000) catch {
        failed = 1;
        dummy_cbr_buffer_update();
    };
    try assert_eq_i32(failed, 1);
}
