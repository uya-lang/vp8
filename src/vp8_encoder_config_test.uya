use std.testing.assert_eq_i32;

use vp8.common.cpu.SimdLevel;
use vp8.encoder.context.EncoderConfig;
use vp8.encoder.context.EncoderRateControlMode;
use vp8.encoder.context.EncoderSpeedPreset;
use vp8.encoder.context.YuvFrameView;
use vp8.encoder.context.empty_yuv_frame_view;
use vp8.encoder.context.make_default_encoder_config;
use vp8.encoder.context.make_i420_frame_view;
use vp8.encoder.context.make_yuv420_frame_view;
use vp8.encoder.context.validate_encoder_config;
use vp8.encoder.context.validate_yuv_frame_view;
use vp8.encoder.context.yuv420_frame_view_size;

test "EncoderConfig default captures keyframe MVP settings" {
    const config: EncoderConfig = make_default_encoder_config(640, 360);

    try assert_eq_i32(config.width as i32, 640);
    try assert_eq_i32(config.height as i32, 360);
    try assert_eq_i32(config.fps_numerator as i32, 30);
    try assert_eq_i32(config.fps_denominator as i32, 1);
    try assert_eq_i32(config.rate_control_mode as i32, EncoderRateControlMode.constant_quantizer as i32);
    try assert_eq_i32(config.quantizer as i32, 32);
    try assert_eq_i32(config.target_bitrate_bps as i32, 0);
    try assert_eq_i32(config.keyframe_interval as i32, 120);
    try assert_eq_i32(config.speed_preset as i32, EncoderSpeedPreset.balanced as i32);
    try assert_eq_i32(config.thread_count as i32, 1);
    try assert_eq_i32(config.simd_level as i32, SimdLevel.scalar as i32);

    try validate_encoder_config(&config);
}

test "EncoderConfig validates geometry timing rate control and workers" {
    var invalid_geometry: EncoderConfig = make_default_encoder_config(0, 16);
    var failed: i32 = 0;
    validate_encoder_config(&invalid_geometry) catch {
        failed = 1;
    };
    try assert_eq_i32(failed, 1);

    var invalid_timing: EncoderConfig = make_default_encoder_config(16, 16);
    invalid_timing.fps_denominator = 0;
    failed = 0;
    validate_encoder_config(&invalid_timing) catch {
        failed = 1;
    };
    try assert_eq_i32(failed, 1);

    var invalid_quantizer: EncoderConfig = make_default_encoder_config(16, 16);
    invalid_quantizer.quantizer = 128 as u8;
    failed = 0;
    validate_encoder_config(&invalid_quantizer) catch {
        failed = 1;
    };
    try assert_eq_i32(failed, 1);

    var invalid_bitrate: EncoderConfig = make_default_encoder_config(16, 16);
    invalid_bitrate.rate_control_mode = EncoderRateControlMode.target_bitrate;
    invalid_bitrate.target_bitrate_bps = 0;
    failed = 0;
    validate_encoder_config(&invalid_bitrate) catch {
        failed = 1;
    };
    try assert_eq_i32(failed, 1);

    var invalid_thread_count: EncoderConfig = make_default_encoder_config(16, 16);
    invalid_thread_count.thread_count = 0;
    failed = 0;
    validate_encoder_config(&invalid_thread_count) catch {
        failed = 1;
    };
    try assert_eq_i32(failed, 1);
}

test "YuvFrameView captures borrowed YUV420 planes with strides" {
    var y_data: [byte: 15] = [ 1, 2, 3, 99, 99, 4, 5, 6, 99, 99, 7, 8, 9, 99, 99 ];
    var u_data: [byte: 6] = [ 10, 11, 99, 12, 13, 99 ];
    var v_data: [byte: 6] = [ 14, 15, 99, 16, 17, 99 ];

    const view: YuvFrameView = try make_yuv420_frame_view(
        &y_data[0] as &byte, 15,
        &u_data[0] as &byte, 6,
        &v_data[0] as &byte, 6,
        3, 3,
        5, 3, 3
    );

    try assert_eq_i32(view.width as i32, 3);
    try assert_eq_i32(view.height as i32, 3);
    try assert_eq_i32(view.y.width as i32, 3);
    try assert_eq_i32(view.y.height as i32, 3);
    try assert_eq_i32(view.y.stride as i32, 5);
    try assert_eq_i32(view.u.width as i32, 2);
    try assert_eq_i32(view.u.height as i32, 2);
    try assert_eq_i32(view.u.stride as i32, 3);
    try assert_eq_i32(view.v.width as i32, 2);
    try assert_eq_i32(view.v.height as i32, 2);
    try assert_eq_i32(view.v.stride as i32, 3);
    try assert_eq_i32(yuv420_frame_view_size(&view) as i32, 17);
    try assert_eq_i32(view.y.data[10] as i32, 7);
    try assert_eq_i32(view.u.data[3] as i32, 12);
    try assert_eq_i32(view.v.data[4] as i32, 17);

    try validate_yuv_frame_view(&view);
}

test "YuvFrameView splits contiguous I420 storage" {
    var data: [byte: 17] = [ 0, 1, 2, 3, 4, 5, 6, 7, 8, 20, 21, 22, 23, 30, 31, 32, 33 ];

    const view: YuvFrameView = try make_i420_frame_view(&data[0] as &byte, 17, 3, 3);

    try assert_eq_i32(view.y.len as i32, 9);
    try assert_eq_i32(view.u.len as i32, 4);
    try assert_eq_i32(view.v.len as i32, 4);
    try assert_eq_i32(view.y.stride as i32, 3);
    try assert_eq_i32(view.u.stride as i32, 2);
    try assert_eq_i32(view.v.stride as i32, 2);
    try assert_eq_i32(view.y.data[8] as i32, 8);
    try assert_eq_i32(view.u.data[0] as i32, 20);
    try assert_eq_i32(view.v.data[0] as i32, 30);
}

test "YuvFrameView rejects invalid strides and short storage" {
    var data: [byte: 24] = [];
    var valid: YuvFrameView = try make_i420_frame_view(&data[0] as &byte, 24, 4, 4);
    valid.y.stride = 3;

    var failed: i32 = 0;
    validate_yuv_frame_view(&valid) catch {
        failed = 1;
    };
    try assert_eq_i32(failed, 1);

    failed = 0;
    _ = make_i420_frame_view(&data[0] as &byte, 23, 4, 4) catch {
        failed = 1;
        empty_yuv_frame_view();
    };
    try assert_eq_i32(failed, 1);
}
