    reset_y16_buffers(&scalar_dst[0] as &byte, &simd_dst[0] as &byte, 48);
    predict_y4x4_vertical_right(&scalar_dst[0] as &byte, stride, &above[0] as &byte, &left[0] as &byte, above_left);
    predict_y4x4_vertical_right_u8x16(&simd_dst[0] as &byte, stride, &above[0] as &byte, &left[0] as &byte, above_left);
    try assert_y16_buffers_equal(&scalar_dst[0] as &byte, &simd_dst[0] as &byte, 48);

    reset_y16_buffers(&scalar_dst[0] as &byte, &simd_dst[0] as &byte, 48);
    predict_y4x4_vertical_left(&scalar_dst[0] as &byte, stride, &above[0] as &byte);
    predict_y4x4_vertical_left_u8x16(&simd_dst[0] as &byte, stride, &above[0] as &byte);
    try assert_y16_buffers_equal(&scalar_dst[0] as &byte, &simd_dst[0] as &byte, 48);

    reset_y16_buffers(&scalar_dst[0] as &byte, &simd_dst[0] as &byte, 48);
    predict_y4x4_horizontal_down(&scalar_dst[0] as &byte, stride, &above[0] as &byte, &left[0] as &byte, above_left);
