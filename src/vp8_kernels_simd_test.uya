test "SIMD simple loop filter matches scalar byte exact" {
    var scalar_vertical: [byte: 256] = [];
    var simd_vertical: [byte: 256] = [];
    var index: usize = 0;
    while index < 256 {
        scalar_vertical[index] = 77 as byte;
        simd_vertical[index] = 77 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < 16 {
        const base: usize = row * 16;
        if row < 8 {
            scalar_vertical[base + 3] = 100 as byte;
            scalar_vertical[base + 4] = 110 as byte;
            scalar_vertical[base + 5] = 120 as byte;
            scalar_vertical[base + 6] = 125 as byte;
        } else {
            scalar_vertical[base + 3] = 0 as byte;
            scalar_vertical[base + 4] = 10 as byte;
            scalar_vertical[base + 5] = 240 as byte;
            scalar_vertical[base + 6] = 255 as byte;
        }
        simd_vertical[base + 3] = scalar_vertical[base + 3];
        simd_vertical[base + 4] = scalar_vertical[base + 4];
        simd_vertical[base + 5] = scalar_vertical[base + 5];
        simd_vertical[base + 6] = scalar_vertical[base + 6];
        row = row + 1;
    }

    loop_filter_simple_vertical_edge(&scalar_vertical[0] as &byte, 16, 5, 16, 40 as u8);
    loop_filter_simple_vertical_edge_u8x16(&simd_vertical[0] as &byte, 16, 5, 16, 40 as u8);
    try assert_y16_buffers_equal(&scalar_vertical[0] as &byte, &simd_vertical[0] as &byte, 256);

    var scalar_horizontal: [byte: 256] = [];
    var simd_horizontal: [byte: 256] = [];
    index = 0;
    while index < 256 {
        scalar_horizontal[index] = 33 as byte;
        simd_horizontal[index] = 33 as byte;
        index = index + 1;
    }

    var col: usize = 0;
    while col < 16 {
        const h_p1: usize = (3 * 16) + col;
        const h_p0: usize = (4 * 16) + col;
        const h_q0: usize = (5 * 16) + col;
        const h_q1: usize = (6 * 16) + col;
        if col < 8 {
            scalar_horizontal[h_p1] = 128 as byte;
            scalar_horizontal[h_p0] = 122 as byte;
            scalar_horizontal[h_q0] = 110 as byte;
            scalar_horizontal[h_q1] = 100 as byte;
        } else {
            scalar_horizontal[h_p1] = 0 as byte;
            scalar_horizontal[h_p0] = 10 as byte;
            scalar_horizontal[h_q0] = 240 as byte;
            scalar_horizontal[h_q1] = 255 as byte;
        }
        simd_horizontal[h_p1] = scalar_horizontal[h_p1];
        simd_horizontal[h_p0] = scalar_horizontal[h_p0];
        simd_horizontal[h_q0] = scalar_horizontal[h_q0];
        simd_horizontal[h_q1] = scalar_horizontal[h_q1];
        col = col + 1;
    }

    loop_filter_simple_horizontal_edge(&scalar_horizontal[0] as &byte, 16, 5, 16, 40 as u8);
    loop_filter_simple_horizontal_edge_u8x16(&simd_horizontal[0] as &byte, 16, 5, 16, 40 as u8);
    try assert_y16_buffers_equal(&scalar_horizontal[0] as &byte, &simd_horizontal[0] as &byte, 256);
}

fn write_normal_vertical_fixture(data: &byte, stride: usize, edge_col: usize, rows: usize) void {
    var row: usize = 0;
    while row < rows {
        const base: usize = row * stride;
        if row < (rows / 2) {
            data[base + edge_col - 4] = 90 as byte;
            data[base + edge_col - 3] = 100 as byte;
            data[base + edge_col - 2] = 110 as byte;
            data[base + edge_col - 1] = 120 as byte;
            data[base + edge_col] = 125 as byte;
            data[base + edge_col + 1] = 130 as byte;
            data[base + edge_col + 2] = 140 as byte;
            data[base + edge_col + 3] = 150 as byte;
        } else {
            data[base + edge_col - 4] = 10 as byte;
            data[base + edge_col - 3] = 20 as byte;
            data[base + edge_col - 2] = 30 as byte;
            data[base + edge_col - 1] = 40 as byte;
            data[base + edge_col] = 220 as byte;
            data[base + edge_col + 1] = 230 as byte;
            data[base + edge_col + 2] = 240 as byte;
            data[base + edge_col + 3] = 250 as byte;
        }
        row = row + 1;
    }
}

fn write_normal_horizontal_fixture(data: &byte, stride: usize, edge_row: usize, cols: usize) void {
    var col: usize = 0;
    while col < cols {
        const p3: usize = ((edge_row - 4) * stride) + col;
        const p2: usize = ((edge_row - 3) * stride) + col;
        const p1: usize = ((edge_row - 2) * stride) + col;
        const p0: usize = ((edge_row - 1) * stride) + col;
        const q0: usize = (edge_row * stride) + col;
        const q1: usize = ((edge_row + 1) * stride) + col;
        const q2: usize = ((edge_row + 2) * stride) + col;
        const q3: usize = ((edge_row + 3) * stride) + col;
        if col < (cols / 2) {
            data[p3] = 90 as byte;
            data[p2] = 100 as byte;
            data[p1] = 110 as byte;
            data[p0] = 120 as byte;
            data[q0] = 125 as byte;
            data[q1] = 130 as byte;
            data[q2] = 140 as byte;
            data[q3] = 150 as byte;
        } else {
            data[p3] = 10 as byte;
            data[p2] = 20 as byte;
            data[p1] = 30 as byte;
            data[p0] = 40 as byte;
            data[q0] = 220 as byte;
            data[q1] = 230 as byte;
            data[q2] = 240 as byte;
            data[q3] = 250 as byte;
        }
        col = col + 1;
    }
}

test "SIMD normal loop filter matches scalar byte exact" {
    var scalar_vertical: [byte: 256] = [];
    var simd_vertical: [byte: 256] = [];
    var scalar_horizontal: [byte: 256] = [];
    var simd_horizontal: [byte: 256] = [];
    var index: usize = 0;
    while index < 256 {
        scalar_vertical[index] = 77 as byte;
        simd_vertical[index] = 77 as byte;
        scalar_horizontal[index] = 33 as byte;
        simd_horizontal[index] = 33 as byte;
        index = index + 1;
    }

    write_normal_vertical_fixture(&scalar_vertical[0] as &byte, 16, 8, 16);
    write_normal_vertical_fixture(&simd_vertical[0] as &byte, 16, 8, 16);
    loop_filter_normal_vertical_edge(&scalar_vertical[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    loop_filter_normal_vertical_edge_u8x16(&simd_vertical[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    try assert_y16_buffers_equal(&scalar_vertical[0] as &byte, &simd_vertical[0] as &byte, 256);

    write_normal_horizontal_fixture(&scalar_horizontal[0] as &byte, 16, 8, 16);
    write_normal_horizontal_fixture(&simd_horizontal[0] as &byte, 16, 8, 16);
    loop_filter_normal_horizontal_edge(&scalar_horizontal[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    loop_filter_normal_horizontal_edge_u8x16(&simd_horizontal[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    try assert_y16_buffers_equal(&scalar_horizontal[0] as &byte, &simd_horizontal[0] as &byte, 256);

    index = 0;
    while index < 256 {
        scalar_vertical[index] = 91 as byte;
        simd_vertical[index] = 91 as byte;
        scalar_horizontal[index] = 41 as byte;
        simd_horizontal[index] = 41 as byte;
        index = index + 1;
    }

    write_normal_vertical_fixture(&scalar_vertical[0] as &byte, 16, 8, 16);
    write_normal_vertical_fixture(&simd_vertical[0] as &byte, 16, 8, 16);
    loop_filter_normal_mb_vertical_edge(&scalar_vertical[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    loop_filter_normal_mb_vertical_edge_u8x16(&simd_vertical[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    try assert_y16_buffers_equal(&scalar_vertical[0] as &byte, &simd_vertical[0] as &byte, 256);

    write_normal_horizontal_fixture(&scalar_horizontal[0] as &byte, 16, 8, 16);
    write_normal_horizontal_fixture(&simd_horizontal[0] as &byte, 16, 8, 16);
    loop_filter_normal_mb_horizontal_edge(&scalar_horizontal[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    loop_filter_normal_mb_horizontal_edge_u8x16(&simd_horizontal[0] as &byte, 16, 8, 16, 40 as u8, 40 as u8, 20 as u8);
    try assert_y16_buffers_equal(&scalar_horizontal[0] as &byte, &simd_horizontal[0] as &byte, 256);
}
