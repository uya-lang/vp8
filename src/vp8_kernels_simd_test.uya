test "SIMD inter copy fixed block predictors match scalar byte exact" {
    var src16: [byte: 400] = [];
    var scalar16: [byte: 400] = [];
    var simd16: [byte: 400] = [];
    var index: usize = 0;
    while index < 400 {
        src16[index] = ((index * 13 + 17) % (256 as usize)) as byte;
        scalar16[index] = 211 as byte;
        simd16[index] = 211 as byte;
        index = index + 1;
    }
    predict_inter_copy(&scalar16[3] as &byte, 20, &src16[5] as &byte, 20, 16, 16);
    predict_inter_copy_16x16_u8x16(&simd16[3] as &byte, 20, &src16[5] as &byte, 20);
    try assert_y16_buffers_equal(&scalar16[0] as &byte, &simd16[0] as &byte, 400);

    var src8: [byte: 160] = [];
    var scalar8: [byte: 128] = [];
    var simd8: [byte: 128] = [];
    index = 0;
    while index < 160 {
        src8[index] = ((index * 9 + 101) % (256 as usize)) as byte;
        index = index + 1;
    }
    index = 0;
    while index < 128 {
        scalar8[index] = 37 as byte;
        simd8[index] = 37 as byte;
        index = index + 1;
    }
    predict_inter_copy(&scalar8[2] as &byte, 13, &src8[4] as &byte, 15, 8, 8);
    predict_inter_copy_8x8_u8x16(&simd8[2] as &byte, 13, &src8[4] as &byte, 15);
    try assert_y16_buffers_equal(&scalar8[0] as &byte, &simd8[0] as &byte, 128);

    var src4: [byte: 96] = [];
    var scalar4: [byte: 64] = [];
    var simd4: [byte: 64] = [];
    index = 0;
    while index < 96 {
        src4[index] = ((index * 19 + 3) % (256 as usize)) as byte;
        index = index + 1;
    }
    index = 0;
    while index < 64 {
        scalar4[index] = 129 as byte;
        simd4[index] = 129 as byte;
        index = index + 1;
    }
    predict_inter_copy(&scalar4[1] as &byte, 7, &src4[3] as &byte, 9, 4, 4);
    predict_inter_copy_4x4_u8x16(&simd4[1] as &byte, 7, &src4[3] as &byte, 9);
    try assert_y16_buffers_equal(&scalar4[0] as &byte, &simd4[0] as &byte, 64);
}

fn fill_distortion_fixture(src: &byte, src_stride: usize, reference: &byte, reference_stride: usize, width: usize, height: usize) void {
    var row: usize = 0;
    while row < height {
        var col: usize = 0;
        while col < width {
            const sample: usize = (row * width) + col;
            src[(row * src_stride) + col] = sample as byte;
            reference[(row * reference_stride) + col] = (255 - sample) as byte;
            col = col + 1;
        }
        row = row + 1;
    }
}

test "SIMD SAD 16x16 matches scalar byte exact across stride" {
    var src: [byte: 400] = [];
    var reference: [byte: 448] = [];
    const src_stride: usize = 19;
    const reference_stride: usize = 21;

    var index: usize = 0;
    while index < 400 {
        src[index] = 99 as byte;
        index = index + 1;
    }
    index = 0;
    while index < 448 {
        reference[index] = 44 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < 16 {
        var col: usize = 0;
        while col < 16 {
            const sample: usize = (row * 16) + col;
            src[3 + (row * src_stride) + col] = sample as byte;
            reference[7 + (row * reference_stride) + col] = (255 - sample) as byte;
            col = col + 1;
        }
        row = row + 1;
    }

    const scalar_sad: u32 = sad_16x16(&src[3] as &byte, src_stride, &reference[7] as &byte, reference_stride);
    const simd_sad: u32 = sad_16x16_u8x16(&src[3] as &byte, src_stride, &reference[7] as &byte, reference_stride);

    try assert_eq_i32(scalar_sad as i32, 32768);
    try assert_eq_i32(simd_sad as i32, scalar_sad as i32);
}

test "SIMD SAD 8x8 matches scalar byte exact across stride" {
    var src: [byte: 160] = [];
    var reference: [byte: 176] = [];
    const src_stride: usize = 13;
    const reference_stride: usize = 15;

    var index: usize = 0;
    while index < 160 {
        src[index] = 123 as byte;
        index = index + 1;
    }
    index = 0;
    while index < 176 {
        reference[index] = 77 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < 8 {
        var col: usize = 0;
        while col < 8 {
            const sample: usize = (row * 8) + col;
            src[2 + (row * src_stride) + col] = sample as byte;
            reference[5 + (row * reference_stride) + col] = (255 - sample) as byte;
            col = col + 1;
        }
        row = row + 1;
    }

    const scalar_sad: u32 = sad_8x8(&src[2] as &byte, src_stride, &reference[5] as &byte, reference_stride);
    const simd_sad: u32 = sad_8x8_u8x16(&src[2] as &byte, src_stride, &reference[5] as &byte, reference_stride);

    try assert_eq_i32(scalar_sad as i32, 12288);
    try assert_eq_i32(simd_sad as i32, scalar_sad as i32);
}

test "SIMD SAD 4x4 matches scalar byte exact across stride" {
    var src: [byte: 64] = [];
    var reference: [byte: 80] = [];
    const src_stride: usize = 7;
    const reference_stride: usize = 9;

    var index: usize = 0;
    while index < 64 {
        src[index] = 151 as byte;
        index = index + 1;
    }
    index = 0;
    while index < 80 {
        reference[index] = 33 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < 4 {
        var col: usize = 0;
        while col < 4 {
            const sample: usize = (row * 4) + col;
            src[1 + (row * src_stride) + col] = sample as byte;
            reference[3 + (row * reference_stride) + col] = (255 - sample) as byte;
            col = col + 1;
        }
        row = row + 1;
    }

    const scalar_sad: u32 = sad_4x4(&src[1] as &byte, src_stride, &reference[3] as &byte, reference_stride);
    const simd_sad: u32 = sad_4x4_u8x16(&src[1] as &byte, src_stride, &reference[3] as &byte, reference_stride);

    try assert_eq_i32(scalar_sad as i32, 3840);
    try assert_eq_i32(simd_sad as i32, scalar_sad as i32);
}

