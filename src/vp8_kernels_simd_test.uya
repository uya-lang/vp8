    var simd_dqcoeff: [i16: 16] = [ 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77, 77 ];
    var expected_qcoeff: [i16: 16] = [
        3, -2, 0, 1,
        4, 0, -5, 6,
        0, 7, -8, 0,
        9, 0, 10, -11
    ];

    const scalar_summary: CoefficientBlockSummary = try quantize_block_4x4(&input[0] as &i16, 5 as i16, 7 as i16, &scalar_qcoeff[0] as &i16, &scalar_dqcoeff[0] as &i16);
    const simd_summary: CoefficientBlockSummary = try quantize_block_4x4_i16x16(&input[0] as &i16, 5 as i16, 7 as i16, &simd_qcoeff[0] as &i16, &simd_dqcoeff[0] as &i16);

    try assert_i16_block_eq(&scalar_qcoeff[0] as &i16, &expected_qcoeff[0] as &i16);
    try assert_i16_block_eq(&simd_qcoeff[0] as &i16, &scalar_qcoeff[0] as &i16);
    try assert_i16_block_eq(&simd_dqcoeff[0] as &i16, &scalar_dqcoeff[0] as &i16);
    try assert_summary_eq(&simd_summary, &scalar_summary);

    var scalar_dequantized: [i16: 16] = [];
    var simd_dequantized: [i16: 16] = [];
    dequant_block_4x4(&scalar_qcoeff[0] as &i16, 5 as i16, 7 as i16, &scalar_dequantized[0] as &i16);
    dequant_block_4x4_i16x16(&scalar_qcoeff[0] as &i16, 5 as i16, 7 as i16, &simd_dequantized[0] as &i16);
    try assert_i16_block_eq(&simd_dequantized[0] as &i16, &scalar_dequantized[0] as &i16);
}

