use std.testing.assert_eq_i32;
use std.testing.expect;

use vp8.common.plane.Plane;
use vp8.common.plane.extend_plane_border;
use vp8.common.plane.make_plane_view;
use vp8.kernels.scalar.add_residual_4x4_clamped;
use vp8.kernels.simd.add_residual_4x4_clamped_u8x16;
use vp8.kernels.simd.load_i16x8;
use vp8.kernels.simd.load_i32x4;
use vp8.kernels.simd.load_u8x16;
use vp8.kernels.simd.extend_plane_border_u8x16;
use vp8.kernels.simd.plane_copy_u8x16;
use vp8.kernels.simd.plane_fill_u8x16;
use vp8.kernels.simd.store_i16x8;
use vp8.kernels.simd.store_i32x4;
use vp8.kernels.simd.store_u8x16;

type TestU8x16 = @vector(u8, 16);
type TestI16x8 = @vector(i16, 8);
type TestI32x4 = @vector(i32, 4);

test "SIMD helper loads and stores u8x16 blocks" {
    var src: [u8: 18] = [
        99u8, 1u8, 2u8, 3u8, 4u8, 5u8, 6u8, 7u8, 8u8,
        9u8, 10u8, 11u8, 12u8, 13u8, 14u8, 15u8, 16u8, 77u8
    ];
    var dst: [u8: 18] = [
        55u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 66u8
    ];

    const values: TestU8x16 = load_u8x16(&src[1] as &u8);
    store_u8x16(&dst[1] as &u8, values);

    try assert_eq_i32(dst[0] as i32, 55);
    try assert_eq_i32(dst[17] as i32, 66);
    var index: usize = 0;
    while index < 16 {
        try assert_eq_i32(dst[index + 1] as i32, src[index + 1] as i32);
        index = index + 1;
    }

    try expect(@vector.all(values >= @vector.splat(1u8)));
}

test "SIMD helper loads and stores i16x8 blocks" {
    var src: [i16: 10] = [ -99, -1, 2, -3, 4, -5, 6, -7, 8, 77 ];
    var dst: [i16: 10] = [ -55, 0, 0, 0, 0, 0, 0, 0, 0, 66 ];

    const values: TestI16x8 = load_i16x8(&src[1] as &i16);
    store_i16x8(&dst[1] as &i16, values);

    try assert_eq_i32(dst[0] as i32, -55);
    try assert_eq_i32(dst[9] as i32, 66);
    var index: usize = 0;
    while index < 8 {
        try assert_eq_i32(dst[index + 1] as i32, src[index + 1] as i32);
        index = index + 1;
    }
}

test "SIMD helper loads and stores i32x4 blocks" {
    var src: [i32: 6] = [ -99, 1000, -2000, 3000, -4000, 77 ];
    var dst: [i32: 6] = [ -55, 0, 0, 0, 0, 66 ];

    const values: TestI32x4 = load_i32x4(&src[1] as &i32);
    store_i32x4(&dst[1] as &i32, values);

    try assert_eq_i32(dst[0], -55);
    try assert_eq_i32(dst[5], 66);
    var index: usize = 0;
    while index < 4 {
        try assert_eq_i32(dst[index + 1], src[index + 1]);
        index = index + 1;
    }
}

test "SIMD plane copy u8x16 copies rows with scalar tails" {
    var src: [byte: 96] = [];
    var dst: [byte: 96] = [];

    var index: usize = 0;
    while index < 96 {
        src[index] = (index + 1) as byte;
        dst[index] = 222 as byte;
        index = index + 1;
    }

    plane_copy_u8x16(&dst[5] as &byte, 24, &src[7] as &byte, 22, 18, 3);

    var row: usize = 0;
    while row < 3 {
        var col: usize = 0;
        while col < 18 {
            const dst_index: usize = 5 + (row * 24) + col;
            const src_index: usize = 7 + (row * 22) + col;
            try assert_eq_i32(dst[dst_index] as i32, src[src_index] as i32);
            col = col + 1;
        }
        try assert_eq_i32(dst[5 + (row * 24) + 18] as i32, 222);
        row = row + 1;
    }

    try assert_eq_i32(dst[4] as i32, 222);
    try assert_eq_i32(dst[5 + (3 * 24)] as i32, 222);
}

test "SIMD plane fill u8x16 fills rows with scalar tails" {
    var dst: [byte: 96] = [];

    var index: usize = 0;
    while index < 96 {
        dst[index] = 111 as byte;
        index = index + 1;
    }

    plane_fill_u8x16(&dst[3] as &byte, 21, 20, 3, 77 as byte);

    var row: usize = 0;
    while row < 3 {
        var col: usize = 0;
        while col < 20 {
            try assert_eq_i32(dst[3 + (row * 21) + col] as i32, 77);
            col = col + 1;
        }
        try assert_eq_i32(dst[3 + (row * 21) + 20] as i32, 111);
        row = row + 1;
    }

    try assert_eq_i32(dst[2] as i32, 111);
    try assert_eq_i32(dst[3 + (3 * 21)] as i32, 111);
}

test "SIMD border extension replicates visible edges and rows" {
    var plane: [byte: 2304] = [];
    const stride: usize = 64;
    const width: usize = 19;
    const height: usize = 3;
    const border: usize = 16;
    const padded_width: usize = width + (border * 2);

    var index: usize = 0;
    while index < 2304 {
        plane[index] = 231 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < height {
        var col: usize = 0;
        while col < width {
            plane[((border + row) * stride) + border + col] = (10 + (row * 32) + col) as byte;
            col = col + 1;
        }
        row = row + 1;
    }

    extend_plane_border_u8x16(&plane[0] as &byte, stride, width, height, border);

    row = 0;
    while row < height {
        const data_row: usize = border + row;
        const left_value: i32 = (10 + (row * 32)) as i32;
        const right_value: i32 = (10 + (row * 32) + width - 1) as i32;

        var col: usize = 0;
        while col < border {
            try assert_eq_i32(plane[(data_row * stride) + col] as i32, left_value);
            col = col + 1;
        }

        col = 0;
        while col < border {
            try assert_eq_i32(plane[(data_row * stride) + border + width + col] as i32, right_value);
            col = col + 1;
        }

        try assert_eq_i32(plane[(data_row * stride) + padded_width] as i32, 231);
        row = row + 1;
    }

    var top_row: usize = 0;
    while top_row < border {
        var col: usize = 0;
        while col < padded_width {
            try assert_eq_i32(plane[(top_row * stride) + col] as i32, plane[(border * stride) + col] as i32);
            col = col + 1;
        }
        try assert_eq_i32(plane[(top_row * stride) + padded_width] as i32, 231);
        top_row = top_row + 1;
    }

    var bottom_row: usize = 0;
    while bottom_row < border {
        const dst_row: usize = border + height + bottom_row;
        const src_row: usize = border + height - 1;
        var col: usize = 0;
        while col < padded_width {
            try assert_eq_i32(plane[(dst_row * stride) + col] as i32, plane[(src_row * stride) + col] as i32);
            col = col + 1;
        }
        try assert_eq_i32(plane[(dst_row * stride) + padded_width] as i32, 231);
        bottom_row = bottom_row + 1;
    }
}

test "SIMD border extension matches scalar plane extension byte exact" {
    var scalar: [byte: 2304] = [];
    var simd: [byte: 2304] = [];
    const stride: usize = 64;
    const width: usize = 19;
    const height: usize = 3;
    const border: usize = 16;

    var index: usize = 0;
    while index < 2304 {
        scalar[index] = 199 as byte;
        simd[index] = 199 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < height {
        var col: usize = 0;
        while col < width {
            const value: byte = (20 + (row * 31) + col) as byte;
            scalar[((border + row) * stride) + border + col] = value;
            simd[((border + row) * stride) + border + col] = value;
            col = col + 1;
        }
        row = row + 1;
    }

    var scalar_plane: Plane = try make_plane_view(&scalar[0] as &byte, 2304, width, height, stride, border);
    extend_plane_border(&scalar_plane);
    extend_plane_border_u8x16(&simd[0] as &byte, stride, width, height, border);

    index = 0;
    while index < 2304 {
        try assert_eq_i32(simd[index] as i32, scalar[index] as i32);
        index = index + 1;
    }
}

test "SIMD residual add clamp matches scalar byte exact across stride" {
    var scalar_dst: [byte: 40] = [];
    var simd_dst: [byte: 40] = [];
    var residual: [i16: 16] = [
        -1000, -20, 0, 1,
        10, 120, 30000, -30000,
        255, -255, 400, -400,
        32, -32, 512, -512
    ];
    const initial: [byte: 16] = [
        0 as byte, 10 as byte, 128 as byte, 255 as byte,
        15 as byte, 120 as byte, 1 as byte, 250 as byte,
        200 as byte, 10 as byte, 240 as byte, 30 as byte,
        99 as byte, 33 as byte, 128 as byte, 250 as byte
    ];
    const stride: usize = 8;

    var index: usize = 0;
    while index < 40 {
        scalar_dst[index] = 203 as byte;
        simd_dst[index] = 203 as byte;
        index = index + 1;
    }

    var row: usize = 0;
    while row < 4 {
        var col: usize = 0;
        while col < 4 {
            const src_index: usize = (row * 4) + col;
            const dst_index: usize = (row * stride) + col;
            scalar_dst[dst_index] = initial[src_index];
            simd_dst[dst_index] = initial[src_index];
            col = col + 1;
        }
        row = row + 1;
    }

    add_residual_4x4_clamped(&scalar_dst[0] as &byte, stride, &residual[0] as &i16);
    add_residual_4x4_clamped_u8x16(&simd_dst[0] as &byte, stride, &residual[0] as &i16);

    index = 0;
    while index < 40 {
        try assert_eq_i32(simd_dst[index] as i32, scalar_dst[index] as i32);
        index = index + 1;
    }
}
