use std.testing.assert_eq_i32;
use std.testing.expect;

use vp8.kernels.simd.load_i16x8;
use vp8.kernels.simd.load_i32x4;
use vp8.kernels.simd.load_u8x16;
use vp8.kernels.simd.plane_copy_u8x16;
use vp8.kernels.simd.plane_fill_u8x16;
use vp8.kernels.simd.store_i16x8;
use vp8.kernels.simd.store_i32x4;
use vp8.kernels.simd.store_u8x16;

type TestU8x16 = @vector(u8, 16);
type TestI16x8 = @vector(i16, 8);
type TestI32x4 = @vector(i32, 4);

test "SIMD helper loads and stores u8x16 blocks" {
    var src: [u8: 18] = [
        99u8, 1u8, 2u8, 3u8, 4u8, 5u8, 6u8, 7u8, 8u8,
        9u8, 10u8, 11u8, 12u8, 13u8, 14u8, 15u8, 16u8, 77u8
    ];
    var dst: [u8: 18] = [
        55u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8,
        0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 66u8
    ];

    const values: TestU8x16 = load_u8x16(&src[1] as &u8);
    store_u8x16(&dst[1] as &u8, values);

    try assert_eq_i32(dst[0] as i32, 55);
    try assert_eq_i32(dst[17] as i32, 66);
    var index: usize = 0;
    while index < 16 {
        try assert_eq_i32(dst[index + 1] as i32, src[index + 1] as i32);
        index = index + 1;
    }

    try expect(@vector.all(values >= @vector.splat(1u8)));
}

test "SIMD helper loads and stores i16x8 blocks" {
    var src: [i16: 10] = [ -99, -1, 2, -3, 4, -5, 6, -7, 8, 77 ];
    var dst: [i16: 10] = [ -55, 0, 0, 0, 0, 0, 0, 0, 0, 66 ];

    const values: TestI16x8 = load_i16x8(&src[1] as &i16);
    store_i16x8(&dst[1] as &i16, values);

    try assert_eq_i32(dst[0] as i32, -55);
    try assert_eq_i32(dst[9] as i32, 66);
    var index: usize = 0;
    while index < 8 {
        try assert_eq_i32(dst[index + 1] as i32, src[index + 1] as i32);
        index = index + 1;
    }
}

test "SIMD helper loads and stores i32x4 blocks" {
    var src: [i32: 6] = [ -99, 1000, -2000, 3000, -4000, 77 ];
    var dst: [i32: 6] = [ -55, 0, 0, 0, 0, 66 ];

    const values: TestI32x4 = load_i32x4(&src[1] as &i32);
    store_i32x4(&dst[1] as &i32, values);

    try assert_eq_i32(dst[0], -55);
    try assert_eq_i32(dst[5], 66);
    var index: usize = 0;
    while index < 4 {
        try assert_eq_i32(dst[index + 1], src[index + 1]);
        index = index + 1;
    }
}

test "SIMD plane copy u8x16 copies rows with scalar tails" {
    var src: [byte: 96] = [];
    var dst: [byte: 96] = [];

    var index: usize = 0;
    while index < 96 {
        src[index] = (index + 1) as byte;
        dst[index] = 222 as byte;
        index = index + 1;
    }

    plane_copy_u8x16(&dst[5] as &byte, 24, &src[7] as &byte, 22, 18, 3);

    var row: usize = 0;
    while row < 3 {
        var col: usize = 0;
        while col < 18 {
            const dst_index: usize = 5 + (row * 24) + col;
            const src_index: usize = 7 + (row * 22) + col;
            try assert_eq_i32(dst[dst_index] as i32, src[src_index] as i32);
            col = col + 1;
        }
        try assert_eq_i32(dst[5 + (row * 24) + 18] as i32, 222);
        row = row + 1;
    }

    try assert_eq_i32(dst[4] as i32, 222);
    try assert_eq_i32(dst[5 + (3 * 24)] as i32, 222);
}

test "SIMD plane fill u8x16 fills rows with scalar tails" {
    var dst: [byte: 96] = [];

    var index: usize = 0;
    while index < 96 {
        dst[index] = 111 as byte;
        index = index + 1;
    }

    plane_fill_u8x16(&dst[3] as &byte, 21, 20, 3, 77 as byte);

    var row: usize = 0;
    while row < 3 {
        var col: usize = 0;
        while col < 20 {
            try assert_eq_i32(dst[3 + (row * 21) + col] as i32, 77);
            col = col + 1;
        }
        try assert_eq_i32(dst[3 + (row * 21) + 20] as i32, 111);
        row = row + 1;
    }

    try assert_eq_i32(dst[2] as i32, 111);
    try assert_eq_i32(dst[3 + (3 * 21)] as i32, 111);
}
