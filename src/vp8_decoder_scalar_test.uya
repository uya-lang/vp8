fn scratch_test_align_up(value: usize, alignment: usize) usize {
    return ((value + alignment - 1) / alignment) * alignment;
}

fn write_literal(writer: &BoolWriter, value: u32, bit_count: u8) !void {
    var index: i8 = (bit_count as i8) - 1;
    while index >= 0 {
        try bool_writer_write(writer, ((value >> (index as u8)) & (1 as u32)) as u8, 128 as byte);
        index = index - 1;
    }
}

fn write_minimal_key_frame_partition_for_mb_count(writer: &BoolWriter, mb_count: usize) !void {
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 1 as u8);
    try write_literal(writer, 0, 6 as u8);
    try write_literal(writer, 0, 3 as u8);
    try write_literal(writer, 0, 2 as u8);
    try write_literal(writer, 0, 7 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);

    var index: usize = 0;
    while index < 1056 {
        try bool_writer_write(writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    const key_y_mode_probs: [byte: 4] = [ 145, 156, 163, 128 ];
    const key_uv_mode_probs: [byte: 3] = [ 142, 114, 183 ];

    index = 0;
    while index < mb_count {
        try bool_writer_write(writer, 1 as u8, key_y_mode_probs[0]);
        try bool_writer_write(writer, 0 as u8, key_y_mode_probs[1]);
        try bool_writer_write(writer, 0 as u8, key_y_mode_probs[2]);
        try bool_writer_write(writer, 0 as u8, key_uv_mode_probs[0]);
        index = index + 1;
    }

    try bool_writer_flush(writer);
}

fn write_minimal_key_frame_partition(writer: &BoolWriter) !void {
    try write_minimal_key_frame_partition_for_mb_count(writer, 1);
}

fn write_b_pred_key_frame_partition(writer: &BoolWriter) !void {
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 1 as u8);
    try write_literal(writer, 0, 6 as u8);
    try write_literal(writer, 0, 3 as u8);
    try write_literal(writer, 0, 2 as u8);
    try write_literal(writer, 0, 7 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);

    var index: usize = 0;
    while index < 1056 {
        try bool_writer_write(writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    try bool_writer_write(writer, 0 as u8, 128 as byte);

    try bool_writer_write(writer, 0 as u8, 145 as byte);
    index = 0;
    while index < 16 {
        try bool_writer_write(writer, 0 as u8, try vp8_kf_bmode_prob(VP8_B_MODE_DC, VP8_B_MODE_DC, 0));
        index = index + 1;
    }
    try bool_writer_write(writer, 0 as u8, 142 as byte);

    try bool_writer_flush(writer);
}

fn test_coeff_prob_offset(block_type: usize, position: usize, context: byte) !usize {
    const band: byte = try coefficient_band(position);
    return ((((block_type * (8 as usize)) + (band as usize)) * (3 as usize)) + (context as usize)) * (11 as usize);
}

test "Decoder can be constructed with a forced scalar kernel table" {
    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 4096);
    defer free_decoder_context(&context);

    const kernels: KernelFunctionTable = make_scalar_kernel_table();
    var decoder: Decoder = make_decoder_with_kernel_table(&context, &kernels);

    try expect(decoder.kernels.active_level == SimdLevel.scalar);
    try expect(decoder.kernels.predict_inter_copy_fn != null);
    try expect(decoder.kernels.add_residual_4x4_clamped_fn != null);
}

test "small frame token partition row golden selects decoder token readers" {
    var data: [byte: 16] = [];
    var readers: [BoolReader: 8] = [];

    var index: usize = 0;
    while index < 8 {
        readers[index] = try make_bool_reader_for_partition(&data[index * 2] as &byte, 2, index as i32);
        index = index + 1;
    }

    const four_partition_rows: [i32: 8] = [ 0, 1, 2, 3, 0, 1, 2, 3 ];
    var row: usize = 0;
    while row < 8 {
        const selected: &BoolReader = try decoder_token_reader_for_mb_row(&readers[0] as &BoolReader, row, 4 as u8);
        try assert_eq_i32(bool_reader_partition_id(selected), four_partition_rows[row]);
        row = row + 1;
    }

    const two_partition_rows: [i32: 4] = [ 0, 1, 0, 1 ];
    row = 0;
    while row < 4 {
        const selected: &BoolReader = try decoder_token_reader_for_mb_row(&readers[0] as &BoolReader, row, 2 as u8);
        try assert_eq_i32(bool_reader_partition_id(selected), two_partition_rows[row]);
        row = row + 1;
    }
}

fn write_eob_token(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = try test_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset]);
}

fn write_one_token_then_eob(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = try test_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset]);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset + 1]);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset + 2]);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_eob_token(writer, coeff_probs, block_type, position + 1, 1 as byte);
}

fn write_zero_token(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = try test_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset]);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset + 1]);
}

fn write_zero_then_one_token_then_eob(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    try write_zero_token(writer, coeff_probs, block_type, position, context);
    try write_one_token_then_eob(writer, coeff_probs, block_type, position + 1, 0 as byte);
}

fn write_four_token_then_eob(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = try test_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset]);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset + 1]);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset + 2]);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset + 3]);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset + 4]);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset + 5]);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_eob_token(writer, coeff_probs, block_type, position + 1, 2 as byte);
}

fn write_key_frame_tokens_with_u_dc(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_eob_token(writer, probs.coeff_probs, 1, 0, 0 as byte);

    var block: usize = 0;
    while block < 16 {
        try write_eob_token(writer, probs.coeff_probs, 0, 1, 0 as byte);
        block = block + 1;
    }

    try write_one_token_then_eob(writer, probs.coeff_probs, 2, 0, 0 as byte);
    try write_eob_token(writer, probs.coeff_probs, 2, 0, 1 as byte);
    try write_eob_token(writer, probs.coeff_probs, 2, 0, 1 as byte);
    try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);

    block = 0;
    while block < 4 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn write_b_pred_tokens_with_first_y_dc(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_one_token_then_eob(writer, probs.coeff_probs, 3, 0, 0 as byte);

    var block: usize = 1;
    while block < 16 {
        var context: byte = 0 as byte;
        if block == 1 || block == 4 {
            context = 1 as byte;
        }
        try write_eob_token(writer, probs.coeff_probs, 3, 0, context);
        block = block + 1;
    }

    block = 0;
    while block < 8 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn write_b_pred_tokens_with_zero_then_ac(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_zero_then_one_token_then_eob(writer, probs.coeff_probs, 3, 0, 0 as byte);

    var block: usize = 1;
    while block < 16 {
        var context: byte = 0 as byte;
        if block == 1 || block == 4 {
            context = 1 as byte;
        }
        try write_eob_token(writer, probs.coeff_probs, 3, 0, context);
        block = block + 1;
    }

    block = 0;
    while block < 8 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn write_inter_tokens_with_y2_dc(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_four_token_then_eob(writer, probs.coeff_probs, 1, 0, 0 as byte);

    var block_y: usize = 0;
    while block_y < 4 {
        var block_x: usize = 0;
        while block_x < 4 {
            var context: byte = 2 as byte;
            if block_x == 0 && block_y == 0 {
                context = 0 as byte;
            } else if block_x == 0 || block_y == 0 {
                context = 1 as byte;
            }
            try write_eob_token(writer, probs.coeff_probs, 0, 1, context);
            block_x = block_x + 1;
        }
        block_y = block_y + 1;
    }

    var block: usize = 0;
    while block < 8 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn write_all_eob_macroblock_tokens(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_eob_token(writer, probs.coeff_probs, 1, 0, 0 as byte);

    var block: usize = 0;
    while block < 16 {
        try write_eob_token(writer, probs.coeff_probs, 0, 1, 0 as byte);
        block = block + 1;
    }

    block = 0;
    while block < 8 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }
}

fn write_all_eob_tokens(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_all_eob_macroblock_tokens(writer, probs);
    try bool_writer_flush(writer);
}

fn write_all_eob_tokens_for_mb_count(writer: &BoolWriter, probs: &Vp8Probs, mb_count: usize) !void {
    var mb_index: usize = 0;
    while mb_index < mb_count {
        try write_all_eob_macroblock_tokens(writer, probs);
        mb_index = mb_index + 1;
    }

    try bool_writer_flush(writer);
}

fn make_key_frame(width: u16, height: u16, first_partition_size: u32, first_partition: &byte, token_partition: &byte, token_partition_len: usize, frame: &byte) usize {
    const tag: u32 = (0 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | (first_partition_size << 5);
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;
    frame[3] = 0x9d as byte;
    frame[4] = 0x01 as byte;
    frame[5] = 0x2a as byte;
    frame[6] = (width & (0xff as u16)) as byte;
    frame[7] = ((width >> 8) & (0xff as u16)) as byte;
    frame[8] = (height & (0xff as u16)) as byte;
    frame[9] = ((height >> 8) & (0xff as u16)) as byte;

    var index: usize = 0;
    while index < (first_partition_size as usize) {
        frame[10 + index] = first_partition[index];
        index = index + 1;
    }
    index = 0;
    while index < token_partition_len {
        frame[10 + (first_partition_size as usize) + index] = token_partition[index];
        index = index + 1;
    }

    return 10 + (first_partition_size as usize) + token_partition_len;
}

fn make_16x16_key_frame(first_partition: &byte, token_partition: &byte, token_partition_len: usize, frame: &byte) void {
    _ = make_key_frame(16 as u16, 16 as u16, 256 as u32, first_partition, token_partition, token_partition_len, frame);
}

fn make_16x16_inter_frame(first_partition: &byte, first_partition_len: usize, token_partition: &byte, token_partition_len: usize, frame: &byte) void {
    const tag: u32 = (1 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | ((first_partition_len as u32) << 5);
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;

    var index: usize = 0;
    while index < first_partition_len {
        frame[3 + index] = first_partition[index];
        index = index + 1;
    }
    index = 0;
    while index < token_partition_len {
        frame[3 + first_partition_len + index] = token_partition[index];
        index = index + 1;
    }
}

fn write_minimal_inter_first_partition(writer: &BoolWriter) !void {
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 1 as u8);
    try write_literal(writer, 0, 6 as u8);
    try write_literal(writer, 0, 3 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 2 as u8);
    try write_literal(writer, 0, 7 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);

    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 2 as u8);
    try write_literal(writer, 0, 2 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 1 as u8, 128 as byte);
    try bool_writer_write(writer, 1 as u8, 128 as byte);

    var index: usize = 0;
    while index < 1056 {
        try bool_writer_write(writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    index = 0;
    while index < 38 {
        try bool_writer_write(writer, 0 as u8, vp8_mv_update_probability(index));
        index = index + 1;
    }

    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 145, 8 as u8);
    try write_literal(writer, 156, 8 as u8);
    try write_literal(writer, 163, 8 as u8);
    try bool_writer_write(writer, 1 as u8, 145 as byte);
    try bool_writer_write(writer, 0 as u8, 156 as byte);
    try bool_writer_flush(writer);
}

fn write_vertical_filter_window(data: &byte, stride: usize, row: usize, edge_col: usize) void {
    const base: usize = row * stride;
    data[base + edge_col - 4] = 90 as byte;
    data[base + edge_col - 3] = 100 as byte;
    data[base + edge_col - 2] = 110 as byte;
    data[base + edge_col - 1] = 120 as byte;
    data[base + edge_col] = 125 as byte;
    data[base + edge_col + 1] = 130 as byte;
    data[base + edge_col + 2] = 140 as byte;
    data[base + edge_col + 3] = 150 as byte;
}

fn write_horizontal_filter_window(data: &byte, stride: usize, col: usize, edge_row: usize) void {
    data[((edge_row - 4) * stride) + col] = 90 as byte;
    data[((edge_row - 3) * stride) + col] = 100 as byte;
    data[((edge_row - 2) * stride) + col] = 110 as byte;
    data[((edge_row - 1) * stride) + col] = 120 as byte;
    data[(edge_row * stride) + col] = 125 as byte;
    data[((edge_row + 1) * stride) + col] = 130 as byte;
    data[((edge_row + 2) * stride) + col] = 140 as byte;
    data[((edge_row + 3) * stride) + col] = 150 as byte;
}

test "Decoder.decode_frame wires header mode token readers and scalar kernel state" {
    var compressed: [byte: 256] = [];
    var writer: BoolWriter = make_bool_writer(&compressed[0] as &byte, 256);
    try write_minimal_key_frame_partition(&writer);

    const first_partition_size: u32 = 256 as u32;
    const tag: u32 = (0 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | (first_partition_size << 5);
    var frame: [byte: 268] = [];
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;
    frame[3] = 0x9d as byte;
    frame[4] = 0x01 as byte;
    frame[5] = 0x2a as byte;
    frame[6] = 16 as byte;
    frame[7] = 0 as byte;
    frame[8] = 16 as byte;
    frame[9] = 0 as byte;

    var index: usize = 0;
    while index < 256 {
        frame[10 + index] = compressed[index];
        index = index + 1;
    }
    frame[268 - 2] = 0 as byte;
    frame[268 - 1] = 0 as byte;

    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 4096);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);

    const result: DecoderFrameResult = try decoder_decode_frame(&decoder, &frame[0] as &byte, 268);
    const header: Vp8FrameHeader = result.header;
    try assert_eq_i32(header.width as i32, 16);
    try assert_eq_i32(header.height as i32, 16);
    try assert_eq_i32(result.token_partition_count as i32, 1);
    try assert_eq_i32(result.macroblock_count as i32, 1);
    try assert_eq_i32(result.parsed_token_partition_count as i32, 1);
    try assert_eq_i32(result.scalar_kernel_border_extended as i32, 0);
    try expect(context.scratch.high_water > token_decode_row_scratch_bytes());
    try expect(context.scratch.high_water >= (try token_decode_row_output_bytes(context.grid.mb_cols)));
    try assert_eq_i32(context.hot_loop_heap_allocation_count as i32, 0);
    try assert_eq_i32(result.performance.macroblock_count as i32, 1);
    try assert_eq_i32(result.performance.thread_count as i32, 1);
    try assert_eq_i32(result.performance.hot_loop_heap_allocation_count as i32, 0);
    try assert_eq_i32(result.performance.bytes_copied_for_ref_refresh as i32, 0);
    try expect(result.performance.coeff_scratch_bytes_written > 0);
    try expect(result.performance.coeff_scratch_bytes_read > 0);
    try expect(result.performance.coeff_scratch_high_water >= (try token_decode_row_output_bytes(context.grid.mb_cols)));
    try assert_eq_i32(result.performance.border_extension_count as i32, 0);
    try assert_eq_i32(context.last_frame_stats.border_extension_count as i32, result.performance.border_extension_count as i32);
    try assert_eq_i32(context.mb_info.y_mode[0] as i32, 0);
    try assert_eq_i32(context.mb_info.uv_mode[0] as i32, 0);

    const current: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    try expect(frame_buffer_border_dirty(current));
    try assert_eq_i32(current.y.plane.origin[0] as i32, 128);
    try assert_eq_i32(current.y.plane.origin[15] as i32, 128);
    try assert_eq_i32(current.y.plane.origin[15 * current.y.plane.stride] as i32, 128);
    try assert_eq_i32(current.u.plane.origin[0] as i32, 128);
    try assert_eq_i32(current.v.plane.origin[0] as i32, 128);
}

test "key frame decode resets entropy probabilities and refreshes all references" {
    var first_partition: [byte: 256] = [];
    var first_writer: BoolWriter = make_bool_writer(&first_partition[0] as &byte, 256);
    try write_minimal_key_frame_partition(&first_writer);

    const defaults: Vp8Probs = vp8_default_probs();
    var token_partition: [byte: 64] = [];
    var token_writer: BoolWriter = make_bool_writer(&token_partition[0] as &byte, 64);
    try write_all_eob_tokens(&token_writer, &defaults);

    var frame: [byte: 330] = [];
    make_16x16_key_frame(&first_partition[0] as &byte, &token_partition[0] as &byte, bool_writer_byte_count(&token_writer), &frame[0] as &byte);

    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 4096);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);

    decoder.y_mode_probs[0] = 1 as byte;
    decoder.y_mode_probs[3] = 1 as byte;
    decoder.uv_mode_probs[0] = 1 as byte;
    decoder.uv_mode_probs[2] = 1 as byte;
    decoder.coeff_probs[33] = 1 as byte;
    decoder.coeff_probs[1055] = 1 as byte;
    decoder.mv_probs[0] = 1 as byte;
    decoder.mv_probs[37] = 1 as byte;

    const result: DecoderFrameResult = try decoder_decode_frame(&decoder, &frame[0] as &byte, 266 + bool_writer_byte_count(&token_writer));
    defer decoded_frame_release(&result.output) catch {};

    try assert_eq_i32(decoder.y_mode_probs[0] as i32, defaults.y_mode_probs[0] as i32);
    try assert_eq_i32(decoder.y_mode_probs[3] as i32, defaults.y_mode_probs[3] as i32);
    try assert_eq_i32(decoder.uv_mode_probs[0] as i32, defaults.uv_mode_probs[0] as i32);
    try assert_eq_i32(decoder.uv_mode_probs[2] as i32, defaults.uv_mode_probs[2] as i32);
    try assert_eq_i32(decoder.coeff_probs[33] as i32, defaults.coeff_probs[33] as i32);
    try assert_eq_i32(decoder.coeff_probs[1055] as i32, defaults.coeff_probs[1055] as i32);
    try assert_eq_i32(decoder.mv_probs[0] as i32, defaults.mv_probs[0] as i32);
    try assert_eq_i32(decoder.mv_probs[37] as i32, defaults.mv_probs[37] as i32);

    try assert_eq_i32(context.frame_pool.last_slot as i32, context.frame_pool.current_slot as i32);
    try assert_eq_i32(context.frame_pool.golden_slot as i32, context.frame_pool.current_slot as i32);
    try assert_eq_i32(context.frame_pool.altref_slot as i32, context.frame_pool.current_slot as i32);
    try assert_eq_i32(context.frame_pool.slot_ref_count0 as i32, 3);
    try assert_eq_i32(context.frame_pool.slot_ref_count1 as i32, 0);
    try assert_eq_i32(context.frame_pool.slot_ref_count2 as i32, 0);
    try assert_eq_i32(context.frame_pool.slot_ref_count3 as i32, 0);
    try assert_eq_i32(result.performance.bytes_copied_for_ref_refresh as i32, 0);

    const refreshed_last: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.last_slot);
    const refreshed_golden: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.golden_slot);
    const refreshed_altref: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.altref_slot);
    try assert_eq_i32(refreshed_last.y.plane.origin[0] as i32, 128);
    try assert_eq_i32(refreshed_golden.u.plane.origin[0] as i32, 128);
    try assert_eq_i32(refreshed_altref.v.plane.origin[0] as i32, 128);
}

