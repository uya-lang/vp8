use std.testing.assert_eq_i32;

use vp8.bitstream.bool_writer.BoolWriter;
use vp8.bitstream.bool_writer.bool_writer_byte_count;
use vp8.bitstream.bool_writer.bool_writer_flush;
use vp8.bitstream.bool_writer.bool_writer_write;
use vp8.bitstream.header.Vp8FrameHeader;
use vp8.bitstream.header.Vp8LoopFilterHeader;
use vp8.bitstream.header.Vp8Probs;
use vp8.bitstream.header.vp8_default_probs;
use vp8.bitstream.header.vp8_coeff_update_probability;
use vp8.bitstream.header.vp8_mv_update_probability;
use vp8.common.decode_context.DecoderContext;
use vp8.common.decode_context.allocate_decoder_context;
use vp8.common.decode_context.free_decoder_context;
use vp8.common.frame.FrameBuffer;
use vp8.common.frame.frame_pool_get_slot;
use vp8.common.frame.frame_pool_refresh_references;
use vp8.decoder.scalar.Decoder;
use vp8.decoder.scalar.DecoderFrameResult;
use vp8.decoder.scalar.decoder_decode_dequant_reconstruct_4x4;
use vp8.decoder.scalar.decoder_apply_row_delayed_loop_filter;
use vp8.decoder.scalar.make_decoder;
use vp8.decoder.scalar.decoder_decode_frame;
use vp8.token.parse.CoefficientBlockSummary;
use vp8.token.parse.coefficient_band;

fn write_literal(writer: &BoolWriter, value: u32, bit_count: u8) !void {
    var index: i8 = (bit_count as i8) - 1;
    while index >= 0 {
        try bool_writer_write(writer, ((value >> (index as u8)) & (1 as u32)) as u8, 128 as byte);
        index = index - 1;
    }
}

fn write_minimal_key_frame_partition(writer: &BoolWriter) !void {
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 1 as u8);
    try write_literal(writer, 0, 6 as u8);
    try write_literal(writer, 0, 3 as u8);
    try write_literal(writer, 0, 7 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 2 as u8);

    var index: usize = 0;
    while index < 1056 {
        try bool_writer_write(writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    index = 0;
    while index < 38 {
        try bool_writer_write(writer, 0 as u8, vp8_mv_update_probability(index));
        index = index + 1;
    }

    const y_mode_probs: [byte: 4] = [ 112, 86, 140, 37 ];
    const uv_mode_probs: [byte: 3] = [ 162, 101, 204 ];
    try bool_writer_write(writer, 0 as u8, y_mode_probs[0]);
    try bool_writer_write(writer, 0 as u8, uv_mode_probs[0]);
    try bool_writer_flush(writer);
}

fn test_coeff_prob_offset(block_type: usize, position: usize, context: byte) !usize {
    const band: byte = try coefficient_band(position);
    return ((((block_type * (8 as usize)) + (band as usize)) * (3 as usize)) + (context as usize)) * (11 as usize);
}

fn write_eob_token(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = try test_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset]);
}

fn write_one_token_then_eob(writer: &BoolWriter, coeff_probs: &byte, block_type: usize, position: usize, context: byte) !void {
    const offset: usize = try test_coeff_prob_offset(block_type, position, context);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset]);
    try bool_writer_write(writer, 1 as u8, coeff_probs[offset + 1]);
    try bool_writer_write(writer, 0 as u8, coeff_probs[offset + 2]);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_eob_token(writer, coeff_probs, block_type, position + 1, 1 as byte);
}

fn write_key_frame_tokens_with_u_dc(writer: &BoolWriter, probs: &Vp8Probs) !void {
    try write_eob_token(writer, probs.coeff_probs, 1, 0, 0 as byte);

    var block: usize = 0;
    while block < 16 {
        try write_eob_token(writer, probs.coeff_probs, 0, 1, 0 as byte);
        block = block + 1;
    }

    try write_one_token_then_eob(writer, probs.coeff_probs, 2, 0, 0 as byte);
    try write_eob_token(writer, probs.coeff_probs, 2, 0, 1 as byte);
    try write_eob_token(writer, probs.coeff_probs, 2, 0, 1 as byte);
    try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);

    block = 0;
    while block < 4 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn write_all_eob_tokens(writer: &BoolWriter, probs: &Vp8Probs) !void {
    var block: usize = 0;
    while block < 16 {
        try write_eob_token(writer, probs.coeff_probs, 0, 0, 0 as byte);
        block = block + 1;
    }

    block = 0;
    while block < 8 {
        try write_eob_token(writer, probs.coeff_probs, 2, 0, 0 as byte);
        block = block + 1;
    }

    try bool_writer_flush(writer);
}

fn make_16x16_key_frame(first_partition: &byte, token_partition: &byte, token_partition_len: usize, frame: &byte) void {
    const first_partition_size: u32 = (7 + 256) as u32;
    const tag: u32 = (0 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | (first_partition_size << 5);
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;
    frame[3] = 0x9d as byte;
    frame[4] = 0x01 as byte;
    frame[5] = 0x2a as byte;
    frame[6] = 16 as byte;
    frame[7] = 0 as byte;
    frame[8] = 16 as byte;
    frame[9] = 0 as byte;

    var index: usize = 0;
    while index < 256 {
        frame[10 + index] = first_partition[index];
        index = index + 1;
    }
    index = 0;
    while index < token_partition_len {
        frame[266 + index] = token_partition[index];
        index = index + 1;
    }
}

fn make_16x16_inter_frame(first_partition: &byte, first_partition_len: usize, token_partition: &byte, token_partition_len: usize, frame: &byte) void {
    const tag: u32 = (1 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | ((first_partition_len as u32) << 5);
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;

    var index: usize = 0;
    while index < first_partition_len {
        frame[3 + index] = first_partition[index];
        index = index + 1;
    }
    index = 0;
    while index < token_partition_len {
        frame[3 + first_partition_len + index] = token_partition[index];
        index = index + 1;
    }
}

fn write_minimal_inter_first_partition(writer: &BoolWriter) !void {
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 1 as u8);
    try write_literal(writer, 0, 6 as u8);
    try write_literal(writer, 0, 3 as u8);
    try write_literal(writer, 0, 7 as u8);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try bool_writer_write(writer, 0 as u8, 128 as byte);
    try write_literal(writer, 0, 2 as u8);

    var index: usize = 0;
    while index < 1056 {
        try bool_writer_write(writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    index = 0;
    while index < 38 {
        try bool_writer_write(writer, 0 as u8, vp8_mv_update_probability(index));
        index = index + 1;
    }

    try bool_writer_write(writer, 1 as u8, 145 as byte);
    try bool_writer_write(writer, 0 as u8, 156 as byte);
    try bool_writer_write(writer, 0 as u8, 2 as byte);
    try bool_writer_flush(writer);
}

fn write_vertical_filter_window(data: &byte, stride: usize, row: usize, edge_col: usize) void {
    const base: usize = row * stride;
    data[base + edge_col - 4] = 90 as byte;
    data[base + edge_col - 3] = 100 as byte;
    data[base + edge_col - 2] = 110 as byte;
    data[base + edge_col - 1] = 120 as byte;
    data[base + edge_col] = 125 as byte;
    data[base + edge_col + 1] = 130 as byte;
    data[base + edge_col + 2] = 140 as byte;
    data[base + edge_col + 3] = 150 as byte;
}

fn write_horizontal_filter_window(data: &byte, stride: usize, col: usize, edge_row: usize) void {
    data[((edge_row - 4) * stride) + col] = 90 as byte;
    data[((edge_row - 3) * stride) + col] = 100 as byte;
    data[((edge_row - 2) * stride) + col] = 110 as byte;
    data[((edge_row - 1) * stride) + col] = 120 as byte;
    data[(edge_row * stride) + col] = 125 as byte;
    data[((edge_row + 1) * stride) + col] = 130 as byte;
    data[((edge_row + 2) * stride) + col] = 140 as byte;
    data[((edge_row + 3) * stride) + col] = 150 as byte;
}

test "Decoder.decode_frame wires header mode token readers and scalar kernel state" {
    var compressed: [byte: 256] = [];
    var writer: BoolWriter = make_bool_writer(&compressed[0] as &byte, 256);
    try write_minimal_key_frame_partition(&writer);

    const first_partition_size: u32 = (7 + 256) as u32;
    const tag: u32 = (0 as u32) | (0 as u32 << 1) | (1 as u32 << 4) | (first_partition_size << 5);
    var frame: [byte: 268] = [];
    frame[0] = (tag & (0xff as u32)) as byte;
    frame[1] = ((tag >> 8) & (0xff as u32)) as byte;
    frame[2] = ((tag >> 16) & (0xff as u32)) as byte;
    frame[3] = 0x9d as byte;
    frame[4] = 0x01 as byte;
    frame[5] = 0x2a as byte;
    frame[6] = 16 as byte;
    frame[7] = 0 as byte;
    frame[8] = 16 as byte;
    frame[9] = 0 as byte;

    var index: usize = 0;
    while index < 256 {
        frame[10 + index] = compressed[index];
        index = index + 1;
    }
    frame[268 - 2] = 0 as byte;
    frame[268 - 1] = 0 as byte;

    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 4096);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);

    const result: DecoderFrameResult = try decoder_decode_frame(&decoder, &frame[0] as &byte, 268);
    const header: Vp8FrameHeader = result.header;
    try assert_eq_i32(header.width as i32, 16);
    try assert_eq_i32(header.height as i32, 16);
    try assert_eq_i32(result.token_partition_count as i32, 1);
    try assert_eq_i32(result.macroblock_count as i32, 1);
    try assert_eq_i32(result.parsed_token_partition_count as i32, 1);
    try assert_eq_i32(result.scalar_kernel_border_extended as i32, 1);
    try assert_eq_i32(context.mb_info.y_mode[0] as i32, 0);
    try assert_eq_i32(context.mb_info.uv_mode[0] as i32, 0);

    const current: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    try assert_eq_i32(current.y.plane.origin[0] as i32, 128);
    try assert_eq_i32(current.y.plane.origin[15] as i32, 128);
    try assert_eq_i32(current.y.plane.origin[15 * current.y.plane.stride] as i32, 128);
    try assert_eq_i32(current.u.plane.origin[0] as i32, 128);
    try assert_eq_i32(current.v.plane.origin[0] as i32, 128);
}

test "key frame decode applies token residuals into current frame" {
    var first_partition: [byte: 256] = [];
    var first_writer: BoolWriter = make_bool_writer(&first_partition[0] as &byte, 256);
    try write_minimal_key_frame_partition(&first_writer);

    const probs: Vp8Probs = vp8_default_probs();
    var token_partition: [byte: 64] = [];
    var token_writer: BoolWriter = make_bool_writer(&token_partition[0] as &byte, 64);
    try write_key_frame_tokens_with_u_dc(&token_writer, &probs);

    var frame: [byte: 330] = [];
    make_16x16_key_frame(&first_partition[0] as &byte, &token_partition[0] as &byte, bool_writer_byte_count(&token_writer), &frame[0] as &byte);

    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 4096);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);

    _ = try decoder_decode_frame(&decoder, &frame[0] as &byte, 266 + bool_writer_byte_count(&token_writer));

    const current: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    try assert_eq_i32(current.y.plane.origin[0] as i32, 128);
    try assert_eq_i32(current.u.plane.origin[0] as i32, 129);
    try assert_eq_i32(current.u.plane.origin[3] as i32, 129);
    try assert_eq_i32(current.u.plane.origin[4] as i32, 128);
    try assert_eq_i32(current.v.plane.origin[0] as i32, 128);
}

test "inter frame decode copies last reference for zero motion macroblock" {
    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 4096);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);

    const current_before_refresh: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    current_before_refresh.y.plane.origin[0] = 41 as byte;
    current_before_refresh.y.plane.origin[15] = 42 as byte;
    current_before_refresh.y.plane.origin[15 * current_before_refresh.y.plane.stride] = 43 as byte;
    current_before_refresh.u.plane.origin[0] = 91 as byte;
    current_before_refresh.v.plane.origin[0] = 111 as byte;
    try frame_pool_refresh_references(&context.frame_pool, true, false, false);

    const probs: Vp8Probs = vp8_default_probs();
    var first_partition: [byte: 256] = [];
    var first_writer: BoolWriter = make_bool_writer(&first_partition[0] as &byte, 256);
    try write_minimal_inter_first_partition(&first_writer);

    var token_partition: [byte: 64] = [];
    var token_writer: BoolWriter = make_bool_writer(&token_partition[0] as &byte, 64);
    try write_all_eob_tokens(&token_writer, &probs);

    var frame: [byte: 323] = [];
    make_16x16_inter_frame(&first_partition[0] as &byte, 256, &token_partition[0] as &byte, bool_writer_byte_count(&token_writer) + 8, &frame[0] as &byte);

    const result: DecoderFrameResult = try decoder_decode_frame(&decoder, &frame[0] as &byte, 3 + 256 + bool_writer_byte_count(&token_writer) + 8);
    try assert_eq_i32(result.header.frame_type as i32, 1);
    try assert_eq_i32(context.mb_info.ref_frame[0] as i32, 1);
    try assert_eq_i32(context.mb_info.mv_x[0] as i32, 0);
    try assert_eq_i32(context.mb_info.mv_y[0] as i32, 0);

    const current: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    try assert_eq_i32(current.y.plane.origin[0] as i32, 41);
    try assert_eq_i32(current.y.plane.origin[15] as i32, 42);
    try assert_eq_i32(current.y.plane.origin[15 * current.y.plane.stride] as i32, 43);
    try assert_eq_i32(current.u.plane.origin[0] as i32, 91);
    try assert_eq_i32(current.v.plane.origin[0] as i32, 111);
}

test "single-thread token dequant transform reconstruct path updates one 4x4 block" {
    var encoded: [byte: 32] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 32);
    var probs: [byte: 11] = [ 10, 20, 30, 128, 10, 10, 10, 10, 10, 10, 10 ];

    try bool_writer_write(&writer, 1 as u8, probs[0]);
    try bool_writer_write(&writer, 1 as u8, probs[1]);
    try bool_writer_write(&writer, 0 as u8, probs[2]);
    try bool_writer_write(&writer, 0 as u8, probs[3]);
    try bool_writer_write(&writer, 0 as u8, probs[0]);
    try bool_writer_flush(&writer);

    var dst: [byte: 24] = [
        100, 100, 100, 100, 77, 77,
        100, 100, 100, 100, 77, 77,
        100, 100, 100, 100, 77, 77,
        100, 100, 100, 100, 77, 77
    ];
    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 32);

    const summary: CoefficientBlockSummary = try decoder_decode_dequant_reconstruct_4x4(
        &reader,
        &probs[0] as &byte,
        32 as i16,
        7 as i16,
        &dst[0] as &byte,
        6
    );

    try assert_eq_i32(summary.has_coeff as i32, 1);
    try assert_eq_i32(summary.dc_only as i32, 1);
    try assert_eq_i32(summary.coefficient_count as i32, 1);
    try assert_eq_i32(dst[0] as i32, 104);
    try assert_eq_i32(dst[3] as i32, 104);
    try assert_eq_i32(dst[18] as i32, 104);
    try assert_eq_i32(dst[4] as i32, 77);
}

test "row delayed loop filter applies previous rows and flushes final row" {
    var context: DecoderContext = try allocate_decoder_context(32, 32, 32, 32, 4096);
    defer free_decoder_context(&context);
    const current: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    const loop_filter: Vp8LoopFilterHeader = Vp8LoopFilterHeader{
        filter_type: 0,
        level: 20 as u8,
        sharpness: 0 as u8,
        delta_enabled: false,
        delta_update: false,
        ref_delta: [ 0, 0, 0, 0 ],
        mode_delta: [ 0, 0, 0, 0 ]
    };

    write_vertical_filter_window(current.y.plane.origin, current.y.plane.stride, 10, 16);
    write_horizontal_filter_window(current.y.plane.origin, current.y.plane.stride, 10, 16);
    write_vertical_filter_window(current.u.plane.origin, current.u.plane.stride, 6, 8);
    write_horizontal_filter_window(current.v.plane.origin, current.v.plane.stride, 6, 8);

    decoder_apply_row_delayed_loop_filter(current, context.grid.mb_cols, context.grid.mb_rows, &loop_filter, false);

    try assert_eq_i32(current.y.plane.origin[(10 * current.y.plane.stride) + 15] as i32, 119);
    try assert_eq_i32(current.y.plane.origin[(10 * current.y.plane.stride) + 16] as i32, 126);
    try assert_eq_i32(current.y.plane.origin[(15 * current.y.plane.stride) + 10] as i32, 119);
    try assert_eq_i32(current.y.plane.origin[(16 * current.y.plane.stride) + 10] as i32, 126);
    try assert_eq_i32(current.u.plane.origin[(6 * current.u.plane.stride) + 7] as i32, 119);
    try assert_eq_i32(current.u.plane.origin[(6 * current.u.plane.stride) + 8] as i32, 126);
    try assert_eq_i32(current.v.plane.origin[(7 * current.v.plane.stride) + 6] as i32, 119);
    try assert_eq_i32(current.v.plane.origin[(8 * current.v.plane.stride) + 6] as i32, 126);
}

test "row delayed simple loop filter applies only luma edges" {
    var context: DecoderContext = try allocate_decoder_context(32, 32, 32, 32, 4096);
    defer free_decoder_context(&context);
    const current: &FrameBuffer = try frame_pool_get_slot(&context.frame_pool, context.frame_pool.current_slot);
    const loop_filter: Vp8LoopFilterHeader = Vp8LoopFilterHeader{
        filter_type: 1,
        level: 20 as u8,
        sharpness: 0 as u8,
        delta_enabled: false,
        delta_update: false,
        ref_delta: [ 0, 0, 0, 0 ],
        mode_delta: [ 0, 0, 0, 0 ]
    };

    write_vertical_filter_window(current.y.plane.origin, current.y.plane.stride, 10, 16);
    write_horizontal_filter_window(current.y.plane.origin, current.y.plane.stride, 10, 16);
    write_vertical_filter_window(current.u.plane.origin, current.u.plane.stride, 6, 8);
    write_horizontal_filter_window(current.v.plane.origin, current.v.plane.stride, 6, 8);

    decoder_apply_row_delayed_loop_filter(current, context.grid.mb_cols, context.grid.mb_rows, &loop_filter, false);

    try assert_eq_i32(current.y.plane.origin[(10 * current.y.plane.stride) + 15] as i32, 119);
    try assert_eq_i32(current.y.plane.origin[(10 * current.y.plane.stride) + 16] as i32, 126);
    try assert_eq_i32(current.y.plane.origin[(15 * current.y.plane.stride) + 10] as i32, 119);
    try assert_eq_i32(current.y.plane.origin[(16 * current.y.plane.stride) + 10] as i32, 126);
    try assert_eq_i32(current.u.plane.origin[(6 * current.u.plane.stride) + 7] as i32, 120);
    try assert_eq_i32(current.u.plane.origin[(6 * current.u.plane.stride) + 8] as i32, 125);
    try assert_eq_i32(current.v.plane.origin[(7 * current.v.plane.stride) + 6] as i32, 120);
    try assert_eq_i32(current.v.plane.origin[(8 * current.v.plane.stride) + 6] as i32, 125);
}
