    defer decoded_frame_release(&shown.output) catch {};
    try assert_eq_i32(shown.header.show_frame as i32, true as i32);
    try assert_eq_i32(shown.has_output as i32, true as i32);
    try assert_eq_i32(shown.output.view.width as i32, 16);
    try assert_eq_i32(shown.output.view.height as i32, 16);
    try assert_eq_i32(shown.output.view.y.origin[0] as i32, 128);
    try assert_eq_i32(shown.output.view.u.origin[0] as i32, 128);
    try assert_eq_i32(show_context.frame_pool.slot_lease_count0 as i32, 1);

    var hidden_frame: [byte: 330] = [];
