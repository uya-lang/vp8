use std.testing.assert_eq_i32;

use vp8.bitstream.header.Vp8FrameHeader;
use vp8.bitstream.header.Vp8FrameTag;
use vp8.bitstream.header.Vp8KeyFrameSize;
use vp8.bitstream.header.Vp8LoopFilterHeader;
use vp8.bitstream.header.Vp8Probs;
use vp8.bitstream.header.Vp8QuantHeader;
use vp8.bitstream.header.Vp8Segmentation;
use vp8.bitstream.header.parse_key_frame_start_code;
use vp8.bitstream.header.parse_key_frame_size;
use vp8.bitstream.header.parse_vp8_frame_tag;
use vp8.bitstream.header.parse_vp8_frame_tag_checked;

fn dummy_tag() Vp8FrameTag {
    return Vp8FrameTag{
        frame_type: 0,
        version: 0,
        show_frame: false,
        first_partition_size: 0
    };
}

fn dummy_size() Vp8KeyFrameSize {
    return Vp8KeyFrameSize{
        width: 0,
        height: 0,
        horizontal_scale: 0,
        vertical_scale: 0
    };
}

test "define VP8 frame header fields" {
    const header: Vp8FrameHeader = Vp8FrameHeader{
        frame_type: 0,
        version: 0,
        show_frame: true,
        first_partition_size: 292,
        width: 640,
        height: 480,
        horizontal_scale: 0,
        vertical_scale: 0
    };

    try assert_eq_i32(header.frame_type as i32, 0);
    try assert_eq_i32(header.version as i32, 0);
    try assert_eq_i32(header.show_frame as i32, true as i32);
    try assert_eq_i32(header.first_partition_size as i32, 292);
    try assert_eq_i32(header.width as i32, 640);
    try assert_eq_i32(header.height as i32, 480);
    try assert_eq_i32(header.horizontal_scale as i32, 0);
    try assert_eq_i32(header.vertical_scale as i32, 0);
}

test "define VP8 segmentation fields" {
    const segmentation: Vp8Segmentation = Vp8Segmentation{
        enabled: true,
        update_map: true,
        update_data: true,
        absolute_delta: false,
        quantizer_delta: [ 0, 1, -2, 3 ],
        loop_filter_delta: [ 0, -1, 2, -3 ],
        segment_prob: [ 255, 128, 0 ]
    };

    try assert_eq_i32(segmentation.enabled as i32, true as i32);
    try assert_eq_i32(segmentation.update_map as i32, true as i32);
    try assert_eq_i32(segmentation.update_data as i32, true as i32);
    try assert_eq_i32(segmentation.absolute_delta as i32, false as i32);
    try assert_eq_i32(segmentation.quantizer_delta[1] as i32, 1);
    try assert_eq_i32(segmentation.quantizer_delta[2] as i32, -2);
    try assert_eq_i32(segmentation.loop_filter_delta[1] as i32, -1);
    try assert_eq_i32(segmentation.loop_filter_delta[2] as i32, 2);
    try assert_eq_i32(segmentation.segment_prob[0] as i32, 255);
    try assert_eq_i32(segmentation.segment_prob[1] as i32, 128);
    try assert_eq_i32(segmentation.segment_prob[2] as i32, 0);
}

test "define VP8 loop filter header fields" {
    const loop_filter: Vp8LoopFilterHeader = Vp8LoopFilterHeader{
        filter_type: 1,
        level: 16,
        sharpness: 3,
        delta_enabled: true,
        delta_update: true,
        ref_delta: [ 2, -1, 0, 1 ],
        mode_delta: [ 0, -2, 2, 4 ]
    };

    try assert_eq_i32(loop_filter.filter_type as i32, 1);
    try assert_eq_i32(loop_filter.level as i32, 16);
    try assert_eq_i32(loop_filter.sharpness as i32, 3);
    try assert_eq_i32(loop_filter.delta_enabled as i32, true as i32);
    try assert_eq_i32(loop_filter.delta_update as i32, true as i32);
    try assert_eq_i32(loop_filter.ref_delta[0] as i32, 2);
    try assert_eq_i32(loop_filter.ref_delta[1] as i32, -1);
    try assert_eq_i32(loop_filter.ref_delta[3] as i32, 1);
    try assert_eq_i32(loop_filter.mode_delta[1] as i32, -2);
    try assert_eq_i32(loop_filter.mode_delta[2] as i32, 2);
    try assert_eq_i32(loop_filter.mode_delta[3] as i32, 4);
}

test "define VP8 quant header fields" {
    const quant: Vp8QuantHeader = Vp8QuantHeader{
        base_qindex: 20,
        y1_dc_delta: -2,
        y2_dc_delta: 4,
        y2_ac_delta: 6,
        uv_dc_delta: -1,
        uv_ac_delta: 3
    };

    try assert_eq_i32(quant.base_qindex as i32, 20);
    try assert_eq_i32(quant.y1_dc_delta as i32, -2);
    try assert_eq_i32(quant.y2_dc_delta as i32, 4);
    try assert_eq_i32(quant.y2_ac_delta as i32, 6);
    try assert_eq_i32(quant.uv_dc_delta as i32, -1);
    try assert_eq_i32(quant.uv_ac_delta as i32, 3);
}

test "define VP8 probability state fields" {
    var coeff_probs: [byte: 4] = [ 1, 2, 3, 4 ];
    var mv_probs: [byte: 3] = [ 5, 6, 7 ];
    const probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 4,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 3
    };

    try assert_eq_i32(probs.y_mode_probs[0] as i32, 112);
    try assert_eq_i32(probs.y_mode_probs[3] as i32, 37);
    try assert_eq_i32(probs.uv_mode_probs[0] as i32, 162);
    try assert_eq_i32(probs.uv_mode_probs[2] as i32, 204);
    try assert_eq_i32(probs.coeff_prob_count as i32, 4);
    try assert_eq_i32(probs.coeff_probs[2] as i32, 3);
    try assert_eq_i32(probs.mv_prob_count as i32, 3);
    try assert_eq_i32(probs.mv_probs[1] as i32, 6);
}

test "parse VP8 frame tag" {
    var data: [byte: 3] = [ 0x90, 0x24, 0x00 ];
    const tag: Vp8FrameTag = try parse_vp8_frame_tag(&data[0] as &byte, 3);

    try assert_eq_i32(tag.frame_type as i32, 0);
    try assert_eq_i32(tag.version as i32, 0);
    try assert_eq_i32(tag.show_frame as i32, true as i32);
    try assert_eq_i32(tag.first_partition_size as i32, 292);
}

test "reject short VP8 frame tag" {
    var data: [byte: 2] = [ 0x90, 0x24 ];
    var failed: i32 = 0;

    _ = parse_vp8_frame_tag(&data[0] as &byte, 2) catch {
        failed = 1;
        dummy_tag();
    };

    try assert_eq_i32(failed, 1);
}

test "validate VP8 first partition size" {
    var ok_data: [byte: 5] = [ 0x50, 0x00, 0x00, 0xaa, 0xbb ];
    var short_data: [byte: 4] = [ 0x50, 0x00, 0x00, 0xaa ];
    var failed: i32 = 0;

    const ok: Vp8FrameTag = try parse_vp8_frame_tag_checked(&ok_data[0] as &byte, 5);
    _ = parse_vp8_frame_tag_checked(&short_data[0] as &byte, 4) catch {
        failed = 1;
        dummy_tag();
    };

    try assert_eq_i32(ok.first_partition_size as i32, 2);
    try assert_eq_i32(failed, 1);
}

test "fuzz smoke frame tag and partition size" {
    var data: [byte: 12] = [];
    var i: u32 = 0;
    var accepted: i32 = 0;
    var rejected: i32 = 0;

    while i < 512 {
        data[0] = (i & (0xff as u32)) as byte;
        data[1] = (((i * 17) >> 1) & (0xff as u32)) as byte;
        data[2] = (((i * 31) >> 2) & (0xff as u32)) as byte;
        data[3] = 0x9d;
        data[4] = 0x01;
        data[5] = 0x2a;

        const len: usize = ((i % (12 as u32)) + 1) as usize;
        _ = parse_vp8_frame_tag_checked(&data[0] as &byte, len) catch {
            rejected = rejected + 1;
            dummy_tag();
        };
        if len >= 3 {
            _ = parse_vp8_frame_tag(&data[0] as &byte, len) catch {
                dummy_tag();
            };
        }
        accepted = accepted + 1;
        i = i + 1;
    }

    try assert_eq_i32(accepted, 512);
    try assert_eq_i32(rejected > 0, true as i32);
}

test "parse key frame start code" {
    var data: [byte: 6] = [ 0x10, 0x00, 0x00, 0x9d, 0x01, 0x2a ];
    try parse_key_frame_start_code(&data[0] as &byte, 6);
}

test "reject invalid or short key frame start code" {
    var bad: [byte: 6] = [ 0x10, 0x00, 0x00, 0x9d, 0x01, 0x2b ];
    var short_data: [byte: 5] = [ 0x10, 0x00, 0x00, 0x9d, 0x01 ];
    var bad_failed: i32 = 0;
    var short_failed: i32 = 0;

    _ = parse_key_frame_start_code(&bad[0] as &byte, 6) catch {
        bad_failed = 1;
    };
    _ = parse_key_frame_start_code(&short_data[0] as &byte, 5) catch {
        short_failed = 1;
    };

    try assert_eq_i32(bad_failed, 1);
    try assert_eq_i32(short_failed, 1);
}

test "parse key frame width height and scale" {
    var data: [byte: 10] = [
        0x10, 0x00, 0x00,
        0x9d, 0x01, 0x2a,
        0x80, 0x82,
        0xe0, 0x41
    ];

    const size: Vp8KeyFrameSize = try parse_key_frame_size(&data[0] as &byte, 10);
    try assert_eq_i32(size.width as i32, 640);
    try assert_eq_i32(size.height as i32, 480);
    try assert_eq_i32(size.horizontal_scale as i32, 2);
    try assert_eq_i32(size.vertical_scale as i32, 1);
}

test "reject short key frame size" {
    var data: [byte: 9] = [
        0x10, 0x00, 0x00,
        0x9d, 0x01, 0x2a,
        0x80, 0x82,
        0xe0
    ];
    var failed: i32 = 0;

    _ = parse_key_frame_size(&data[0] as &byte, 9) catch {
        failed = 1;
        dummy_size();
    };

    try assert_eq_i32(failed, 1);
}
