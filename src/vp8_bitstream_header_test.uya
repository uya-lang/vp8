    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, bool_writer_byte_count(&writer));
    const config: Vp8KeyFrameColorConfig = try parse_vp8_key_frame_color_config(&reader);

    try assert_eq_i32(config.color_space as i32, 0);
    try assert_eq_i32(config.clamping_type as i32, 1);
}

test "parse refresh entropy and skip coeff headers" {
    var out: [byte: 8] = [];
