    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_literal_for_header(&writer, 0, 8 as u8);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, bool_writer_byte_count(&writer));
    const refresh_entropy: bool = try parse_vp8_refresh_entropy(&reader);
    const skip: Vp8SkipCoeffHeader = try parse_vp8_skip_coeff_header(&reader);

    try assert_eq_i32(refresh_entropy as i32, true as i32);
    try assert_eq_i32(skip.enabled as i32, true as i32);
    try assert_eq_i32(skip.prob_skip_false as i32, 0);
}

test "parse VP8 loop filter type level sharpness and delta updates" {
    var out: [byte: 32] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 32);

    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_literal_for_header(&writer, 19, 6 as u8);
    try write_literal_for_header(&writer, 5, 3 as u8);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_literal_for_header(&writer, 3, 6 as u8);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_literal_for_header(&writer, 2, 6 as u8);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, 32);
    const loop_filter: Vp8LoopFilterHeader = try parse_vp8_loop_filter(&reader);

    try assert_eq_i32(loop_filter.filter_type as i32, 1);
    try assert_eq_i32(loop_filter.level as i32, 19);
    try assert_eq_i32(loop_filter.sharpness as i32, 5);
    try assert_eq_i32(loop_filter.delta_enabled as i32, true as i32);
    try assert_eq_i32(loop_filter.delta_update as i32, true as i32);
    try assert_eq_i32(loop_filter.ref_delta[0] as i32, -3);
    try assert_eq_i32(loop_filter.ref_delta[1] as i32, -1);
    try assert_eq_i32(loop_filter.ref_delta[2] as i32, -1);
    try assert_eq_i32(loop_filter.ref_delta[3] as i32, 1);
    try assert_eq_i32(loop_filter.mode_delta[0] as i32, 2);
    try assert_eq_i32(loop_filter.mode_delta[1] as i32, -1);
    try assert_eq_i32(loop_filter.mode_delta[2] as i32, 2);
    try assert_eq_i32(loop_filter.mode_delta[3] as i32, 4);
}

test "parse VP8 quant base index and optional deltas" {
    var out: [byte: 32] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 32);

    try write_literal_for_header(&writer, 37, 7 as u8);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_signed_delta_for_header(&writer, -3);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_signed_delta_for_header(&writer, 4);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_signed_delta_for_header(&writer, -2);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, 32);
    const quant: Vp8QuantHeader = try parse_vp8_quant(&reader);

    try assert_eq_i32(quant.base_qindex as i32, 37);
    try assert_eq_i32(quant.y1_dc_delta as i32, -3);
    try assert_eq_i32(quant.y2_dc_delta as i32, 0);
    try assert_eq_i32(quant.y2_ac_delta as i32, 4);
    try assert_eq_i32(quant.uv_dc_delta as i32, -2);
    try assert_eq_i32(quant.uv_ac_delta as i32, 0);
}

test "parse VP8 token partition count code" {
    var out: [byte: 8] = [ 0, 0, 0, 0, 0, 0, 0, 0 ];
