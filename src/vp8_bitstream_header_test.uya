    try assert_eq_i32((try vp8_token_partition_for_row(4, 4 as u8)) as i32, 0);
    try assert_eq_i32((try vp8_token_partition_for_row(7, 4 as u8)) as i32, 3);
    try assert_eq_i32((try vp8_token_partition_for_row(8, 8 as u8)) as i32, 0);
    try assert_eq_i32((try vp8_token_partition_for_row(15, 8 as u8)) as i32, 7);
}

test "parse VP8 frame tag" {
