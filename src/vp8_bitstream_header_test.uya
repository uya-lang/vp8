fn dummy_tag() Vp8FrameTag {
    return Vp8FrameTag{
        frame_type: 0,
        version: 0,
        show_frame: false,
        first_partition_size: 0
    };
}

fn dummy_size() Vp8KeyFrameSize {
    return Vp8KeyFrameSize{
        width: 0,
        height: 0,
        horizontal_scale: 0,
        vertical_scale: 0
    };
}

fn write_literal_for_header(writer: &BoolWriter, value: u32, bit_count: u8) !void {
    var index: i8 = (bit_count as i8) - 1;
    while index >= 0 {
        try bool_writer_write(writer, ((value >> (index as u8)) & (1 as u32)) as u8, 128 as byte);
        index = index - 1;
    }
}

fn write_signed_delta_for_header(writer: &BoolWriter, value: i32) !void {
    if value < 0 {
        try write_literal_for_header(writer, (0 - value) as u32, 4 as u8);
        try bool_writer_write(writer, 1 as u8, 128 as byte);
    } else {
        try write_literal_for_header(writer, value as u32, 4 as u8);
        try bool_writer_write(writer, 0 as u8, 128 as byte);
    }
}

test "define VP8 frame header fields" {
    const header: Vp8FrameHeader = Vp8FrameHeader{
        frame_type: 0,
        version: 0,
        show_frame: true,
        first_partition_size: 292,
        width: 640,
        height: 480,
        horizontal_scale: 0,
        vertical_scale: 0
    };

    try assert_eq_i32(header.frame_type as i32, 0);
    try assert_eq_i32(header.version as i32, 0);
    try assert_eq_i32(header.show_frame as i32, true as i32);
    try assert_eq_i32(header.first_partition_size as i32, 292);
    try assert_eq_i32(header.width as i32, 640);
    try assert_eq_i32(header.height as i32, 480);
    try assert_eq_i32(header.horizontal_scale as i32, 0);
    try assert_eq_i32(header.vertical_scale as i32, 0);
}

test "define VP8 segmentation fields" {
    const segmentation: Vp8Segmentation = Vp8Segmentation{
        enabled: true,
        update_map: true,
        update_data: true,
        absolute_delta: false,
        quantizer_delta: [ 0, 1, -2, 3 ],
        loop_filter_delta: [ 0, -1, 2, -3 ],
        segment_prob: [ 255, 128, 0 ]
    };

    try assert_eq_i32(segmentation.enabled as i32, true as i32);
    try assert_eq_i32(segmentation.update_map as i32, true as i32);
    try assert_eq_i32(segmentation.update_data as i32, true as i32);
    try assert_eq_i32(segmentation.absolute_delta as i32, false as i32);
    try assert_eq_i32(segmentation.quantizer_delta[1] as i32, 1);
    try assert_eq_i32(segmentation.quantizer_delta[2] as i32, -2);
    try assert_eq_i32(segmentation.loop_filter_delta[1] as i32, -1);
    try assert_eq_i32(segmentation.loop_filter_delta[2] as i32, 2);
    try assert_eq_i32(segmentation.segment_prob[0] as i32, 255);
    try assert_eq_i32(segmentation.segment_prob[1] as i32, 128);
    try assert_eq_i32(segmentation.segment_prob[2] as i32, 0);
}

test "define VP8 loop filter header fields" {
    const loop_filter: Vp8LoopFilterHeader = Vp8LoopFilterHeader{
        filter_type: 1,
        level: 16,
        sharpness: 3,
        delta_enabled: true,
        delta_update: true,
        ref_delta: [ 2, -1, 0, 1 ],
        mode_delta: [ 0, -2, 2, 4 ]
    };

    try assert_eq_i32(loop_filter.filter_type as i32, 1);
    try assert_eq_i32(loop_filter.level as i32, 16);
    try assert_eq_i32(loop_filter.sharpness as i32, 3);
    try assert_eq_i32(loop_filter.delta_enabled as i32, true as i32);
    try assert_eq_i32(loop_filter.delta_update as i32, true as i32);
    try assert_eq_i32(loop_filter.ref_delta[0] as i32, 2);
    try assert_eq_i32(loop_filter.ref_delta[1] as i32, -1);
    try assert_eq_i32(loop_filter.ref_delta[3] as i32, 1);
    try assert_eq_i32(loop_filter.mode_delta[1] as i32, -2);
    try assert_eq_i32(loop_filter.mode_delta[2] as i32, 2);
    try assert_eq_i32(loop_filter.mode_delta[3] as i32, 4);
}

test "define VP8 quant header fields" {
    const quant: Vp8QuantHeader = Vp8QuantHeader{
        base_qindex: 20,
        y1_dc_delta: -2,
        y2_dc_delta: 4,
        y2_ac_delta: 6,
        uv_dc_delta: -1,
        uv_ac_delta: 3
    };

    try assert_eq_i32(quant.base_qindex as i32, 20);
    try assert_eq_i32(quant.y1_dc_delta as i32, -2);
    try assert_eq_i32(quant.y2_dc_delta as i32, 4);
    try assert_eq_i32(quant.y2_ac_delta as i32, 6);
    try assert_eq_i32(quant.uv_dc_delta as i32, -1);
    try assert_eq_i32(quant.uv_ac_delta as i32, 3);
}

test "define VP8 probability state fields" {
    var coeff_probs: [byte: 4] = [ 1, 2, 3, 4 ];
    var mv_probs: [byte: 3] = [ 5, 6, 7 ];
    const probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 4,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 3
    };

    try assert_eq_i32(probs.y_mode_probs[0] as i32, 112);
    try assert_eq_i32(probs.y_mode_probs[3] as i32, 37);
    try assert_eq_i32(probs.uv_mode_probs[0] as i32, 162);
    try assert_eq_i32(probs.uv_mode_probs[2] as i32, 204);
    try assert_eq_i32(probs.coeff_prob_count as i32, 4);
    try assert_eq_i32(probs.coeff_probs[2] as i32, 3);
    try assert_eq_i32(probs.mv_prob_count as i32, 3);
    try assert_eq_i32(probs.mv_probs[1] as i32, 6);
}

test "VP8 default probability state matches spec tables" {
    const probs: Vp8Probs = vp8_default_probs();

    try assert_eq_i32(probs.y_mode_probs[0] as i32, 112);
    try assert_eq_i32(probs.y_mode_probs[1] as i32, 86);
    try assert_eq_i32(probs.y_mode_probs[2] as i32, 140);
    try assert_eq_i32(probs.y_mode_probs[3] as i32, 37);
    try assert_eq_i32(probs.uv_mode_probs[0] as i32, 162);
    try assert_eq_i32(probs.uv_mode_probs[1] as i32, 101);
    try assert_eq_i32(probs.uv_mode_probs[2] as i32, 204);
    try assert_eq_i32(probs.coeff_prob_count as i32, 1056);
    try assert_eq_i32(probs.coeff_probs[0] as i32, 128);
    try assert_eq_i32(probs.coeff_probs[33] as i32, 253);
    try assert_eq_i32(probs.coeff_probs[264] as i32, 198);
    try assert_eq_i32(probs.coeff_probs[527] as i32, 128);
    try assert_eq_i32(probs.coeff_probs[1055] as i32, 128);
    try assert_eq_i32(probs.mv_prob_count as i32, 38);
    try assert_eq_i32(probs.mv_probs[0] as i32, 162);
    try assert_eq_i32(probs.mv_probs[18] as i32, 254);
    try assert_eq_i32(probs.mv_probs[19] as i32, 164);
    try assert_eq_i32(probs.mv_probs[37] as i32, 254);
}

test "VP8 coefficient update probability table exposes spec values" {
    try assert_eq_i32(vp8_coeff_update_probability(0) as i32, 255);
    try assert_eq_i32(vp8_coeff_update_probability(33) as i32, 176);
    try assert_eq_i32(vp8_coeff_update_probability(264) as i32, 217);
    try assert_eq_i32(vp8_coeff_update_probability(527) as i32, 255);
    try assert_eq_i32(vp8_coeff_update_probability(1055) as i32, 255);
}

test "parse VP8 coefficient probability updates into caller state" {
    var out: [byte: 256] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 256);
    var index: usize = 0;

    while index < 1056 {
        if index == 33 {
            try bool_writer_write(&writer, 1 as u8, vp8_coeff_update_probability(index));
            try write_literal_for_header(&writer, 77, 8 as u8);
        } else {
            try bool_writer_write(&writer, 0 as u8, vp8_coeff_update_probability(index));
        }
        index = index + 1;
    }
    try bool_writer_flush(&writer);

    const defaults: Vp8Probs = vp8_default_probs();
    var coeff_probs: [byte: 1056] = [];
    var mv_probs: [byte: 38] = [];
    var copy_index: usize = 0;
    while copy_index < 1056 {
        coeff_probs[copy_index] = defaults.coeff_probs[copy_index];
        copy_index = copy_index + 1;
    }
    copy_index = 0;
    while copy_index < 38 {
        mv_probs[copy_index] = defaults.mv_probs[copy_index];
        copy_index = copy_index + 1;
    }
    var probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 1056,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 38
    };
    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, 256);
    try parse_vp8_coeff_probability_updates(&reader, &probs);

    try assert_eq_i32(probs.coeff_probs[0] as i32, 128);
    try assert_eq_i32(probs.coeff_probs[33] as i32, 77);
    try assert_eq_i32(probs.coeff_probs[34] as i32, 136);
}

test "VP8 MV update probability table exposes spec values" {
    try assert_eq_i32(vp8_mv_update_probability(0) as i32, 237);
    try assert_eq_i32(vp8_mv_update_probability(18) as i32, 254);
    try assert_eq_i32(vp8_mv_update_probability(19) as i32, 231);
    try assert_eq_i32(vp8_mv_update_probability(37) as i32, 254);
}

test "parse VP8 MV probability updates into caller state" {
    var out: [byte: 32] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 32);
    var index: usize = 0;

    while index < 38 {
        if index == 2 {
            try bool_writer_write(&writer, 1 as u8, vp8_mv_update_probability(index));
            try write_literal_for_header(&writer, 99, 7 as u8);
        } else {
            try bool_writer_write(&writer, 0 as u8, vp8_mv_update_probability(index));
        }
        index = index + 1;
    }
    try bool_writer_flush(&writer);

    const defaults: Vp8Probs = vp8_default_probs();
    var coeff_probs: [byte: 1056] = [];
    var mv_probs: [byte: 38] = [];
    var copy_index: usize = 0;
    while copy_index < 1056 {
        coeff_probs[copy_index] = defaults.coeff_probs[copy_index];
        copy_index = copy_index + 1;
    }
    copy_index = 0;
    while copy_index < 38 {
        mv_probs[copy_index] = defaults.mv_probs[copy_index];
        copy_index = copy_index + 1;
    }
    var probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 1056,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 38
    };
    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, 32);
    try parse_vp8_mv_probability_updates(&reader, &probs);

    try assert_eq_i32(probs.mv_probs[0] as i32, 162);
    try assert_eq_i32(probs.mv_probs[2] as i32, 99);
    try assert_eq_i32(probs.mv_probs[3] as i32, 146);
}

test "key frame reset restores caller probability state to VP8 defaults" {
    var coeff_probs: [byte: 1056] = [];
    var mv_probs: [byte: 38] = [];
    var index: usize = 0;

    while index < 1056 {
        coeff_probs[index] = 1 as byte;
        index = index + 1;
    }
    index = 0;
    while index < 38 {
        mv_probs[index] = 1 as byte;
        index = index + 1;
    }

    var probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 1, 1, 1, 1 ],
        uv_mode_probs: [ 1, 1, 1 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 1056,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 38
    };

    reset_vp8_key_frame_probs(&probs);

    try assert_eq_i32(probs.y_mode_probs[0] as i32, 112);
    try assert_eq_i32(probs.y_mode_probs[3] as i32, 37);
    try assert_eq_i32(probs.uv_mode_probs[0] as i32, 162);
    try assert_eq_i32(probs.uv_mode_probs[2] as i32, 204);
    try assert_eq_i32(probs.coeff_probs[0] as i32, 128);
    try assert_eq_i32(probs.coeff_probs[33] as i32, 253);
    try assert_eq_i32(probs.coeff_probs[1055] as i32, 128);
    try assert_eq_i32(probs.mv_probs[0] as i32, 162);
    try assert_eq_i32(probs.mv_probs[37] as i32, 254);
}

test "inter frame probability updates inherit existing state and apply deltas" {
    var out: [byte: 256] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 256);
    var index: usize = 0;

    while index < 1056 {
        if index == 33 {
            try bool_writer_write(&writer, 1 as u8, vp8_coeff_update_probability(index));
            try write_literal_for_header(&writer, 88, 8 as u8);
        } else {
            try bool_writer_write(&writer, 0 as u8, vp8_coeff_update_probability(index));
        }
        index = index + 1;
    }
    index = 0;
    while index < 38 {
        try bool_writer_write(&writer, 0 as u8, vp8_mv_update_probability(index));
        index = index + 1;
    }
    try bool_writer_flush(&writer);

    const defaults: Vp8Probs = vp8_default_probs();
    var coeff_probs: [byte: 1056] = [];
    var mv_probs: [byte: 38] = [];
    var copy_index: usize = 0;
    while copy_index < 1056 {
        coeff_probs[copy_index] = defaults.coeff_probs[copy_index];
        copy_index = copy_index + 1;
    }
    copy_index = 0;
    while copy_index < 38 {
        mv_probs[copy_index] = defaults.mv_probs[copy_index];
        copy_index = copy_index + 1;
    }
    coeff_probs[33] = 77 as byte;
    coeff_probs[34] = 66 as byte;

    var probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 1056,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 38
    };
    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, 256);
    try parse_vp8_frame_probability_updates(&reader, &probs, false);

    try assert_eq_i32(probs.coeff_probs[33] as i32, 88);
    try assert_eq_i32(probs.coeff_probs[34] as i32, 66);
    try assert_eq_i32(probs.mv_probs[2] as i32, 225);
}

test "key frame probability updates do not read motion vector updates" {
    var out: [byte: 256] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 256);
    var index: usize = 0;

    while index < 1056 {
        try bool_writer_write(&writer, 0 as u8, vp8_coeff_update_probability(index));
        index = index + 1;
    }
    try bool_writer_flush(&writer);

    var coeff_probs: [byte: 1056] = [];
    var mv_probs: [byte: 38] = [];
    index = 0;
    while index < 1056 {
        coeff_probs[index] = 1 as byte;
        index = index + 1;
    }
    index = 0;
    while index < 38 {
        mv_probs[index] = 1 as byte;
        index = index + 1;
    }

    var probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 1, 1, 1, 1 ],
        uv_mode_probs: [ 1, 1, 1 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 1056,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 38
    };
    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, bool_writer_byte_count(&writer));
    try parse_vp8_frame_probability_updates(&reader, &probs, true);

    try assert_eq_i32(probs.coeff_probs[0] as i32, 128);
    try assert_eq_i32(probs.mv_probs[0] as i32, 162);
    try assert_eq_i32(probs.mv_probs[37] as i32, 254);
    try assert_eq_i32(bool_reader_bit_offset(&reader) as i32, 1056);
}

test "bad probability update reports exact reader partition and byte offset" {
    var data: [byte: 2] = [ 0x00, 0x00 ];
    var reader: BoolReader = try make_bool_reader_for_partition(&data[0] as &byte, 2, 7);
    const defaults: Vp8Probs = vp8_default_probs();
    var coeff_probs: [byte: 1056] = [];
    var mv_probs: [byte: 38] = [];
    var copy_index: usize = 0;
    while copy_index < 1056 {
        coeff_probs[copy_index] = defaults.coeff_probs[copy_index];
        copy_index = copy_index + 1;
    }
    copy_index = 0;
    while copy_index < 38 {
        mv_probs[copy_index] = defaults.mv_probs[copy_index];
        copy_index = copy_index + 1;
    }
    var probs: Vp8Probs = Vp8Probs{
        y_mode_probs: [ 112, 86, 140, 37 ],
        uv_mode_probs: [ 162, 101, 204 ],
        coeff_probs: &coeff_probs[0] as &byte,
        coeff_prob_count: 1056,
        mv_probs: &mv_probs[0] as &byte,
        mv_prob_count: 38
    };
    var failed: i32 = 0;

    _ = parse_vp8_frame_probability_updates(&reader, &probs, false) catch {
        failed = 1;
    };

    try assert_eq_i32(failed, 1);
    try assert_eq_i32(bool_reader_error_partition_id(&reader), 7);
    try assert_eq_i32(bool_reader_error_byte_offset(&reader) as i32, 2);
}

test "parse VP8 segmentation enabled update data and map probabilities" {
    var out: [byte: 32] = [];
    var writer: BoolWriter = make_bool_writer(&out[0] as &byte, 32);

    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 1 as u8, 128 as byte);
    try write_literal_for_header(&writer, 200, 8 as u8);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_write(&writer, 0 as u8, 128 as byte);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&out[0] as &byte, 32);
    const segmentation: Vp8Segmentation = try parse_vp8_segmentation(&reader);

    try assert_eq_i32(segmentation.enabled as i32, true as i32);
    try assert_eq_i32(segmentation.update_map as i32, true as i32);
    try assert_eq_i32(segmentation.update_data as i32, false as i32);
    try assert_eq_i32(segmentation.absolute_delta as i32, false as i32);
    try assert_eq_i32(segmentation.quantizer_delta[0] as i32, 0);
    try assert_eq_i32(segmentation.quantizer_delta[1] as i32, 0);
    try assert_eq_i32(segmentation.quantizer_delta[2] as i32, 0);
    try assert_eq_i32(segmentation.quantizer_delta[3] as i32, 0);
    try assert_eq_i32(segmentation.loop_filter_delta[0] as i32, 0);
    try assert_eq_i32(segmentation.loop_filter_delta[1] as i32, 0);
    try assert_eq_i32(segmentation.loop_filter_delta[2] as i32, 0);
    try assert_eq_i32(segmentation.loop_filter_delta[3] as i32, 0);
    try assert_eq_i32(segmentation.segment_prob[0] as i32, 200);
    try assert_eq_i32(segmentation.segment_prob[1] as i32, 255);
    try assert_eq_i32(segmentation.segment_prob[2] as i32, 255);
}

test "parse key frame color space and clamping bits" {
