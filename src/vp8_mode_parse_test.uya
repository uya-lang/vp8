use vp8.common.mb_info.free_macroblock_info_arrays;
use vp8.common.mb_info.macroblock_info_get;

fn write_bits(writer: &BoolWriter, bits: &u8, count: usize, probs: &byte) !void {
    var index: usize = 0;
    while index < count {
        try bool_writer_write(writer, bits[index], probs[index]);
        index = index + 1;
    }
}

fn parse_y_mode_from_bits(bits: &u8, count: usize) !byte {
    var encoded: [byte: 16] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 16);
    const probs: Vp8Probs = vp8_default_probs();
    try write_bits(&writer, bits, count, &probs.y_mode_probs[0] as &byte);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 16);
    return try parse_key_frame_y_mode(&reader, &probs);
}

fn parse_uv_mode_from_bits(bits: &u8, count: usize) !byte {
    var encoded: [byte: 16] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 16);
    const probs: Vp8Probs = vp8_default_probs();
    try write_bits(&writer, bits, count, &probs.uv_mode_probs[0] as &byte);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 16);
    return try parse_key_frame_uv_mode(&reader, &probs);
}

fn write_b_mode_bits(writer: &BoolWriter, bits: &u8, prob_indices: &u8, count: usize, above: byte, left: byte) !void {
    var index: usize = 0;
    while index < count {
        const prob: byte = try vp8_kf_bmode_prob(above, left, prob_indices[index] as usize);
        try bool_writer_write(writer, bits[index], prob);
        index = index + 1;
    }
}

fn parse_b_mode_from_bits(bits: &u8, prob_indices: &u8, count: usize, above: byte, left: byte) !byte {
    var encoded: [byte: 16] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 16);
    try write_b_mode_bits(&writer, bits, prob_indices, count, above, left);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 16);
    return try parse_key_frame_luma_4x4_block_mode(&reader, above, left);
}

fn parse_inter_intra_flag_from_bit(bit: u8, prob_inter: byte) !bool {
    var encoded: [byte: 8] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 8);
    try bool_writer_write(&writer, bit, prob_inter);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 8);
    return try parse_inter_intra_flag(&reader, prob_inter);
}

fn parse_inter_reference_frame_from_bits(bits: &u8, count: usize, prob_last: byte, prob_gf: byte) !byte {
    var encoded: [byte: 8] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 8);
    try bool_writer_write(&writer, bits[0], prob_last);
    if count > 1 {
        try bool_writer_write(&writer, bits[1], prob_gf);
    }
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 8);
    return try parse_inter_reference_frame(&reader, prob_last, prob_gf);
}

fn parse_skip_flag_from_bit(bit: u8, skip_enabled: bool, prob_skip_false: byte) !bool {
    var encoded: [byte: 8] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 8);
    try bool_writer_write(&writer, bit, prob_skip_false);
    try bool_writer_flush(&writer);

    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 8);
    return try parse_skip_coefficient_flag(&reader, skip_enabled, prob_skip_false);
}

fn write_mv_component(writer: &BoolWriter, value: i16, probs: &byte) !void {
    var magnitude: i16 = value;
    if magnitude < 0 {
        magnitude = (0 - magnitude) as i16;
    }

    if magnitude < 8 {
        try bool_writer_write(writer, 0 as u8, probs[0]);
        var bit: u8 = 0;
        if magnitude == 4 || magnitude == 5 || magnitude == 6 || magnitude == 7 {
            bit = 1;
        }
        try bool_writer_write(writer, bit, probs[2]);
        if bit == 0 {
            var bit2: u8 = 0;
            if magnitude == 2 || magnitude == 3 {
                bit2 = 1;
            }
            try bool_writer_write(writer, bit2, probs[3]);
            if bit2 == 0 {
                var bit1: u8 = 0;
                if magnitude == 1 {
                    bit1 = 1;
                }
                try bool_writer_write(writer, bit1, probs[4]);
            } else {
                var bit3: u8 = 0;
                if magnitude == 3 {
                    bit3 = 1;
                }
                try bool_writer_write(writer, bit3, probs[5]);
            }
        } else {
            var bit6: u8 = 0;
            if magnitude == 6 || magnitude == 7 {
                bit6 = 1;
            }
            try bool_writer_write(writer, bit6, probs[6]);
            if bit6 == 0 {
                var bit5: u8 = 0;
                if magnitude == 5 {
                    bit5 = 1;
                }
                try bool_writer_write(writer, bit5, probs[7]);
            } else {
                var bit7: u8 = 0;
                if magnitude == 7 {
                    bit7 = 1;
                }
                try bool_writer_write(writer, bit7, probs[8]);
            }
        }
    } else {
        try bool_writer_write(writer, 1 as u8, probs[0]);
        try bool_writer_write(writer, ((magnitude >> 3) & 1) as u8, 128 as byte);
        try bool_writer_write(writer, ((magnitude >> 2) & 1) as u8, 128 as byte);
        try bool_writer_write(writer, ((magnitude >> 1) & 1) as u8, 128 as byte);
        try bool_writer_write(writer, magnitude as u8 & (1 as u8), 128 as byte);
        try bool_writer_write(writer, ((magnitude >> 4) & 1) as u8, probs[9]);
        try bool_writer_write(writer, ((magnitude >> 5) & 1) as u8, probs[10]);
        try bool_writer_write(writer, ((magnitude >> 6) & 1) as u8, probs[11]);
        try bool_writer_write(writer, ((magnitude >> 7) & 1) as u8, probs[12]);
    }

    if magnitude != 0 {
        var sign: u8 = 0;
        if value < 0 {
            sign = 1;
        }
        try bool_writer_write(writer, sign, probs[1]);
    }
}

fn parse_mv_from_script(mode_bits: &u8, mode_count: usize, new_y: i16, new_x: i16, write_new_mv: bool) !Vp8MotionVector {
    var encoded: [byte: 64] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 64);
    const probs: Vp8Probs = vp8_default_probs();
    const mode_probs: [byte: 4] = [ 2, 173, 34, 173 ];
    try write_bits(&writer, mode_bits, mode_count, &mode_probs[0] as &byte);
    if write_new_mv {
        try write_mv_component(&writer, new_y, &probs.mv_probs[0] as &byte);
        try write_mv_component(&writer, new_x, &probs.mv_probs[19] as &byte);
    }
    try bool_writer_flush(&writer);

    const nearest: Vp8MotionVector = Vp8MotionVector{ y: 3, x: -4 };
    const near: Vp8MotionVector = Vp8MotionVector{ y: -7, x: 8 };
    const new_base: Vp8MotionVector = Vp8MotionVector{ y: 1, x: -2 };
    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 64);
    return try parse_inter_motion_vector(&reader, &probs, &nearest, &near, &new_base);
}

test "parse key frame macroblock y mode tree" {
    var dc_bits: [u8: 1] = [ 0 ];
    var v_bits: [u8: 2] = [ 1, 0 ];
    var h_bits: [u8: 3] = [ 1, 1, 0 ];
    var tm_bits: [u8: 4] = [ 1, 1, 1, 0 ];
    var b_bits: [u8: 4] = [ 1, 1, 1, 1 ];

    try assert_eq_i32((try parse_y_mode_from_bits(&dc_bits[0] as &u8, 1)) as i32, 0);
    try assert_eq_i32((try parse_y_mode_from_bits(&v_bits[0] as &u8, 2)) as i32, 1);
    try assert_eq_i32((try parse_y_mode_from_bits(&h_bits[0] as &u8, 3)) as i32, 2);
    try assert_eq_i32((try parse_y_mode_from_bits(&tm_bits[0] as &u8, 4)) as i32, 3);
    try assert_eq_i32((try parse_y_mode_from_bits(&b_bits[0] as &u8, 4)) as i32, 4);
}

test "parse key frame macroblock uv mode tree" {
    var dc_bits: [u8: 1] = [ 0 ];
    var v_bits: [u8: 2] = [ 1, 0 ];
    var h_bits: [u8: 3] = [ 1, 1, 0 ];
    var tm_bits: [u8: 3] = [ 1, 1, 1 ];

    try assert_eq_i32((try parse_uv_mode_from_bits(&dc_bits[0] as &u8, 1)) as i32, 0);
    try assert_eq_i32((try parse_uv_mode_from_bits(&v_bits[0] as &u8, 2)) as i32, 1);
    try assert_eq_i32((try parse_uv_mode_from_bits(&h_bits[0] as &u8, 3)) as i32, 2);
    try assert_eq_i32((try parse_uv_mode_from_bits(&tm_bits[0] as &u8, 3)) as i32, 3);
}

test "parse key frame 4x4 luma block mode tree" {
    var dc_bits: [u8: 1] = [ 0 ];
    var dc_probs: [u8: 1] = [ 0 ];
    var tm_bits: [u8: 2] = [ 1, 0 ];
    var tm_probs: [u8: 2] = [ 0, 1 ];
    var ve_bits: [u8: 3] = [ 1, 1, 0 ];
    var ve_probs: [u8: 3] = [ 0, 1, 2 ];
    var he_bits: [u8: 5] = [ 1, 1, 1, 0, 0 ];
    var he_probs: [u8: 5] = [ 0, 1, 2, 3, 4 ];
    var rd_bits: [u8: 6] = [ 1, 1, 1, 0, 1, 0 ];
    var rd_probs: [u8: 6] = [ 0, 1, 2, 3, 4, 5 ];
    var vr_bits: [u8: 6] = [ 1, 1, 1, 0, 1, 1 ];
    var vr_probs: [u8: 6] = [ 0, 1, 2, 3, 4, 5 ];
    var ld_bits: [u8: 5] = [ 1, 1, 1, 1, 0 ];
    var ld_probs: [u8: 5] = [ 0, 1, 2, 3, 6 ];
    var vl_bits: [u8: 6] = [ 1, 1, 1, 1, 1, 0 ];
    var vl_probs: [u8: 6] = [ 0, 1, 2, 3, 6, 7 ];
    var hd_bits: [u8: 7] = [ 1, 1, 1, 1, 1, 1, 0 ];
    var hd_probs: [u8: 7] = [ 0, 1, 2, 3, 6, 7, 8 ];
    var hu_bits: [u8: 7] = [ 1, 1, 1, 1, 1, 1, 1 ];
    var hu_probs: [u8: 7] = [ 0, 1, 2, 3, 6, 7, 8 ];

    try assert_eq_i32((try parse_b_mode_from_bits(&dc_bits[0] as &u8, &dc_probs[0] as &u8, 1, 0 as byte, 0 as byte)) as i32, 0);
    try assert_eq_i32((try parse_b_mode_from_bits(&tm_bits[0] as &u8, &tm_probs[0] as &u8, 2, 0 as byte, 0 as byte)) as i32, 1);
    try assert_eq_i32((try parse_b_mode_from_bits(&ve_bits[0] as &u8, &ve_probs[0] as &u8, 3, 0 as byte, 0 as byte)) as i32, 2);
    try assert_eq_i32((try parse_b_mode_from_bits(&he_bits[0] as &u8, &he_probs[0] as &u8, 5, 0 as byte, 0 as byte)) as i32, 3);
    try assert_eq_i32((try parse_b_mode_from_bits(&rd_bits[0] as &u8, &rd_probs[0] as &u8, 6, 0 as byte, 0 as byte)) as i32, 5);
    try assert_eq_i32((try parse_b_mode_from_bits(&vr_bits[0] as &u8, &vr_probs[0] as &u8, 6, 0 as byte, 0 as byte)) as i32, 6);
    try assert_eq_i32((try parse_b_mode_from_bits(&ld_bits[0] as &u8, &ld_probs[0] as &u8, 5, 0 as byte, 0 as byte)) as i32, 4);
    try assert_eq_i32((try parse_b_mode_from_bits(&vl_bits[0] as &u8, &vl_probs[0] as &u8, 6, 0 as byte, 0 as byte)) as i32, 7);
    try assert_eq_i32((try parse_b_mode_from_bits(&hd_bits[0] as &u8, &hd_probs[0] as &u8, 7, 0 as byte, 0 as byte)) as i32, 8);
    try assert_eq_i32((try parse_b_mode_from_bits(&hu_bits[0] as &u8, &hu_probs[0] as &u8, 7, 0 as byte, 0 as byte)) as i32, 9);
}

test "parse key frame 4x4 luma modes updates above and left contexts" {
    var encoded: [byte: 64] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 64);
    var all_dc_bits: [u8: 1] = [ 0 ];
    var all_dc_probs: [u8: 1] = [ 0 ];
    var above_modes: [byte: 4] = [ 1, 2, 3, 4 ];
    var left_modes: [byte: 4] = [ 5, 6, 7, 8 ];
    var block: usize = 0;
    while block < 16 {
        const by: usize = block / 4;
        const bx: usize = block % (4 as usize);
        var above: byte = 0 as byte;
        var left: byte = 0 as byte;
        if by == 0 {
            above = above_modes[bx];
        }
        if bx == 0 {
            left = left_modes[by];
        }
        try write_b_mode_bits(&writer, &all_dc_bits[0] as &u8, &all_dc_probs[0] as &u8, 1, above, left);
        block = block + 1;
    }
    try bool_writer_flush(&writer);

    var output_modes: [byte: 16] = [];
    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 64);
    try parse_key_frame_luma_4x4_modes(&reader, &above_modes[0] as &byte, &left_modes[0] as &byte, &output_modes[0] as &byte);

    var index: usize = 0;
    while index < 16 {
        try assert_eq_i32(output_modes[index] as i32, 0);
        index = index + 1;
    }
    try assert_eq_i32(above_modes[0] as i32, 0);
    try assert_eq_i32(above_modes[3] as i32, 0);
    try assert_eq_i32(left_modes[0] as i32, 0);
    try assert_eq_i32(left_modes[3] as i32, 0);
}

test "small key frame mode map matches golden macroblock order" {
    var encoded: [byte: 32] = [];
    var writer: BoolWriter = make_bool_writer(&encoded[0] as &byte, 32);
    const probs: Vp8Probs = vp8_default_probs();

    var dc_y_bits: [u8: 1] = [ 0 ];
    var v_y_bits: [u8: 2] = [ 1, 0 ];
    var dc_uv_bits: [u8: 1] = [ 0 ];
    var v_uv_bits: [u8: 2] = [ 1, 0 ];

    try write_bits(&writer, &dc_y_bits[0] as &u8, 1, &probs.y_mode_probs[0] as &byte);
    try write_bits(&writer, &dc_uv_bits[0] as &u8, 1, &probs.uv_mode_probs[0] as &byte);
    try write_bits(&writer, &v_y_bits[0] as &u8, 2, &probs.y_mode_probs[0] as &byte);
    try write_bits(&writer, &v_uv_bits[0] as &u8, 2, &probs.uv_mode_probs[0] as &byte);
    try bool_writer_flush(&writer);

    var grid: MacroblockGrid = try macroblock_grid_for_frame(32, 16);
    var info: MacroblockInfoArrays = try allocate_macroblock_info_arrays(&grid);
    defer free_macroblock_info_arrays(&info);
    var reader: BoolReader = try make_bool_reader(&encoded[0] as &byte, 32);

    try parse_key_frame_mode_map(&reader, &probs, &info);

    const mb00: MacroblockInfoValue = try macroblock_info_get(&info, 0, 0);
    const mb10: MacroblockInfoValue = try macroblock_info_get(&info, 1, 0);

    try assert_eq_i32(mb00.y_mode as i32, 0);
    try assert_eq_i32(mb00.uv_mode as i32, 0);
    try assert_eq_i32(mb10.y_mode as i32, 1);
    try assert_eq_i32(mb10.uv_mode as i32, 1);
}

test "parse inter frame intra inter macroblock flag" {
    const prob_inter: byte = 145 as byte;
    try expect(!(try parse_inter_intra_flag_from_bit(0, prob_inter)));
    try expect(try parse_inter_intra_flag_from_bit(1, prob_inter));
}

test "parse inter reference frame selector" {
    const prob_last: byte = 160 as byte;
    const prob_gf: byte = 170 as byte;
    var last_bits: [u8: 1] = [ 0 ];
    var golden_bits: [u8: 2] = [ 1, 0 ];
    var altref_bits: [u8: 2] = [ 1, 1 ];

    try assert_eq_i32((try parse_inter_reference_frame_from_bits(&last_bits[0] as &u8, 1, prob_last, prob_gf)) as i32, 1);
    try assert_eq_i32((try parse_inter_reference_frame_from_bits(&golden_bits[0] as &u8, 2, prob_last, prob_gf)) as i32, 2);
    try assert_eq_i32((try parse_inter_reference_frame_from_bits(&altref_bits[0] as &u8, 2, prob_last, prob_gf)) as i32, 3);
}

test "parse nearest near zero and new motion vectors" {
    var nearest_bits: [u8: 4] = [ 1, 0, 0, 0 ];
    var near_bits: [u8: 4] = [ 1, 0, 0, 1 ];
    var zero_bits: [u8: 3] = [ 1, 0, 1 ];
    var new_bits: [u8: 2] = [ 1, 1 ];

    const nearest: Vp8MotionVector = try parse_mv_from_script(&nearest_bits[0] as &u8, 4, 0, 0, false);
    try assert_eq_i32(nearest.mode as i32, VP8_INTER_MV_MODE_NEAREST as i32);
    try assert_eq_i32(nearest.y as i32, 3);
    try assert_eq_i32(nearest.x as i32, -4);

    const near: Vp8MotionVector = try parse_mv_from_script(&near_bits[0] as &u8, 4, 0, 0, false);
    try assert_eq_i32(near.mode as i32, VP8_INTER_MV_MODE_NEAR as i32);
    try assert_eq_i32(near.y as i32, -7);
    try assert_eq_i32(near.x as i32, 8);

    const zero: Vp8MotionVector = try parse_mv_from_script(&zero_bits[0] as &u8, 3, 0, 0, false);
    try assert_eq_i32(zero.mode as i32, VP8_INTER_MV_MODE_ZERO as i32);
    try assert_eq_i32(zero.y as i32, 0);
    try assert_eq_i32(zero.x as i32, 0);

    const new_mv: Vp8MotionVector = try parse_mv_from_script(&new_bits[0] as &u8, 2, -5, 12, true);
    try assert_eq_i32(new_mv.mode as i32, VP8_INTER_MV_MODE_NEW as i32);
    try assert_eq_i32(new_mv.y as i32, -4);
    try assert_eq_i32(new_mv.x as i32, 10);
}

test "clamp motion vector to visible reference frame bounds" {
    const mv: Vp8MotionVector = Vp8MotionVector{ y: -200, x: 200, mode: VP8_INTER_MV_MODE_NEW };
    const clamped: Vp8MotionVector = try clamp_inter_motion_vector(&mv, 1, 1, 32, 32, 16, 16);

    try assert_eq_i32(clamped.mode as i32, VP8_INTER_MV_MODE_NEW as i32);
    try assert_eq_i32(clamped.y as i32, -128);
    try assert_eq_i32(clamped.x as i32, 0);
    try expect(try inter_motion_vector_inside_frame(&clamped, 1, 1, 32, 32, 16, 16));

    const out_of_bounds: Vp8MotionVector = Vp8MotionVector{ y: -129, x: 1, mode: VP8_INTER_MV_MODE_NEW };
    try expect(!(try inter_motion_vector_inside_frame(&out_of_bounds, 1, 1, 32, 32, 16, 16)));
}

test "motion vector bounds reject invalid frame and block geometry" {
    const mv: Vp8MotionVector = Vp8MotionVector{ y: 0, x: 0, mode: VP8_INTER_MV_MODE_ZERO };
    _ = clamp_inter_motion_vector(&mv, 0, 0, 15, 16, 16, 16) catch {
        return;
    };
    try expect(false);
}

test "parse skip coefficient flag when frame enables mb no coeff skip" {
    const prob_skip_false: byte = 120 as byte;
    try expect(!(try parse_skip_flag_from_bit(0 as u8, true, prob_skip_false)));
    try expect(try parse_skip_flag_from_bit(1 as u8, true, prob_skip_false));
    try expect(!(try parse_skip_flag_from_bit(1 as u8, false, prob_skip_false)));
}
