test "encoder keyframe IVF API writes a parseable one-frame keyframe stream" {
    var input: [byte: 384] = [];
    var index: usize = 0;
    while index < 256 {
        input[index] = (64 + (((index * 17) % (96 as usize)) as i32)) as byte;
        index = index + 1;
    }
    while index < 384 {
        input[index] = (96 + (((index * 7) % (64 as usize)) as i32)) as byte;
        index = index + 1;
    }

    var out: [byte: 4096] = [];
    const config: EncoderConfig = make_default_encoder_config(16, 16);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 384, 16, 16);

    const written: usize = try encode_keyframe_ivf(&config, &frame, &out[0] as &byte, 4096);

    const ivf: IvfHeader = try parse_ivf_header(&out[0] as &byte, written);
    try assert_eq_i32(ivf.width as i32, 16);
    try assert_eq_i32(ivf.height as i32, 16);
    try assert_eq_i32(ivf.frame_count as i32, 1);

    var iterator: IvfFrameIterator = try make_ivf_frame_iterator(&out[0] as &byte, written, &ivf);
    const ivf_frame: IvfFrame = try ivf_frame_iterator_next(&iterator);
    try assert_eq_i32(ivf_frame.index as i32, 0);
    try assert_eq_i32(ivf_frame.payload.len as i32 > 10, true as i32);
    try assert_eq_i32(ivf_frame_iterator_has_next(&iterator) as i32, false as i32);

    const tag: Vp8FrameTag = try parse_vp8_frame_tag_checked(ivf_frame.payload.data, ivf_frame.payload.len);
    try assert_eq_i32(tag.frame_type as i32, 0);
    try assert_eq_i32(tag.show_frame as i32, true as i32);

    const key_header: Vp8FrameHeader = try parse_vp8_key_frame_header(ivf_frame.payload.data, ivf_frame.payload.len);
    try assert_eq_i32(key_header.width as i32, 16);
    try assert_eq_i32(key_header.height as i32, 16);
    try assert_eq_i32(key_header.first_partition_size as i32 > 0, true as i32);
}

test "UYA decoder decodes encoder keyframe IVF output" {
    var input: [byte: 384] = [];
    var index: usize = 0;
    while index < 256 {
        input[index] = (48 + (((index * 29) % (128 as usize)) as i32)) as byte;
        index = index + 1;
    }
    while index < 384 {
        input[index] = (80 + (((index * 11) % (80 as usize)) as i32)) as byte;
        index = index + 1;
    }

    var out: [byte: 4096] = [];
    const config: EncoderConfig = make_default_encoder_config(16, 16);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 384, 16, 16);
    const written: usize = try encode_keyframe_ivf(&config, &frame, &out[0] as &byte, 4096);

    const ivf: IvfHeader = try parse_ivf_header(&out[0] as &byte, written);
    var iterator: IvfFrameIterator = try make_ivf_frame_iterator(&out[0] as &byte, written, &ivf);
    const ivf_frame: IvfFrame = try ivf_frame_iterator_next(&iterator);

    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 65536);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);
    var result: DecoderFrameResult = try decoder_decode_frame(&decoder, ivf_frame.payload.data, ivf_frame.payload.len);
    defer decoded_frame_release(&result.output) catch {};

    try assert_eq_i32(result.has_output as i32, true as i32);
    try assert_eq_i32(result.header.width as i32, 16);
    try assert_eq_i32(result.header.height as i32, 16);
    try assert_eq_i32(result.macroblock_count as i32, 1);
    try assert_eq_i32(result.output.view.width as i32, 16);
    try assert_eq_i32(result.output.view.height as i32, 16);
    try assert_eq_i32(result.output.view.y.width as i32, 16);
    try assert_eq_i32(result.output.view.y.height as i32, 16);
    try assert_eq_i32(result.output.view.u.width as i32, 8);
    try assert_eq_i32(result.output.view.u.height as i32, 8);
    try assert_eq_i32(result.output.view.v.width as i32, 8);
    try assert_eq_i32(result.output.view.v.height as i32, 8);
    try assert_eq_i32((result.output.view.y.origin != null) as i32, true as i32);
    try assert_eq_i32((result.output.view.u.origin != null) as i32, true as i32);
    try assert_eq_i32((result.output.view.v.origin != null) as i32, true as i32);
}

test "encoder keyframe writes selected non-DC luma 4x4 modes" {
    var input: [byte: 384] = [];
    var row: usize = 0;
    while row < 16 {
        var col: usize = 0;
        while col < 16 {
            input[(row * 16) + col] = (20 + ((((row * 37) + (col * 19) + ((row / 4) * ((col % 5) + 1) * 11)) % (210 as usize)) as i32)) as byte;
            col = col + 1;
        }
        row = row + 1;
    }
    var index: usize = 256;
    while index < 384 {
        input[index] = (96 + (((index * 13) % (64 as usize)) as i32)) as byte;
        index = index + 1;
    }

    var out: [byte: 8192] = [];
    const config: EncoderConfig = make_default_encoder_config(16, 16);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 384, 16, 16);
    const written: usize = try encode_keyframe_ivf(&config, &frame, &out[0] as &byte, 8192);

    const ivf: IvfHeader = try parse_ivf_header(&out[0] as &byte, written);
    var iterator: IvfFrameIterator = try make_ivf_frame_iterator(&out[0] as &byte, written, &ivf);
    const ivf_frame: IvfFrame = try ivf_frame_iterator_next(&iterator);

    var context: DecoderContext = try allocate_decoder_context(16, 16, 32, 32, 65536);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);
    var result: DecoderFrameResult = try decoder_decode_frame(&decoder, ivf_frame.payload.data, ivf_frame.payload.len);
    defer decoded_frame_release(&result.output) catch {};

    var non_dc_count: i32 = 0;
    index = 0;
    while index < 16 {
        if context.mb_info.b_mode[index] != VP8_B_MODE_DC {
            non_dc_count = non_dc_count + 1;
        }
        index = index + 1;
    }

    try assert_eq_i32((non_dc_count > 0) as i32, true as i32);
}

test "encoder speed presets expose measurable work and output differences" {
    var input: [byte: 384] = [];
    var row: usize = 0;
    while row < 16 {
        var col: usize = 0;
        while col < 16 {
            input[(row * 16) + col] = (20 + ((((row * 37) + (col * 19) + ((row / 4) * ((col % 5) + 1) * 11)) % (210 as usize)) as i32)) as byte;
            col = col + 1;
        }
        row = row + 1;
    }
    var index: usize = 256;
    while index < 384 {
        input[index] = (96 + (((index * 13) % (64 as usize)) as i32)) as byte;
        index = index + 1;
    }

    var fastest_out: [byte: 8192] = [];
    var best_out: [byte: 8192] = [];
    var fastest_config: EncoderConfig = make_default_encoder_config(16, 16);
    var best_config: EncoderConfig = make_default_encoder_config(16, 16);
    fastest_config.speed_preset = EncoderSpeedPreset.fastest;
    best_config.speed_preset = EncoderSpeedPreset.best;
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 384, 16, 16);

    const fastest_stats: EncoderKeyframeEncodeStats = try encode_keyframe_ivf_with_stats(&fastest_config, &frame, &fastest_out[0] as &byte, 8192);
    const best_stats: EncoderKeyframeEncodeStats = try encode_keyframe_ivf_with_stats(&best_config, &frame, &best_out[0] as &byte, 8192);

    try assert_eq_i32((fastest_stats.mode_search_work_units < best_stats.mode_search_work_units) as i32, true as i32);
    var differs: bool = fastest_stats.written_len != best_stats.written_len;
    index = 0;
    while !differs && index < fastest_stats.written_len {
        if fastest_out[index] != best_out[index] {
            differs = true;
        }
        index = index + 1;
    }
    try assert_eq_i32(differs as i32, true as i32);
}

test "encoder keyframe can use forced SIMD predictor cost kernels" {
    var input: [byte: 768] = [];
    var index: usize = 0;
    while index < 512 {
        input[index] = (24 + ((((index * 41) + (index / 5) + ((index / 32) * 17)) % (206 as usize)) as i32)) as byte;
        index = index + 1;
    }
    while index < 768 {
        input[index] = (72 + ((((index * 19) + (index / 7)) % (96 as usize)) as i32)) as byte;
        index = index + 1;
    }

    var scalar_out: [byte: 16384] = [];
    var simd_out: [byte: 16384] = [];
    const config: EncoderConfig = make_default_encoder_config(32, 16);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 768, 32, 16);
    const scalar_table: KernelFunctionTable = make_scalar_kernel_table();
    const capabilities: SimdCapabilities = simd_detect_capabilities();
    const simd_table: KernelFunctionTable = make_forced_simd_kernel_table(&capabilities);

    const scalar_stats: EncoderKeyframeEncodeStats = try encode_keyframe_ivf_with_stats_and_kernel_table(&config, &scalar_table, &frame, &scalar_out[0] as &byte, 16384);
    const simd_stats: EncoderKeyframeEncodeStats = try encode_keyframe_ivf_with_stats_and_kernel_table(&config, &simd_table, &frame, &simd_out[0] as &byte, 16384);

    try assert_eq_i32(simd_stats.written_len as i32, scalar_stats.written_len as i32);
    try assert_eq_i32(simd_stats.mode_search_work_units as i32, scalar_stats.mode_search_work_units as i32);
    index = 0;
    while index < scalar_stats.written_len {
        try assert_eq_i32(simd_out[index] as i32, scalar_out[index] as i32);
        index = index + 1;
    }
}

test "encoder keyframe rejects missing predictor cost kernel entry" {
    var input: [byte: 384] = [];
    var out: [byte: 4096] = [];
    const config: EncoderConfig = make_default_encoder_config(16, 16);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 384, 16, 16);
    var table: KernelFunctionTable = make_scalar_kernel_table();
    table.intra4x4_predictor_sad_fn = null as &void;

    var failed: i32 = 0;
    _ = encode_keyframe_ivf_with_stats_and_kernel_table(&config, &table, &frame, &out[0] as &byte, 4096) catch {
        failed = 1;
        EncoderKeyframeEncodeStats{
            written_len: 0,
            mode_search_work_units: 0
        };
    };
    try assert_eq_i32(failed, 1);
}

test "encoder keyframe keeps coefficient probabilities browser-compatible by default" {
    var input: [byte: 1536] = [];
    var out: [byte: 32768] = [];
    const config: EncoderConfig = make_default_encoder_config(16, 64);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 1536, 16, 64);
    const written: usize = try encode_keyframe_ivf(&config, &frame, &out[0] as &byte, 32768);

    const ivf: IvfHeader = try parse_ivf_header(&out[0] as &byte, written);
    var iterator: IvfFrameIterator = try make_ivf_frame_iterator(&out[0] as &byte, written, &ivf);
    const ivf_frame: IvfFrame = try ivf_frame_iterator_next(&iterator);

    var context: DecoderContext = try allocate_decoder_context(16, 64, 32, 32, 65536);
    defer free_decoder_context(&context);
    var decoder: Decoder = make_decoder(&context);
    var result: DecoderFrameResult = try decoder_decode_frame(&decoder, ivf_frame.payload.data, ivf_frame.payload.len);
    defer decoded_frame_release(&result.output) catch {};

    const defaults: Vp8Probs = vp8_default_probs();
    var changed: bool = false;
    var index: usize = 0;
    while index < 1056 {
        if decoder.coeff_probs[index] != defaults.coeff_probs[index] {
            changed = true;
        }
        index = index + 1;
    }

    try assert_eq_i32(changed as i32, false as i32);
}

test "encoder keyframe IVF output is deterministic for fixed input" {
    var input: [byte: 384] = [];
    var index: usize = 0;
    while index < 384 {
        input[index] = (((index * 37) + (index / 3) + 19) % (251 as usize)) as byte;
        index = index + 1;
    }

    var first_out: [byte: 4096] = [];
    var second_out: [byte: 4096] = [];
    const config: EncoderConfig = make_default_encoder_config(16, 16);
    const frame: YuvFrameView = try make_i420_frame_view(&input[0] as &byte, 384, 16, 16);

    const first_len: usize = try encode_keyframe_ivf(&config, &frame, &first_out[0] as &byte, 4096);
    const second_len: usize = try encode_keyframe_ivf(&config, &frame, &second_out[0] as &byte, 4096);

    try assert_eq_i32(first_len as i32, second_len as i32);
    index = 0;
    while index < first_len {
        try assert_eq_i32(first_out[index] as i32, second_out[index] as i32);
        index = index + 1;
    }
}
