test "scalar simple loop filter updates only p0 and q0 when threshold passes" {
    var vertical: [byte: 64] = [];
    var row: usize = 0;
    while row < 4 {
        const base: usize = row * 8;
        vertical[base + 1] = 100 as byte;
        vertical[base + 2] = 110 as byte;
        vertical[base + 3] = 120 as byte;
        vertical[base + 4] = 125 as byte;
        row = row + 1;
    }

    loop_filter_simple_vertical_edge(&vertical[0] as &byte, 8, 3, 4, 40 as u8);

    row = 0;
    while row < 4 {
        const base: usize = row * 8;
        try assert_eq_i32(vertical[base + 1] as i32, 100);
        try assert_eq_i32(vertical[base + 2] as i32, 111);
        try assert_eq_i32(vertical[base + 3] as i32, 119);
        try assert_eq_i32(vertical[base + 4] as i32, 125);
        row = row + 1;
    }

    var horizontal: [byte: 64] = [];
    var col: usize = 0;
    while col < 4 {
        horizontal[(1 * 8) + col] = 128 as byte;
        horizontal[(2 * 8) + col] = 122 as byte;
        horizontal[(3 * 8) + col] = 110 as byte;
        horizontal[(4 * 8) + col] = 100 as byte;
        col = col + 1;
    }

    loop_filter_simple_horizontal_edge(&horizontal[0] as &byte, 8, 3, 4, 40 as u8);

    col = 0;
    while col < 4 {
        try assert_eq_i32(horizontal[(1 * 8) + col] as i32, 128);
        try assert_eq_i32(horizontal[(2 * 8) + col] as i32, 121);
        try assert_eq_i32(horizontal[(3 * 8) + col] as i32, 111);
        try assert_eq_i32(horizontal[(4 * 8) + col] as i32, 100);
        col = col + 1;
    }
}

