use std.testing.assert_eq_i32;

use vp8.kernels.scalar.clamp_i16_to_i16;
use vp8.kernels.scalar.clamp_i32_to_i32;
use vp8.kernels.scalar.clip_i32_to_u8;
use vp8.kernels.scalar.clip_i16_to_u8;
use vp8.kernels.scalar.inverse_transform_dc_only_4x4;

test "scalar clamp helpers keep values inside signed bounds" {
    try assert_eq_i32(clamp_i32_to_i32(-300, -128, 127), -128);
    try assert_eq_i32(clamp_i32_to_i32(-128, -128, 127), -128);
    try assert_eq_i32(clamp_i32_to_i32(0, -128, 127), 0);
    try assert_eq_i32(clamp_i32_to_i32(127, -128, 127), 127);
    try assert_eq_i32(clamp_i32_to_i32(300, -128, 127), 127);

    try assert_eq_i32(clamp_i16_to_i16(-400 as i16, -127 as i16, 127 as i16) as i32, -127);
    try assert_eq_i32(clamp_i16_to_i16(64 as i16, -127 as i16, 127 as i16) as i32, 64);
    try assert_eq_i32(clamp_i16_to_i16(400 as i16, -127 as i16, 127 as i16) as i32, 127);
}

test "scalar clip helpers saturate reconstructed pixels to 8 bit" {
    try assert_eq_i32(clip_i32_to_u8(-4096) as i32, 0);
    try assert_eq_i32(clip_i32_to_u8(-1) as i32, 0);
    try assert_eq_i32(clip_i32_to_u8(0) as i32, 0);
    try assert_eq_i32(clip_i32_to_u8(128) as i32, 128);
    try assert_eq_i32(clip_i32_to_u8(255) as i32, 255);
    try assert_eq_i32(clip_i32_to_u8(256) as i32, 255);
    try assert_eq_i32(clip_i32_to_u8(4096) as i32, 255);

    try assert_eq_i32(clip_i16_to_u8(-1 as i16) as i32, 0);
    try assert_eq_i32(clip_i16_to_u8(42 as i16) as i32, 42);
    try assert_eq_i32(clip_i16_to_u8(300 as i16) as i32, 255);
}

fn assert_all_4x4(values: &i16, expected: i16) !void {
    var index: usize = 0;
    while index < 16 {
        try assert_eq_i32(values[index] as i32, expected as i32);
        index = index + 1;
    }
}

test "scalar DC only inverse transform fills deterministic residual block" {
    var out: [i16: 16] = [];

    inverse_transform_dc_only_4x4(32 as i16, &out[0] as &i16);
    try assert_all_4x4(&out[0] as &i16, 4 as i16);

    inverse_transform_dc_only_4x4(7 as i16, &out[0] as &i16);
    try assert_all_4x4(&out[0] as &i16, 1 as i16);

    inverse_transform_dc_only_4x4(-20 as i16, &out[0] as &i16);
    try assert_all_4x4(&out[0] as &i16, -2 as i16);
}
