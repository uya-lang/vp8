fn assert_loop_filter_thresholds(thresholds: LoopFilterThresholds, enabled: bool, filter_level: u8, limit: u8, macroblock_blimit: u8, subblock_blimit: u8, thresh: u8) !void {
    try assert_eq_i32(thresholds.enabled as i32, enabled as i32);
    try assert_eq_i32(thresholds.filter_level as i32, filter_level as i32);
    try assert_eq_i32(thresholds.limit as i32, limit as i32);
    try assert_eq_i32(thresholds.macroblock_blimit as i32, macroblock_blimit as i32);
    try assert_eq_i32(thresholds.subblock_blimit as i32, subblock_blimit as i32);
    try assert_eq_i32(thresholds.thresh as i32, thresh as i32);
}

test "scalar loop filter thresholds derive VP8 limit blimit and thresh" {
    var low_key: LoopFilterThresholds = build_loop_filter_thresholds(14, 0 as u8, true);
    try assert_loop_filter_thresholds(low_key, true, 14 as u8, 14 as u8, 46 as u8, 42 as u8, 0 as u8);

    var mid_key: LoopFilterThresholds = build_loop_filter_thresholds(15, 0 as u8, true);
    try assert_loop_filter_thresholds(mid_key, true, 15 as u8, 15 as u8, 49 as u8, 45 as u8, 1 as u8);

    var high_key: LoopFilterThresholds = build_loop_filter_thresholds(40, 0 as u8, true);
    try assert_loop_filter_thresholds(high_key, true, 40 as u8, 40 as u8, 124 as u8, 120 as u8, 2 as u8);

    var inter_twenty: LoopFilterThresholds = build_loop_filter_thresholds(20, 0 as u8, false);
    try assert_loop_filter_thresholds(inter_twenty, true, 20 as u8, 20 as u8, 64 as u8, 60 as u8, 2 as u8);

    var inter_forty: LoopFilterThresholds = build_loop_filter_thresholds(40, 0 as u8, false);
    try assert_loop_filter_thresholds(inter_forty, true, 40 as u8, 40 as u8, 124 as u8, 120 as u8, 3 as u8);
}

test "scalar loop filter thresholds apply sharpness and clamp adjusted levels" {
    var sharp_one: LoopFilterThresholds = build_loop_filter_thresholds(32, 1 as u8, true);
    try assert_loop_filter_thresholds(sharp_one, true, 32 as u8, 8 as u8, 76 as u8, 72 as u8, 1 as u8);

    var sharp_five: LoopFilterThresholds = build_loop_filter_thresholds(32, 5 as u8, true);
    try assert_loop_filter_thresholds(sharp_five, true, 32 as u8, 4 as u8, 72 as u8, 68 as u8, 1 as u8);

    var tiny_sharp: LoopFilterThresholds = build_loop_filter_thresholds(3, 7 as u8, true);
    try assert_loop_filter_thresholds(tiny_sharp, true, 3 as u8, 1 as u8, 11 as u8, 7 as u8, 0 as u8);

    var below_zero: LoopFilterThresholds = build_loop_filter_thresholds(-9, 0 as u8, false);
    try assert_loop_filter_thresholds(below_zero, false, 0 as u8, 1 as u8, 5 as u8, 1 as u8, 0 as u8);

    var above_range: LoopFilterThresholds = build_loop_filter_thresholds(99, 8 as u8, false);
    try assert_loop_filter_thresholds(above_range, true, 63 as u8, 2 as u8, 132 as u8, 128 as u8, 3 as u8);
}

fn write_vertical_filter_window(data: &byte, stride: usize, row: usize, edge_col: usize) void {
    const base: usize = row * stride;
    data[base + edge_col - 4] = 90 as byte;
    data[base + edge_col - 3] = 100 as byte;
    data[base + edge_col - 2] = 110 as byte;
    data[base + edge_col - 1] = 120 as byte;
    data[base + edge_col] = 125 as byte;
    data[base + edge_col + 1] = 130 as byte;
    data[base + edge_col + 2] = 140 as byte;
    data[base + edge_col + 3] = 150 as byte;
}

fn write_horizontal_filter_window(data: &byte, stride: usize, col: usize, edge_row: usize) void {
    data[((edge_row - 4) * stride) + col] = 90 as byte;
    data[((edge_row - 3) * stride) + col] = 100 as byte;
    data[((edge_row - 2) * stride) + col] = 110 as byte;
    data[((edge_row - 1) * stride) + col] = 120 as byte;
    data[(edge_row * stride) + col] = 125 as byte;
    data[((edge_row + 1) * stride) + col] = 130 as byte;
    data[((edge_row + 2) * stride) + col] = 140 as byte;
    data[((edge_row + 3) * stride) + col] = 150 as byte;
}

test "scalar normal macroblock loop filter dispatcher filters Y and UV edges" {
    var y_data: [byte: 1024] = [];
    var u_data: [byte: 256] = [];
    var v_data: [byte: 256] = [];
    var y: Plane = try make_plane_view(&y_data[0] as &byte, 1024, 32, 32, 32, 0);
    var u: Plane = try make_plane_view(&u_data[0] as &byte, 256, 16, 16, 16, 0);
    var v: Plane = try make_plane_view(&v_data[0] as &byte, 256, 16, 16, 16, 0);
    const thresholds: LoopFilterThresholds = LoopFilterThresholds{
        enabled: true,
        filter_level: 20 as u8,
        limit: 40 as u8,
        macroblock_blimit: 40 as u8,
        subblock_blimit: 40 as u8,
        thresh: 20 as u8
    };

    write_vertical_filter_window(&y_data[0] as &byte, 32, 20, 16);
    write_horizontal_filter_window(&y_data[0] as &byte, 32, 20, 16);
    write_vertical_filter_window(&u_data[0] as &byte, 16, 12, 8);
    write_horizontal_filter_window(&u_data[0] as &byte, 16, 12, 8);
    write_vertical_filter_window(&v_data[0] as &byte, 16, 12, 8);
    write_horizontal_filter_window(&v_data[0] as &byte, 16, 12, 8);

    loop_filter_normal_macroblock_edges_yuv(&y, &u, &v, 1, 1, &thresholds);

    try assert_eq_i32(y_data[(20 * 32) + 14] as i32, 109);
    try assert_eq_i32(y_data[(20 * 32) + 15] as i32, 119);
    try assert_eq_i32(y_data[(20 * 32) + 16] as i32, 126);
    try assert_eq_i32(y_data[(20 * 32) + 17] as i32, 131);
    try assert_eq_i32(y_data[(14 * 32) + 20] as i32, 109);
    try assert_eq_i32(y_data[(15 * 32) + 20] as i32, 119);
    try assert_eq_i32(y_data[(16 * 32) + 20] as i32, 126);
    try assert_eq_i32(y_data[(17 * 32) + 20] as i32, 131);

    try assert_eq_i32(u_data[(12 * 16) + 6] as i32, 109);
    try assert_eq_i32(u_data[(12 * 16) + 7] as i32, 119);
    try assert_eq_i32(u_data[(12 * 16) + 8] as i32, 126);
    try assert_eq_i32(u_data[(12 * 16) + 9] as i32, 131);
    try assert_eq_i32(u_data[(6 * 16) + 12] as i32, 109);
    try assert_eq_i32(u_data[(7 * 16) + 12] as i32, 119);
    try assert_eq_i32(u_data[(8 * 16) + 12] as i32, 126);
    try assert_eq_i32(u_data[(9 * 16) + 12] as i32, 131);
    try assert_eq_i32(v_data[(12 * 16) + 6] as i32, 109);
    try assert_eq_i32(v_data[(12 * 16) + 8] as i32, 126);
    try assert_eq_i32(v_data[(7 * 16) + 12] as i32, 119);
    try assert_eq_i32(v_data[(9 * 16) + 12] as i32, 131);
}

test "scalar normal subblock loop filter dispatcher filters Y and UV internal edges" {
    var y_data: [byte: 1024] = [];
    var u_data: [byte: 256] = [];
    var v_data: [byte: 256] = [];
    var y: Plane = try make_plane_view(&y_data[0] as &byte, 1024, 32, 32, 32, 0);
    var u: Plane = try make_plane_view(&u_data[0] as &byte, 256, 16, 16, 16, 0);
    var v: Plane = try make_plane_view(&v_data[0] as &byte, 256, 16, 16, 16, 0);
    const thresholds: LoopFilterThresholds = LoopFilterThresholds{
        enabled: true,
        filter_level: 20 as u8,
        limit: 40 as u8,
        macroblock_blimit: 40 as u8,
        subblock_blimit: 40 as u8,
        thresh: 20 as u8
    };

    write_vertical_filter_window(&y_data[0] as &byte, 32, 10, 4);
    write_horizontal_filter_window(&y_data[0] as &byte, 32, 10, 4);
    write_vertical_filter_window(&u_data[0] as &byte, 16, 6, 4);
    write_horizontal_filter_window(&u_data[0] as &byte, 16, 6, 4);
    write_vertical_filter_window(&v_data[0] as &byte, 16, 6, 4);
    write_horizontal_filter_window(&v_data[0] as &byte, 16, 6, 4);

    loop_filter_normal_subblock_edges_yuv(&y, &u, &v, 0, 0, &thresholds);

    try assert_eq_i32(y_data[(10 * 32) + 2] as i32, 111);
    try assert_eq_i32(y_data[(10 * 32) + 3] as i32, 122);
    try assert_eq_i32(y_data[(10 * 32) + 4] as i32, 123);
    try assert_eq_i32(y_data[(10 * 32) + 5] as i32, 129);
    try assert_eq_i32(y_data[(2 * 32) + 10] as i32, 111);
    try assert_eq_i32(y_data[(3 * 32) + 10] as i32, 122);
    try assert_eq_i32(y_data[(4 * 32) + 10] as i32, 123);
    try assert_eq_i32(y_data[(5 * 32) + 10] as i32, 129);

    try assert_eq_i32(u_data[(6 * 16) + 2] as i32, 111);
    try assert_eq_i32(u_data[(6 * 16) + 3] as i32, 122);
    try assert_eq_i32(u_data[(6 * 16) + 4] as i32, 123);
    try assert_eq_i32(u_data[(6 * 16) + 5] as i32, 129);
    try assert_eq_i32(v_data[(2 * 16) + 6] as i32, 111);
    try assert_eq_i32(v_data[(3 * 16) + 6] as i32, 122);
    try assert_eq_i32(v_data[(4 * 16) + 6] as i32, 123);
    try assert_eq_i32(v_data[(5 * 16) + 6] as i32, 129);
}
